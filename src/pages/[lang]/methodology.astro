---
import Base from '../../layouts/Base.astro';
import { LOCALES } from '../../i18n/locales';
import { t } from '../../i18n/t';

export function getStaticPaths() { return LOCALES.map((locale) => ({ params: { lang: locale.code } })); }
const { lang } = Astro.params;
const sections = [
  { mark: '節', title: t(lang, 'methodology.boundariesTitle'), body: t(lang, 'methodology.boundariesBody') },
  { mark: '時', title: t(lang, 'form.trueSolar'), body: t(lang, 'form.trueSolarHint') },
  { mark: '運', title: t(lang, 'reading.daeun'), body: t(lang, 'reading.daeunContext') },
  { mark: '判', title: t(lang, 'methodology.limitationsTitle'), body: t(lang, 'methodology.limitationsBody') },
];
---
<Base lang={lang} title={t(lang, 'methodology.title')} description={t(lang, 'methodology.lead')} path="methodology">
  <header class="methodology-hero">
    <p>CALCULATION TRANSPARENCY</p>
    <h1>{t(lang, 'methodology.title')}</h1>
    <span>{t(lang, 'methodology.lead')}</span>
  </header>

  <section class="methodology-grid">
    {sections.map((section, index) => (
      <article class="card methodology-card">
        <div><span aria-hidden="true">{section.mark}</span><small>{String(index + 1).padStart(2, '0')}</small></div>
        <h2>{section.title}</h2>
        <p>{section.body}</p>
      </article>
    ))}
  </section>

  <section class="card methodology-details">
    <div>
      <p>{t(lang, 'methodology.localTitle')}</p>
      <h2>{t(lang, 'privacy.leadStrong')}</h2>
      <span>{t(lang, 'methodology.localBody')}</span>
    </div>
    <dl>
      <div><dt>{t(lang, 'reading.hiddenStems')}</dt><dd>{t(lang, 'reading.hiddenStemsContext')}</dd></div>
      <div><dt>{t(lang, 'reading.seun')}</dt><dd>{t(lang, 'reading.seunContext')}</dd></div>
      <div><dt>{t(lang, 'reading.shinsal')}</dt><dd>{t(lang, 'reading.shinsalContext')}</dd></div>
    </dl>
  </section>

  <aside class="card verification-note">
    <span aria-hidden="true">✓</span>
    <div><h2>{t(lang, 'methodology.verificationTitle')}</h2><p>{t(lang, 'methodology.verificationBody')}</p></div>
  </aside>

  <style>
    .methodology-hero { max-width: 58rem; margin-block-end: clamp(3rem, 7vw, 5rem); }
    .methodology-hero > p { margin: 0 0 .65rem; color: var(--vermilion); font-family: var(--font-mono); font-size: .65rem; font-weight: 800; letter-spacing: .1em; }
    .methodology-hero h1 { margin: 0 0 1rem; font-size: var(--text-hero); }
    .methodology-hero > span { display: block; max-width: 50rem; color: var(--ink-soft); font-size: var(--text-lg); line-height: 1.7; }
    .methodology-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-5); }
    .methodology-card { padding: clamp(1.25rem, 4vw, 2rem); }
    .methodology-card > div { display: flex; align-items: center; justify-content: space-between; }
    .methodology-card > div span { display: grid; inline-size: 2.8rem; aspect-ratio: 1; place-items: center; border-radius: .85rem; color: var(--vermilion); background: var(--peach-pale); font-family: var(--font-display); font-size: 1.2rem; }
    .methodology-card small { color: var(--ink-soft); font-family: var(--font-mono); font-size: .6rem; }
    .methodology-card h2 { margin: 1rem 0 .55rem; font-size: var(--text-xl); }
    .methodology-card p { margin: 0; color: var(--ink-soft); line-height: 1.7; }
    .methodology-details { display: grid; grid-template-columns: minmax(0, .75fr) minmax(0, 1.25fr); gap: clamp(1.5rem, 5vw, 4rem); margin-block: clamp(3rem, 7vw, 5rem); padding: clamp(1.5rem, 5vw, 3rem); background: linear-gradient(135deg, var(--jade-pale), rgb(255 255 255 / .82)); }
    .methodology-details > div > p { margin: 0; color: var(--vermilion); font-family: var(--font-mono); font-size: .62rem; font-weight: 800; }
    .methodology-details h2 { margin: .55rem 0; font-size: var(--text-2xl); }
    .methodology-details > div > span { color: var(--ink-soft); line-height: 1.65; }
    .methodology-details dl { display: grid; gap: .7rem; margin: 0; }
    .methodology-details dl > div { padding: .9rem; border: 1px solid color-mix(in srgb, var(--indigo) 14%, var(--line)); border-radius: .8rem; background: rgb(255 255 255 / .64); }
    .methodology-details dt { color: var(--indigo); font-size: .75rem; font-weight: 800; }
    .methodology-details dd { margin: .35rem 0 0; color: var(--ink-soft); font-size: .68rem; line-height: 1.6; }
    .verification-note { display: grid; grid-template-columns: auto 1fr; align-items: center; gap: 1rem; max-width: 58rem; padding: 1.25rem; border-inline-start: 5px solid var(--gold); }
    .verification-note > span { display: grid; inline-size: 2.7rem; aspect-ratio: 1; place-items: center; border-radius: 50%; color: white; background: var(--indigo); }
    .verification-note h2 { margin: 0 0 .35rem; font-size: var(--text-lg); }
    .verification-note p { margin: 0; color: var(--ink-soft); font-size: var(--text-sm); }
    @media (max-width: 720px) { .methodology-grid, .methodology-details { grid-template-columns: 1fr; } }
  </style>
</Base>
