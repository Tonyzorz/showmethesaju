---
import Base from '../../layouts/Base.astro';
import { LOCALES } from '../../i18n/locales';
import { t } from '../../i18n/t';
import { TERMS } from '../../lib/glossary';

export function getStaticPaths() {
  return LOCALES.map((l) => ({ params: { lang: l.code } }));
}
const { lang } = Astro.params;
const faqLd = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: TERMS.map((tm) => ({
    '@type': 'Question', name: t(lang, `glossary.terms.${tm.key}.name`),
    acceptedAnswer: { '@type': 'Answer', text: t(lang, `glossary.terms.${tm.key}.def`) },
  })),
};
---
<Base lang={lang} title={t(lang, 'meta.glossary.title')} description={t(lang, 'meta.glossary.description')} path="glossary">
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <h1>{t(lang, 'glossary.title')}</h1>
  <div class="terms">
    {TERMS.map((tm) => (
      <article class="card term" id={tm.key}>
        <h2>{t(lang, `glossary.terms.${tm.key}.name`)} <span class="meta" lang="ko">{tm.hanja}</span> <span class="meta">{tm.roman}</span></h2>
        <p>{t(lang, `glossary.terms.${tm.key}.def`)}</p>
      </article>
    ))}
  </div>
  <style>
    .terms { display: grid; gap: var(--space-5); grid-template-columns: 1fr; }
    .term { padding: clamp(1.4rem, 4vw, 2rem); transition: transform var(--dur-fast), box-shadow var(--dur-fast); }
    .term:hover { transform: translateY(-3px); box-shadow: var(--shadow-float); }
    .term h2 { margin-top: 0; font-size: var(--text-lg); }
    .term p { margin-bottom: 0; color: var(--ink-soft); }
    .meta { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--ink-soft); font-weight: 400; margin-inline-start: var(--space-2); }
    @media (min-width: 760px) { .terms { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  </style>
</Base>
