---
import Base from '../../layouts/Base.astro';
import { LOCALES } from '../../i18n/locales';
import { t } from '../../i18n/t';
import { withBase } from '../../lib/paths';
export function getStaticPaths() { return LOCALES.map((l) => ({ params: { lang: l.code } })); }
const { lang } = Astro.params;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://showmethesaju.com';
const authorName = t(lang, 'about.authorName');
const authorProfile = 'https://github.com/Tonyzorz';
const issuesUrl = 'https://github.com/Tonyzorz/showmethesaju/issues';
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: authorName,
  jobTitle: t(lang, 'about.authorRole'),
  url: `${site}/${lang}/about/`,
  sameAs: [authorProfile],
};
---
<Base lang={lang} title={t(lang, 'meta.about.title')} description={t(lang, 'about.story')} path="about">
  <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <div class="about-page">
    <header class="about-intro">
      <p class="eyebrow">{t(lang, 'about.masterHeading')}</p>
      <h1>{t(lang, 'nav.about')}</h1>
      <p>{t(lang, 'about.story')}</p>
    </header>

    <section class="card author-card">
      <div class="author-seal" aria-hidden="true">{authorName.slice(0, 1)}</div>
      <div>
        <p class="author-role">{t(lang, 'about.authorRole')}</p>
        <h2>{authorName}</h2>
        <p>{t(lang, 'about.authorBio')}</p>
        <a class="text-link" href={authorProfile} rel="me noopener" target="_blank">{t(lang, 'about.authorLink')} ↗</a>
      </div>
    </section>

    <div class="about-grid">
      <article class="card about-detail">
        <span class="detail-number" aria-hidden="true">01</span>
        <h2>{t(lang, 'about.standardsTitle')}</h2>
        <p>{t(lang, 'about.standardsBody')}</p>
        <a class="text-link" href={withBase(`/${lang}/methodology/`)}>{t(lang, 'methodology.title')} →</a>
      </article>
      <article class="card about-detail">
        <span class="detail-number" aria-hidden="true">02</span>
        <h2>{t(lang, 'about.aiTitle')}</h2>
        <p>{t(lang, 'about.aiBody')}</p>
      </article>
    </div>

    <section class="card corrections-card">
      <div>
        <p class="eyebrow">{t(lang, 'about.correctionsTitle')}</p>
        <h2>{t(lang, 'about.correctionsHeading')}</h2>
        <p>{t(lang, 'about.correctionsBody')}</p>
      </div>
      <a class="btn-secondary" href={issuesUrl} rel="noopener" target="_blank">{t(lang, 'about.correctionsLink')} ↗</a>
    </section>

    <p class="disclaimer">{t(lang, 'reading.disclaimer')}</p>
  </div>
  <style>
    .about-page { max-width: var(--container-wide); margin: 0 auto; }
    .about-intro { max-width: var(--container-text); margin-block-end: var(--space-8); }
    .about-intro h1 { margin: var(--space-2) 0 var(--space-4); font-size: var(--text-3xl); }
    .about-intro > p:last-child { color: var(--ink-soft); font-size: var(--text-lg); line-height: var(--leading-body); }
    .eyebrow, .author-role { margin: 0; color: var(--gold-dark); font-size: var(--text-xs); font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
    .author-card { display: grid; grid-template-columns: auto 1fr; gap: clamp(1.25rem, 4vw, 2.5rem); align-items: start; padding: clamp(1.5rem, 4vw, 2.75rem); border-top: 4px solid var(--indigo); }
    .author-seal { display: grid; place-items: center; width: clamp(4.5rem, 10vw, 6.5rem); aspect-ratio: 1; border: 1px solid var(--line-strong); border-radius: 30% 70% 58% 42% / 42% 35% 65% 58%; background: var(--paper-deep); color: var(--indigo); font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.25rem); }
    .author-card h2 { margin: var(--space-2) 0 var(--space-3); font-size: var(--text-2xl); }
    .author-card p:not(.author-role), .about-detail p, .corrections-card p { color: var(--ink-soft); line-height: var(--leading-body); }
    .text-link { display: inline-flex; margin-top: var(--space-3); font-weight: 800; text-decoration-thickness: 1px; text-underline-offset: .25em; }
    .about-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-4); margin-block: var(--space-4); }
    .about-detail { position: relative; overflow: hidden; padding: clamp(1.5rem, 4vw, 2.5rem); }
    .about-detail h2 { max-width: 18ch; margin: var(--space-6) 0 var(--space-3); font-size: var(--text-xl); }
    .detail-number { color: var(--indigo); font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 800; }
    .corrections-card { display: flex; align-items: center; justify-content: space-between; gap: var(--space-6); padding: clamp(1.5rem, 4vw, 2.5rem); }
    .corrections-card > div { max-width: var(--container-text); }
    .corrections-card h2 { margin: var(--space-2) 0 var(--space-3); font-size: var(--text-xl); }
    .corrections-card .btn-secondary { flex: none; }
    .disclaimer { max-width: var(--container-text); margin: var(--space-8) auto 0; color: var(--ink-soft); font-size: var(--text-sm); text-align: center; }
    @media (max-width: 720px) {
      .author-card, .about-grid { grid-template-columns: 1fr; }
      .corrections-card { align-items: flex-start; flex-direction: column; }
    }
  </style>
</Base>
