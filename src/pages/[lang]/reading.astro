    function renderShinsal(r: SajuResult) {
      type AnyOccurrence = { name: string; targetRole: PillarRole; targetBranch: number };
      const grouped = new Map<string, AnyOccurrence[]>();
      for (const occurrence of [...r.shinsal, ...extraShinsal(r)] as AnyOccurrence[]) {
        const group = grouped.get(occurrence.name) ?? [];
        group.push(occurrence);
        grouped.set(occurrence.name, group);
      }
      const order: string[] = [
        'cheonEul', 'cheonDeok', 'wolDeok', 'munChang', 'geonRok', 'yangIn',
        'amNok', 'geumYeo', 'cheonUi',
        'peachBlossom', 'hongYeom', 'travelHorse', 'flowerCanopy', 'gongMang',
        'hyeonChim', 'goRan', 'baekHo', 'gwaeGang',
      ];
      const cards = order.filter((name) => grouped.has(name)).map((name) => {
        const occurrences = grouped.get(name)!;
        return `<article class="shinsal-item">
          <strong>${shinsalLabel(name)}</strong>
          <span>${occurrences.map((item) => `${roleLabels[item.targetRole]} ${BRANCHES_HANJA[item.targetBranch]}`).join(' · ')}</span>
        </article>`;
      });
      document.getElementById('shinsal-list')!.innerHTML = cards.length
        ? cards.join('')
        : `<p class="empty-state">${S['shinsalNone']}</p>`;
    }

