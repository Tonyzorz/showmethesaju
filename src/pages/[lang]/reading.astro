---
import Base from '../../layouts/Base.astro';
import GlossaryTooltip from '../../components/GlossaryTooltip.astro';
import { LOCALES } from '../../i18n/locales';
import { t, ns } from '../../i18n/t';
import { withBase } from '../../lib/paths';

export function getStaticPaths() {
  return LOCALES.map((l) => ({ params: { lang: l.code } }));
}
const { lang } = Astro.params;
const strings = {
  ...ns(lang, 'reading'),
  cta: t(lang, 'hero.cta'),
  siteName: t(lang, 'meta.siteName'),
  genderFemale: t(lang, 'form.genderF'),
  genderMale: t(lang, 'form.genderM'),
};
---
<Base lang={lang} title={t(lang, 'meta.reading.title')} path="reading" noindex>
  <script type="application/json" id="i18n-reading" set:html={JSON.stringify(strings)} />

  <section id="loading-state" class="loading-state" aria-live="polite">
    <span class="loading-mark" aria-hidden="true"></span>
    <h1>{t(lang, 'reading.yourPillars')}</h1>
    <p>{t(lang, 'readingLoading')}</p>
    <a href={withBase(`/${lang}/`)}>{t(lang, 'hero.cta')}</a>
  </section>

  <section id="result" hidden>
    <header class="result-hero">
      <div class="result-kicker" aria-hidden="true"><span></span> 木 · 火 · 土 · 金 · 水</div>
      <h1>{t(lang, 'reading.yourPillars')}</h1>
      <p id="birth-summary" class="birth-summary"></p>
      <div class="element-ribbon" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
    </header>
    <p id="boundary-note" class="note" hidden></p>
    <div id="pillars" class="pillars"></div>

    <h2 class="section-title">{t(lang, 'reading.chartAtGlance')}</h2>
    <div class="insight-grid">
      <section class="card panel day-master-panel">
        <div class="panel-heading">
          <h2><button class="gloss" data-gloss="ilgan" type="button">{t(lang, 'reading.dayMaster')}</button></h2>
          <span class="panel-index" aria-hidden="true">01</span>
        </div>
        <div class="day-master-layout">
          <div class="dm-symbol" id="dm-symbol">
            <span id="dm-char" lang="ko"></span>
            <small id="dm-reading"></small>
          </div>
          <p id="dm-text"></p>
        </div>
      </section>
      <section class="card panel yin-yang-panel">
        <div class="panel-heading">
          <h2>{t(lang, 'reading.yinYangBalance')}</h2>
          <span class="panel-index" aria-hidden="true">02</span>
        </div>
        <div class="yy-layout">
          <div id="yy-donut" class="yy-donut" role="img">
            <div class="yy-center"><strong id="yy-ratio">0%</strong><span>陽</span></div>
          </div>
          <div class="yy-details">
            <div class="yy-legend" aria-hidden="true">
              <span><i class="yang-dot"></i>陽 <strong id="yy-yang-count">0</strong></span>
              <span><i class="yin-dot"></i>陰 <strong id="yy-yin-count">0</strong></span>
            </div>
            <p id="yy-text"></p>
          </div>
        </div>
      </section>
    </div>

    <section class="card panel element-panel">
      <div class="panel-heading">
        <div>
          <p class="panel-overline">{t(lang, 'reading.elementPattern')}</p>
          <h2><button class="gloss" data-gloss="ohaeng" type="button">{t(lang, 'reading.elements')}</button></h2>
        </div>
        <span class="panel-index" aria-hidden="true">03</span>
      </div>
      <div class="element-dashboard">
        <div class="radar-wrap">
          <svg id="element-radar" viewBox="0 0 360 340" role="img" aria-label={t(lang, 'reading.elements')}>
            <g id="radar-grid"></g>
            <polygon id="radar-shape" points="180,170 180,170 180,170 180,170 180,170"></polygon>
            <g id="radar-points"></g>
            <g id="radar-labels"></g>
          </svg>
        </div>
        <div class="element-breakdown">
          <div id="element-bars" class="element-bars"></div>
          <div class="pattern-summary">
            <p id="dominant-text"></p>
            <p id="missing-text" class="soft"></p>
          </div>
        </div>
      </div>
      <p class="soft context-note">{t(lang, 'reading.elementContext')}</p>
    </section>

    <section class="card panel gods-panel">
      <div class="panel-heading">
        <h2><button class="gloss" data-gloss="sipseong" type="button">{t(lang, 'reading.tenGods')}</button></h2>
        <span class="panel-index" aria-hidden="true">04</span>
      </div>
      <div class="table-scroll"><table id="tengods" class="tengods"></table></div>
      <p class="soft context-note">{t(lang, 'reading.tenGodsContext')}</p>
    </section>

    <section class="card panel hidden-stems-panel">
      <div class="panel-heading">
        <h2>{t(lang, 'reading.hiddenStems')}</h2>
        <span class="panel-index" aria-hidden="true">05</span>
      </div>
      <div id="hidden-stems" class="hidden-stems-grid"></div>
      <p class="soft context-note">{t(lang, 'reading.hiddenStemsContext')}</p>
    </section>

    <div class="analysis-grid">
      <section class="card panel relations-panel">
        <div class="panel-heading">
          <h2>{t(lang, 'reading.branchRelations')}</h2>
          <span class="panel-index" aria-hidden="true">06</span>
        </div>
        <div id="branch-relations" class="relation-list"></div>
        <p class="soft context-note">{t(lang, 'reading.relationsContext')}</p>
      </section>
      <section class="card panel shinsal-panel">
        <div class="panel-heading">
          <h2>{t(lang, 'reading.shinsal')}</h2>
          <span class="panel-index" aria-hidden="true">07</span>
        </div>
        <div id="shinsal-list" class="shinsal-list"></div>
        <p class="soft context-note">{t(lang, 'reading.shinsalContext')}</p>
      </section>
    </div>

    <section class="card panel luck-panel daeun-panel">
      <div class="panel-heading">
        <div>
          <p class="panel-overline">10 YEAR CYCLES</p>
          <h2>{t(lang, 'reading.daeun')}</h2>
        </div>
        <span class="panel-index" aria-hidden="true">08</span>
      </div>
      <p id="daeun-meta" class="luck-meta"></p>
      <div id="daeun-list" class="luck-strip"></div>
      <div id="daeun-detail" class="luck-detail"></div>
      <p class="soft context-note">{t(lang, 'reading.daeunContext')}</p>
    </section>

    <section class="card panel luck-panel seun-panel">
      <div class="panel-heading">
        <div>
          <p class="panel-overline">YEARLY CYCLES</p>
          <h2>{t(lang, 'reading.seun')}</h2>
        </div>
        <span class="panel-index" aria-hidden="true">09</span>
      </div>
      <div id="seun-list" class="luck-strip luck-strip--annual"></div>
      <div id="seun-detail" class="luck-detail"></div>
      <p class="soft context-note">{t(lang, 'reading.seunContext')}</p>
    </section>

    <section class="pillar-guide">
      <h2>{t(lang, 'reading.pillarRoles')}</h2>
      <div class="role-grid">
        {(['year', 'month', 'day', 'hour'] as const).map((role) => (
          <article class="role-card">
            <span aria-hidden="true">{role === 'year' ? '年' : role === 'month' ? '月' : role === 'day' ? '日' : '時'}</span>
            <h3>{t(lang, `reading.role.${role}.title`)}</h3>
            <p>{t(lang, `reading.role.${role}.body`)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="card reading-guide">
      <div aria-hidden="true" class="guide-mark">讀</div>
      <div>
        <h2>{t(lang, 'reading.readingGuide.title')}</h2>
        <p>{t(lang, 'reading.readingGuide.body')}</p>
      </div>
    </section>

    <div class="actions card">
      <button id="share-url" class="btn-secondary" type="button">{t(lang, 'reading.share')}</button>
      <button id="share-png" class="btn-primary" type="button">{t(lang, 'reading.sharePng')}</button>
      <a class="btn-secondary" href={withBase(`/${lang}/learn/`)} data-analytics-event="navigation_click" data-analytics-destination="learn_from_chart" data-analytics-area="reading_actions">{t(lang, 'reading.learnMore')}</a>
    </div>
    <p class="disclaimer">{t(lang, 'reading.disclaimer')}</p>
  </section>

  <section id="no-query" hidden>
    <h1>{t(lang, 'reading.yourPillars')}</h1>
    <p id="render-error" class="note" hidden>{t(lang, 'readingError')}</p>
    <p><a class="btn-primary" href={withBase(`/${lang}/`)}>{t(lang, 'hero.cta')}</a></p>
  </section>

  <GlossaryTooltip lang={lang} />

  <script>
    import {
      BRANCHES_HANJA,
      computeAnnualLuck,
      computeSaju,
      hiddenStemsForBranch,
      ipchunUtcMs,
      type AnnualLuck,
      type LuckCycle,
      type Pillar,
      type PillarRole,
      type SajuResult,
      type ShinsalName,
    } from '../../lib/saju-engine';
    import { trackEvent } from '../../lib/analytics';

    const S: Record<string, string> = JSON.parse(document.getElementById('i18n-reading')!.textContent!);
    const q = new URLSearchParams(location.search);
    const fmt = (template: string, vars: Record<string, string | number>) =>
      Object.entries(vars).reduce((text, [key, value]) => text.replaceAll(`{${key}}`, String(value)), template);
    const tenGodLabel = (name: string | null) => name ? (S[`tg.${name}`] ?? name) : S['notApplicable'];

    const values = {
      year: Number(q.get('y')), month: Number(q.get('m')), day: Number(q.get('d')),
      hour: Number(q.get('h')), minute: Number(q.get('mi')),
      tzOffsetMinutes: Number(q.get('tz')), longitude: Number(q.get('lon')),
    };
    const gender = q.get('g') === 'f' ? 'female' : q.get('g') === 'm' ? 'male' : undefined;
    const dateCheck = new Date(Date.UTC(values.year, values.month - 1, values.day));
    const validQuery = q.has('y') && (!q.has('g') || Boolean(gender)) && Object.values(values).every(Number.isFinite) &&
      values.year >= 1900 && values.year <= 2050 &&
      dateCheck.getUTCFullYear() === values.year && dateCheck.getUTCMonth() === values.month - 1 && dateCheck.getUTCDate() === values.day &&
      values.hour >= 0 && values.hour <= 23 && values.minute >= 0 && values.minute <= 59 &&
      values.tzOffsetMinutes >= -840 && values.tzOffsetMinutes <= 840 &&
      values.longitude >= -180 && values.longitude <= 180;

    function pillarCard(p: Pillar | null, label: string, i: number): string {
      if (!p) return `<article class="pillar pillar-empty reveal" style="--reveal-i:${i}">
        <header class="pillar-top"><span class="pillar-label">${label}</span></header>
        <p class="hint">${S['hourUnknown']}</p>
      </article>`;
      const tg = `<span class="ten-god">${tenGodLabel(p.tenGod)}</span>`;
      return `<article class="pillar pillar--${p.stemElement} reveal" style="--reveal-i:${i}">
        <header class="pillar-top"><span class="pillar-label">${label}</span>${tg}</header>
        <div class="glyph-stack" lang="ko">
          <span class="pillar-glyph element-text--${p.stemElement}">${p.stemHanja}</span>
          <span class="glyph-bridge" aria-hidden="true"></span>
          <span class="pillar-glyph element-text--${p.branchElement}">${p.branchHanja}</span>
        </div>
        <footer class="pillar-bottom">
          <strong>${p.stemKo}${p.branchKo}</strong>
          <span class="element-pair"><i class="element-dot element-bg--${p.stemElement}"></i>${S[`el.${p.stemElement}`]}<b>·</b><i class="element-dot element-bg--${p.branchElement}"></i>${S[`el.${p.branchElement}`]}</span>
        </footer>
      </article>`;
    }

    const elementOrder = ['wood', 'fire', 'earth', 'metal', 'water'] as const;
    const svgPoint = (index: number, ratio: number, radius = 112) => {
      const angle = (-90 + index * 72) * Math.PI / 180;
      return [180 + Math.cos(angle) * radius * ratio, 165 + Math.sin(angle) * radius * ratio] as const;
    };
    const svgPoints = (ratio: number, radius = 112) => elementOrder
      .map((_, index) => svgPoint(index, ratio, radius).map((n) => n.toFixed(1)).join(','))
      .join(' ');

    function renderElementRadar(counts: SajuResult['elementCounts'], total: number) {
      const grid = document.getElementById('radar-grid')!;
      grid.innerHTML = [0.25, 0.5, 0.75, 1]
        .map((level) => `<polygon class="radar-level" points="${svgPoints(level)}"></polygon>`)
        .join('') + elementOrder.map((_, index) => {
          const [x, y] = svgPoint(index, 1);
          return `<line class="radar-axis" x1="180" y1="165" x2="${x.toFixed(1)}" y2="${y.toFixed(1)}"></line>`;
        }).join('');

      const dataPoints = elementOrder.map((element, index) => svgPoint(index, counts[element] / total));
      document.getElementById('radar-shape')!.setAttribute('points', dataPoints
        .map(([x, y]) => `${x.toFixed(1)},${y.toFixed(1)}`)
        .join(' '));
      document.getElementById('radar-points')!.innerHTML = dataPoints.map(([x, y], index) =>
        `<circle class="radar-point element-fill--${elementOrder[index]}" cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="5"></circle>`
      ).join('');
      document.getElementById('radar-labels')!.innerHTML = elementOrder.map((element, index) => {
        const [x, y] = svgPoint(index, 1, 142);
        return `<text class="radar-label element-fill--${element}" x="${x.toFixed(1)}" y="${y.toFixed(1)}">${S[`el.${element}`]}</text>`;
      }).join('');
      document.getElementById('element-radar')!.setAttribute('aria-label', elementOrder
        .map((element) => `${S[`el.${element}`]} ${counts[element]}`).join(', '));
    }

    const roleLabels: Record<PillarRole, string> = {
      year: S['pillarYear'], month: S['pillarMonth'], day: S['pillarDay'], hour: S['pillarHour'],
    };
    const relationLabel = (type: string) => S[`rel.${type}`] ?? type;
    const shinsalLabel = (name: ShinsalName) => S[`shinsal.${name}`] ?? name;
    const ageLabel = (totalMonths: number) => fmt(S['ageYearsMonths'], {
      years: Math.floor(totalMonths / 12), months: totalMonths % 12,
    });

    function hiddenStemMarkup(branch: number, r: SajuResult) {
      return hiddenStemsForBranch(branch, r.day.stem).map((hidden) =>
        `<span class="hidden-chip">
          <small>${S[`qi.${hidden.phase}`]}</small>
          <strong class="element-text--${hidden.element}" lang="ko">${hidden.stemHanja}</strong>
          <span>${tenGodLabel(hidden.tenGod)}</span>
        </span>`
      ).join('');
    }

    function renderHiddenStems(r: SajuResult) {
      const rows: [PillarRole, Pillar | null][] = [
        ['hour', r.hour], ['day', r.day], ['month', r.month], ['year', r.year],
      ];
      document.getElementById('hidden-stems')!.innerHTML = rows.map(([role, pillar]) =>
        `<article class="hidden-pillar">
          <header><span>${roleLabels[role]}</span>${pillar ? `<strong lang="ko">${pillar.branchHanja}</strong>` : ''}</header>
          <div>${pillar ? hiddenStemMarkup(pillar.branch, r) : `<span class="soft">${S['hourUnknown']}</span>`}</div>
        </article>`
      ).join('');
    }

    function renderRelations(r: SajuResult) {
      const target = document.getElementById('branch-relations')!;
      target.innerHTML = r.relations.length ? r.relations.map((relation) =>
        `<div class="relation-item">
          <span class="relation-badge relation-badge--${relation.type}">${relationLabel(relation.type)}</span>
          <strong lang="ko">${BRANCHES_HANJA[relation.leftBranch]} ↔ ${BRANCHES_HANJA[relation.rightBranch]}</strong>
          <small>${roleLabels[relation.leftRole]} · ${roleLabels[relation.rightRole]}</small>
        </div>`
      ).join('') : `<p class="empty-state">${S['relationNone']}</p>`;
    }

    function renderShinsal(r: SajuResult) {
      const grouped = new Map<ShinsalName, typeof r.shinsal>();
      for (const occurrence of r.shinsal) {
        const group = grouped.get(occurrence.name) ?? [];
        group.push(occurrence);
        grouped.set(occurrence.name, group);
      }
      const order: ShinsalName[] = ['cheonEul', 'munChang', 'peachBlossom', 'travelHorse', 'flowerCanopy', 'gongMang'];
      const cards = order.filter((name) => grouped.has(name)).map((name) => {
        const occurrences = grouped.get(name)!;
        return `<article class="shinsal-item">
          <strong>${shinsalLabel(name)}</strong>
          <span>${occurrences.map((item) => `${roleLabels[item.targetRole]} ${BRANCHES_HANJA[item.targetBranch]}`).join(' · ')}</span>
        </article>`;
      });
      document.getElementById('shinsal-list')!.innerHTML = cards.length
        ? cards.join('')
        : `<p class="empty-state">${S['shinsalNone']}</p>`;
    }

    function renderLuckDetail(cycle: LuckCycle, title: string, target: HTMLElement, r: SajuResult) {
      const relationBadges = cycle.relations.length
        ? cycle.relations.map((relation) => `<span class="detail-badge">${relationLabel(relation.type)} · ${roleLabels[relation.natalRole]} ${BRANCHES_HANJA[relation.natalBranch]}</span>`).join('')
        : `<span class="soft">${S['relationNone']}</span>`;
      const shinsalBadges = cycle.shinsal.length
        ? cycle.shinsal.map((name) => `<span class="detail-badge detail-badge--jade">${shinsalLabel(name)}</span>`).join('')
        : `<span class="soft">${S['shinsalNone']}</span>`;
      target.innerHTML = `<div class="luck-detail__pillar">
          <small>${title}</small>
          <strong class="element-text--${cycle.pillar.stemElement}" lang="ko">${cycle.pillar.hanja}</strong>
          <span>${tenGodLabel(cycle.pillar.tenGod)}</span>
        </div>
        <div class="luck-detail__group"><h3>${S['hiddenStems']}</h3><div class="hidden-inline">${hiddenStemMarkup(cycle.pillar.branch, r)}</div></div>
        <div class="luck-detail__group"><h3>${S['branchRelations']}</h3><div class="detail-badges">${relationBadges}</div></div>
        <div class="luck-detail__group"><h3>${S['shinsal']}</h3><div class="detail-badges">${shinsalBadges}</div></div>`;
    }

    function setupLuckStrip(
      list: HTMLElement,
      detail: HTMLElement,
      cycles: LuckCycle[],
      labels: string[],
      sublabels: string[],
      selectedIndex: number,
      cycleType: 'daeun' | 'seun',
      r: SajuResult,
    ) {
      list.innerHTML = cycles.map((cycle, index) =>
        `<button class="luck-card${index === selectedIndex ? ' is-selected' : ''}" type="button" data-cycle-index="${index}" aria-pressed="${index === selectedIndex}">
          <small>${labels[index]}</small>
          <strong class="element-text--${cycle.pillar.stemElement}" lang="ko">${cycle.pillar.hanja}</strong>
          <span>${sublabels[index]}</span>
          <i aria-hidden="true">${cycle.relations.length + cycle.shinsal.length}</i>
        </button>`
      ).join('');
      const selectCycle = (index: number, track = false) => {
        list.querySelectorAll<HTMLButtonElement>('.luck-card').forEach((button, buttonIndex) => {
          button.classList.toggle('is-selected', buttonIndex === index);
          button.setAttribute('aria-pressed', String(buttonIndex === index));
        });
        renderLuckDetail(cycles[index], labels[index], detail, r);
        if (track) trackEvent('luck_cycle_select', { cycle_type: cycleType, cycle_index: index, language: document.documentElement.lang });
      };
      list.querySelectorAll<HTMLButtonElement>('.luck-card').forEach((button) =>
        button.addEventListener('click', () => selectCycle(Number(button.dataset.cycleIndex), true))
      );
      selectCycle(selectedIndex);
    }

    function renderLuck(r: SajuResult, timeUnknown: boolean) {
      const daeunList = document.getElementById('daeun-list')!;
      const daeunDetail = document.getElementById('daeun-detail')!;
      const daeunMeta = document.getElementById('daeun-meta')!;
      if (!r.daeun || !r.gender) {
        daeunMeta.textContent = S['genderRequired'];
        daeunList.innerHTML = '';
        daeunDetail.innerHTML = '';
      } else {
        const genderLabel = r.gender === 'female' ? S['genderFemale'] : S['genderMale'];
        daeunMeta.textContent = fmt(S['daeunMeta'], {
          gender: genderLabel,
          direction: S[r.daeun.direction],
          age: ageLabel(r.daeun.startAgeMonths),
        }) + (timeUnknown ? ` ${S['daeunApproximate']}` : '');
        const now = new Date();
        let currentAgeMonths = (now.getFullYear() - values.year) * 12 + now.getMonth() - (values.month - 1);
        if (now.getDate() < values.day) currentAgeMonths--;
        let activeDaeun = 0;
        r.daeun.cycles.forEach((cycle, index) => { if (cycle.startAgeMonths <= currentAgeMonths) activeDaeun = index; });
        setupLuckStrip(
          daeunList, daeunDetail, r.daeun.cycles,
          r.daeun.cycles.map((cycle) => ageLabel(cycle.startAgeMonths)),
          r.daeun.cycles.map((cycle) => fmt(S['startYear'], { year: cycle.startYear })),
          activeDaeun, 'daeun', r,
        );
      }

      const now = new Date();
      const civilYear = now.getFullYear();
      const currentSajuYear = now.getTime() < ipchunUtcMs(civilYear) ? civilYear - 1 : civilYear;
      const annual: AnnualLuck[] = computeAnnualLuck(r, currentSajuYear - 1, 12);
      setupLuckStrip(
        document.getElementById('seun-list')!, document.getElementById('seun-detail')!, annual,
        annual.map((cycle) => fmt(S['ipchunYear'], { year: cycle.year })),
        annual.map((cycle) => tenGodLabel(cycle.pillar.tenGod)),
        1, 'seun', r,
      );
    }

    function render(r: SajuResult, timeUnknown: boolean) {
      const locale = document.documentElement.lang || 'en';
      const birthDate = new Date(Date.UTC(values.year, values.month - 1, values.day, values.hour, values.minute));
      const formattedBirth = new Intl.DateTimeFormat(locale, timeUnknown
        ? { dateStyle: 'long', timeZone: 'UTC' }
        : { dateStyle: 'long', timeStyle: 'short', timeZone: 'UTC' }
      ).format(birthDate);
      const offsetSign = values.tzOffsetMinutes >= 0 ? '+' : '-';
      const offsetHours = String(Math.floor(Math.abs(values.tzOffsetMinutes) / 60)).padStart(2, '0');
      const offsetMinutes = String(Math.abs(values.tzOffsetMinutes) % 60).padStart(2, '0');
      const genderSummary = gender === 'female' ? S['genderFemale'] : gender === 'male' ? S['genderMale'] : '';
      document.getElementById('birth-summary')!.textContent = `${formattedBirth} · UTC${offsetSign}${offsetHours}:${offsetMinutes}${genderSummary ? ` · ${genderSummary}` : ''}`;

      // Pillars, traditional right-to-left order: 시 일 월 년 — but web reading order wins: hour…year reversed.
      document.getElementById('pillars')!.innerHTML = [
        pillarCard(r.hour, S['pillarHour'], 0),
        pillarCard(r.day, S['pillarDay'], 1),
        pillarCard(r.month, S['pillarMonth'], 2),
        pillarCard(r.year, S['pillarYear'], 3),
      ].join('');

      // Day master
      document.getElementById('dm-char')!.textContent = r.dayMaster.hanja;
      document.getElementById('dm-reading')!.textContent = r.dayMaster.ko;
      document.getElementById('dm-symbol')!.classList.add(`element-bg-soft--${r.dayMaster.element}`, `element-text--${r.dayMaster.element}`);
      document.getElementById('dm-text')!.textContent = S[`dm.${r.day.stem}`] ?? '';

      // Yin/yang overview across every visible stem and branch.
      const visiblePillars = [r.year, r.month, r.day, r.hour].filter((p): p is Pillar => !!p);
      const yang = visiblePillars.reduce((sum, p) => sum + Number(p.stemYang) + Number(p.branchYang), 0);
      const totalPolarity = visiblePillars.length * 2;
      const yin = totalPolarity - yang;
      const yangPercent = Math.round(yang / totalPolarity * 100);
      const yinYangText = fmt(S['yinYangSummary'], { yang, yin });
      const donut = document.getElementById('yy-donut') as HTMLElement;
      donut.style.setProperty('--yang-angle', `${yang / totalPolarity * 360}deg`);
      donut.setAttribute('aria-label', yinYangText);
      document.getElementById('yy-ratio')!.textContent = `${yangPercent}%`;
      document.getElementById('yy-yang-count')!.textContent = String(yang);
      document.getElementById('yy-yin-count')!.textContent = String(yin);
      document.getElementById('yy-text')!.textContent = yinYangText;

      // Element bars
      const total = Object.values(r.elementCounts).reduce((a, b) => a + b, 0) || 1;
      const rankedElements = (Object.entries(r.elementCounts) as [string, number][]).sort((a, b) => b[1] - a[1]);
      const [dominant, dominantCount] = rankedElements[0];
      const missing = rankedElements.filter(([, count]) => count === 0).map(([element]) => S[`el.${element}`]);
      document.getElementById('dominant-text')!.textContent = fmt(S['dominantSummary'], {
        element: S[`el.${dominant}`], count: dominantCount, total,
      });
      document.getElementById('missing-text')!.textContent = missing.length
        ? fmt(S['missingSummary'], { elements: missing.join(', ') })
        : S['noMissingElements'];
      document.getElementById('element-bars')!.innerHTML = elementOrder.map((el) => {
        const n = r.elementCounts[el];
        const percent = Math.round(n / total * 100);
        return `<div class="ebar" role="img" aria-label="${S[`el.${el}`]} ${n} / ${total}">
          <span class="ebar-label"><i class="element-dot element-bg--${el}"></i>${S[`el.${el}`]}</span>
          <span class="ebar-track"><span class="ebar-fill element-bg--${el}" style="--bar-width:${percent}%"></span></span>
          <span class="ebar-n"><strong>${n}</strong><small>${percent}%</small></span>
        </div>`;
      }).join('');
      renderElementRadar(r.elementCounts, total);

      // Ten gods table
      const rows = [
        [S['pillarHour'], r.hour], [S['pillarDay'], r.day], [S['pillarMonth'], r.month], [S['pillarYear'], r.year],
      ] as const;
      document.getElementById('tengods')!.innerHTML =
        `<thead><tr><th scope="col"></th><th scope="col"><button class="gloss" data-gloss="cheongan" type="button">${S['heavenlyStem']}</button></th><th scope="col"><button class="gloss" data-gloss="sipseong" type="button">${S['tenGods']}</button></th></tr></thead><tbody>` +
        rows.map(([label, p]) => p
          ? `<tr><th scope="row">${label}</th><td data-label="${S['heavenlyStem']}" lang="ko"><span class="stem-badge element-text--${p.stemElement}">${p.stemHanja}</span> ${p.stemKo}</td><td data-label="${S['tenGods']}"><span class="god-badge">${tenGodLabel(p.tenGod)}</span></td></tr>`
          : `<tr><th scope="row">${label}</th><td colspan="2">—</td></tr>`
        ).join('') + `</tbody>`;

      renderHiddenStems(r);
      renderRelations(r);
      renderShinsal(r);
      renderLuck(r, timeUnknown);

      // Term-boundary warning: within ~0.15° of a 30° boundary (≈ a few hours), or time unknown near one.
      const off = ((r.solarLongitude - 315) % 30 + 30) % 30;
      if (Math.min(off, 30 - off) < (timeUnknown ? 0.6 : 0.15)) {
        const note = document.getElementById('boundary-note')!;
        note.textContent = S['termBoundaryNote'];
        note.hidden = false;
      }

      // Share: copy URL
      document.getElementById('share-url')!.addEventListener('click', async (e) => {
        try {
          await navigator.clipboard.writeText(location.href);
        } catch {
          const input = document.createElement('textarea');
          input.value = location.href;
          document.body.append(input);
          input.select();
          document.execCommand('copy');
          input.remove();
        }
        (e.currentTarget as HTMLElement).textContent = S['shared'];
        trackEvent('share', { method: 'link', content_type: 'saju_chart', language: document.documentElement.lang });
      });

      // Share: PNG card (square 1080). Fonts must be loaded before drawing hanja.
      document.getElementById('share-png')!.addEventListener('click', async () => {
        await (document as any).fonts?.ready;
        const c = document.createElement('canvas');
        c.width = 1080; c.height = 1080;
        const ctx = c.getContext('2d')!;
        const css = getComputedStyle(document.documentElement);
        const v = (n: string) => css.getPropertyValue(n).trim();
        ctx.fillStyle = v('--paper'); ctx.fillRect(0, 0, 1080, 1080);
        ctx.fillStyle = v('--ink');
        ctx.font = '700 56px "Gowun Batang", serif';
        ctx.textAlign = 'center';
        ctx.fillText(S['yourPillars'], 540, 130);
        const ps = [r.year, r.month, r.day, r.hour];
        ps.forEach((p, i) => {
          const x = 180 + i * 240;
          ctx.strokeStyle = v('--line'); ctx.lineWidth = 2;
          ctx.strokeRect(x - 90, 220, 180, 520);
          if (!p) return;
          ctx.fillStyle = v(`--el-${p.stemElement}`);
          ctx.fillRect(x - 90, 220, 180, 10);
          ctx.font = '700 110px "Gowun Batang", serif';
          ctx.fillText(p.stemHanja, x, 400);
          ctx.fillText(p.branchHanja, x, 560);
          ctx.fillStyle = v('--ink-soft');
          ctx.font = '400 34px "IBM Plex Mono", monospace';
          ctx.fillText(p.stemKo + p.branchKo, x, 660);
        });
        // seal
        ctx.save();
        ctx.translate(910, 900); ctx.rotate(-0.07);
        ctx.strokeStyle = v('--vermilion'); ctx.lineWidth = 6;
        ctx.strokeRect(-70, -70, 140, 140);
        ctx.fillStyle = v('--vermilion');
        ctx.font = '700 44px "Gowun Batang", serif';
        ctx.fillText('쇼미', 0, -8); ctx.fillText('사주', 0, 44);
        ctx.restore();
        ctx.fillStyle = v('--ink-soft');
        ctx.font = '400 30px "IBM Plex Mono", monospace';
        ctx.textAlign = 'left';
        ctx.fillText('tonyzorz.github.io/showmethesaju', 60, 1010);
        const a = document.createElement('a');
        a.download = 'my-saju.png';
        a.href = c.toDataURL('image/png');
        a.click();
        trackEvent('share', { method: 'image', content_type: 'saju_chart', language: document.documentElement.lang });
      });
    }

    // Run only after every helper and const above has been initialized.
    // Keeping this at the end prevents a temporal-dead-zone failure in the bundled module.
    if (!validQuery) {
      document.getElementById('loading-state')!.hidden = true;
      document.getElementById('no-query')!.hidden = false;
    } else {
      try {
        const timeUnknown = q.get('tu') === '1';
        const res: SajuResult = computeSaju({
          ...values,
          gender,
          timeUnknown,
          useTrueSolarTime: q.get('ts') === '1',
        });
        render(res, timeUnknown);
        document.getElementById('loading-state')!.hidden = true;
        document.getElementById('result')!.hidden = false;
        trackEvent('chart_view', {
          language: document.documentElement.lang,
          pillar_status: timeUnknown ? 'three_pillars' : 'four_pillars',
          solar_correction: q.get('ts') === '1',
        });
      } catch (error) {
        console.error('Unable to render Saju chart', error);
        document.getElementById('loading-state')!.hidden = true;
        document.getElementById('no-query')!.hidden = false;
        document.getElementById('render-error')!.hidden = false;
        trackEvent('chart_error', { error_type: 'render_failure', language: document.documentElement.lang });
      }
    }
  </script>

