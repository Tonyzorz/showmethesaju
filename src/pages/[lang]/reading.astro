    function setupLuckStrip(
      list: HTMLElement,
      detail: HTMLElement,
      cycles: LuckCycle[],
      labels: string[],
      sublabels: string[],
      selectedIndex: number,
      cycleType: 'daeun' | 'seun',
      r: SajuResult,
    ) {
      list.innerHTML = cycles.map((cycle, index) =>
        `<button class="luck-card${index === selectedIndex ? ' is-selected' : ''}" type="button" data-cycle-index="${index}" aria-pressed="${index === selectedIndex}">
          <small>${labels[index]}</small>
          <strong class="element-text--${cycle.pillar.stemElement}" lang="ko">${cycle.pillar.hanja}</strong>
          <span>${sublabels[index]}</span>
          <em>${stageLabel(cycle.twelveStage)}</em>
          <i aria-hidden="true">${cycle.relations.length + cycle.shinsal.length}</i>
        </button>`
      ).join('');
      const selectCycle = (index: number, track = false) => {
        list.querySelectorAll<HTMLButtonElement>('.luck-card').forEach((button, buttonIndex) => {
          button.classList.toggle('is-selected', buttonIndex === index);
          button.setAttribute('aria-pressed', String(buttonIndex === index));
        });
        renderLuckDetail(cycles[index], labels[index], detail, r);
        if (cycleType === 'seun') renderWolun(cycles[index] as AnnualLuck, r);
        if (track) trackEvent('luck_cycle_select', { cycle_type: cycleType, cycle_index: index, language: document.documentElement.lang });
      };
      list.querySelectorAll<HTMLButtonElement>('.luck-card').forEach((button) =>
        button.addEventListener('click', () => selectCycle(Number(button.dataset.cycleIndex), true))
      );
      selectCycle(selectedIndex);
    }

    function renderWolun(annual: AnnualLuck, r: SajuResult) {
      // 12 saju months of the selected 세운 year, stems via the year-stem cycle.
      const months = monthlyLuck(annual.pillar.stem, r.day.stem, annual.year);
      const monthFmt = new Intl.DateTimeFormat(document.documentElement.lang, { month: 'short' });
      document.getElementById('wolun-title')!.textContent = fmt(S['wolunTitle'], { year: annual.year });
      document.getElementById('wolun-list')!.innerHTML = months.map((m) => {
        const label = monthFmt.format(new Date(m.civilYear, m.civilMonth - 1, 15));
        const stage = twelveStageForStemBranch(r.day.stem, m.pillar.branch);
        return `<div class="wolun-card">
          <small>${label}</small>
          <strong class="element-text--${m.pillar.stemElement}" lang="ko">${m.pillar.hanja}</strong>
          <span>${tenGodLabel(m.tenGod)}</span>
          <em>${stageLabel(stage)}</em>
        </div>`;
      }).join('');
    }

    function renderLuck(r: SajuResult, timeUnknown: boolean) {
      const timing = currentTiming(r);
      const daeunList = document.getElementById('daeun-list')!;
      const daeunDetail = document.getElementById('daeun-detail')!;
      const daeunMeta = document.getElementById('daeun-meta')!;
      if (!r.daeun || !r.gender) {
        daeunMeta.textContent = S['genderRequired'];
        daeunList.innerHTML = '';
        daeunDetail.innerHTML = '';
      } else {
        const genderLabel = r.gender === 'female' ? S['genderFemale'] : S['genderMale'];
        daeunMeta.textContent = fmt(S['daeunMeta'], {
          gender: genderLabel,
          direction: S[r.daeun.direction],
          age: ageLabel(r.daeun.startAgeMonths),
        }) + (timeUnknown ? ` ${S['daeunApproximate']}` : '');
        setupLuckStrip(
          daeunList, daeunDetail, r.daeun.cycles,
          r.daeun.cycles.map((cycle) => ageLabel(cycle.startAgeMonths)),
          r.daeun.cycles.map((cycle) => fmt(S['startYear'], { year: cycle.startYear })),
          Math.max(0, timing.activeDaeunIndex), 'daeun', r,
        );
      }

      const annual: AnnualLuck[] = computeAnnualLuck(r, timing.currentSajuYear - 1, 12);
      setupLuckStrip(
        document.getElementById('seun-list')!, document.getElementById('seun-detail')!, annual,
        annual.map((cycle) => fmt(S['ipchunYear'], { year: cycle.year })),
        annual.map((cycle) => tenGodLabel(cycle.pillar.tenGod)),
        1, 'seun', r,
      );
    }

    function render(r: SajuResult, timeUnknown: boolean) {
      const locale = document.documentElement.lang || 'en';
      const birthDate = new Date(Date.UTC(values.year, values.month - 1, values.day, values.hour, values.minute));
      const formattedBirth = new Intl.DateTimeFormat(locale, timeUnknown
        ? { dateStyle: 'long', timeZone: 'UTC' }
        : { dateStyle: 'long', timeStyle: 'short', timeZone: 'UTC' }
      ).format(birthDate);
      const offsetSign = values.tzOffsetMinutes >= 0 ? '+' : '-';
      const offsetHours = String(Math.floor(Math.abs(values.tzOffsetMinutes) / 60)).padStart(2, '0');
      const offsetMinutes = String(Math.abs(values.tzOffsetMinutes) % 60).padStart(2, '0');
      const genderSummary = gender === 'female' ? S['genderFemale'] : gender === 'male' ? S['genderMale'] : '';
      document.getElementById('birth-summary')!.textContent = `${formattedBirth} · UTC${offsetSign}${offsetHours}:${offsetMinutes}${genderSummary ? ` · ${genderSummary}` : ''}`;

      // Pillars, traditional right-to-left order: 시 일 월 년 — but web reading order wins: hour…year reversed.
      document.getElementById('pillars')!.innerHTML = [
        pillarCard(r.hour, S['pillarHour'], 'hour', 0, r),
        pillarCard(r.day, S['pillarDay'], 'day', 1, r),
        pillarCard(r.month, S['pillarMonth'], 'month', 2, r),
        pillarCard(r.year, S['pillarYear'], 'year', 3, r),
      ].join('');
      renderChartFacts(r);
      renderReadingFocus(r);
      renderCurrentTiming(r);

      // Day master
      document.getElementById('dm-char')!.textContent = r.dayMaster.hanja;
      document.getElementById('dm-reading')!.textContent = r.dayMaster.ko;
      document.getElementById('dm-symbol')!.classList.add(`element-bg-soft--${r.dayMaster.element}`, `element-text--${r.dayMaster.element}`);
      document.getElementById('dm-text')!.textContent = S[`dm.${r.day.stem}`] ?? '';

      // Yin/yang overview across every visible stem and branch.
      const visiblePillars = [r.year, r.month, r.day, r.hour].filter((p): p is Pillar => !!p);
      const yang = visiblePillars.reduce((sum, p) => sum + Number(p.stemYang) + Number(p.branchYang), 0);
      const totalPolarity = visiblePillars.length * 2;
      const yin = totalPolarity - yang;
      const yangPercent = Math.round(yang / totalPolarity * 100);
      const yinYangText = fmt(S['yinYangSummary'], { yang, yin });
      const donut = document.getElementById('yy-donut') as HTMLElement;
      donut.style.setProperty('--yang-angle', `${yang / totalPolarity * 360}deg`);
      donut.setAttribute('aria-label', yinYangText);
      document.getElementById('yy-ratio')!.textContent = `${yangPercent}%`;
      document.getElementById('yy-yang-count')!.textContent = String(yang);
      document.getElementById('yy-yin-count')!.textContent = String(yin);
      document.getElementById('yy-text')!.textContent = yinYangText;

      // Element bars
      const total = Object.values(r.elementCounts).reduce((a, b) => a + b, 0) || 1;
      const rankedElements = (Object.entries(r.elementCounts) as [string, number][]).sort((a, b) => b[1] - a[1]);
      const [dominant, dominantCount] = rankedElements[0];
      const missing = rankedElements.filter(([, count]) => count === 0).map(([element]) => S[`el.${element}`]);
      document.getElementById('dominant-text')!.textContent = fmt(S['dominantSummary'], {
        element: S[`el.${dominant}`], count: dominantCount, total,
      });
      document.getElementById('missing-text')!.textContent = missing.length
        ? fmt(S['missingSummary'], { elements: missing.join(', ') })
        : S['noMissingElements'];
      document.getElementById('element-bars')!.innerHTML = elementOrder.map((el) => {
        const n = r.elementCounts[el];
        const percent = Math.round(n / total * 100);
        return `<div class="ebar" role="img" aria-label="${S[`el.${el}`]} ${n} / ${total}">
          <span class="ebar-label"><i class="element-dot element-bg--${el}"></i>${S[`el.${el}`]}</span>
          <span class="ebar-track"><span class="ebar-fill element-bg--${el}" style="--bar-width:${percent}%"></span></span>
          <span class="ebar-n"><strong>${n}</strong><small>${percent}%</small></span>
        </div>`;
      }).join('');
      renderElementRadar(r.elementCounts, total);

      // Ten gods table
      const rows = [
        [S['pillarHour'], r.hour], [S['pillarDay'], r.day], [S['pillarMonth'], r.month], [S['pillarYear'], r.year],
      ] as const;
      document.getElementById('tengods')!.innerHTML =
        `<thead><tr><th scope="col"></th><th scope="col"><button class="gloss" data-gloss="cheongan" type="button">${S['heavenlyStem']}</button></th><th scope="col"><button class="gloss" data-gloss="sipseong" type="button">${S['tenGods']}</button></th></tr></thead><tbody>` +
        rows.map(([label, p]) => p
          ? `<tr><th scope="row">${label}</th><td data-label="${S['heavenlyStem']}" lang="ko"><span class="stem-badge element-text--${p.stemElement}">${p.stemHanja}</span> ${p.stemKo}</td><td data-label="${S['tenGods']}"><span class="god-badge">${tenGodLabel(p.tenGod)}</span></td></tr>`
          : `<tr><th scope="row">${label}</th><td colspan="2">—</td></tr>`
        ).join('') + `</tbody>`;
      renderTenGodDistribution(r);

      renderHiddenStems(r);
      renderExtras(r);
      renderRelations(r);
      renderShinsal(r);
      renderLuck(r, timeUnknown);

      // Term-boundary warning: within ~0.15° of a 30° boundary (≈ a few hours), or time unknown near one.
      const off = ((r.solarLongitude - 315) % 30 + 30) % 30;
      if (Math.min(off, 30 - off) < (timeUnknown ? 0.6 : 0.15)) {
        const note = document.getElementById('boundary-note')!;
        note.textContent = S['termBoundaryNote'];
        note.hidden = false;
      }

      // Share: copy URL
      document.getElementById('share-url')!.addEventListener('click', async (e) => {
        try {
          await navigator.clipboard.writeText(location.href);
        } catch {
          const input = document.createElement('textarea');
          input.value = location.href;
          document.body.append(input);
          input.select();
          document.execCommand('copy');
          input.remove();
        }
        (e.currentTarget as HTMLElement).textContent = S['shared'];
        trackEvent('share', { method: 'link', content_type: 'saju_chart', language: document.documentElement.lang });
      });

      // Share cards v2: square 1080 + IG story 1080×1920, both carrying the
      // day master and 격국·신강약 line. No birth data on the image by design.
      const siteLabel = location.host + (import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, ''));
      async function drawCard(mode: 'square' | 'story'): Promise<HTMLCanvasElement> {
        await (document as any).fonts?.ready;
        const W = 1080, H = mode === 'story' ? 1920 : 1080;
        const c = document.createElement('canvas');
        c.width = W; c.height = H;
        const ctx = c.getContext('2d')!;
        const css = getComputedStyle(document.documentElement);
        const v = (n: string) => css.getPropertyValue(n).trim();
        ctx.fillStyle = v('--paper'); ctx.fillRect(0, 0, W, H);
        ctx.textAlign = 'center';

        const top = mode === 'story' ? 260 : 130;
        ctx.fillStyle = v('--ink');
        ctx.font = `700 ${mode === 'story' ? 64 : 56}px "Gowun Batang", serif`;
        ctx.fillText(S['yourPillars'], W / 2, top);

        const cardY = mode === 'story' ? 420 : 240;
        const cardH = mode === 'story' ? 620 : 520;
        const roleLabels4 = [S['pillarYear'], S['pillarMonth'], S['pillarDay'], S['pillarHour']];
        const ps = [r.year, r.month, r.day, r.hour];
        ps.forEach((p, i) => {
          const x = 180 + i * 240;
          ctx.fillStyle = v('--ink-soft');
          ctx.font = '400 28px "IBM Plex Mono", monospace';
          ctx.fillText(roleLabels4[i], x, cardY - 24);
          ctx.strokeStyle = v('--line'); ctx.lineWidth = 2;
          ctx.strokeRect(x - 90, cardY, 180, cardH);
          if (!p) return;
          ctx.fillStyle = v(`--el-${p.stemElement}`);
          ctx.fillRect(x - 90, cardY, 180, 10);
          ctx.fillStyle = v('--ink');
          ctx.font = `700 ${mode === 'story' ? 120 : 110}px "Gowun Batang", serif`;
          ctx.fillText(p.stemHanja, x, cardY + (mode === 'story' ? 220 : 160));
          ctx.fillText(p.branchHanja, x, cardY + (mode === 'story' ? 400 : 320));
          ctx.fillStyle = v('--ink-soft');
          ctx.font = '400 34px "IBM Plex Mono", monospace';
          ctx.fillText(p.stemKo + p.branchKo, x, cardY + cardH - 60);
        });

        // Day master + structure line (격국 · 신강약).
        const gg = gyeokguk(r);
        const st = strengthAnalysis(r);
        const infoY = cardY + cardH + (mode === 'story' ? 130 : 90);
        ctx.fillStyle = v('--ink');
        ctx.font = '700 44px "Gowun Batang", serif';
        ctx.fillText(`${S['dayMaster']} ${r.dayMaster.hanja}(${r.dayMaster.ko})`, W / 2, infoY);
        ctx.fillStyle = v('--ink-soft');
        ctx.font = '400 34px "IBM Plex Mono", monospace';
        ctx.fillText(`${S[`gg.${gg.name}`]} · ${S[`strengthV.${st.verdict}`]}`, W / 2, infoY + 60);

        // Seal + domain.
        const sealC = mode === 'story' ? [W / 2, H - 360] : [910, 900];
        ctx.save();
        ctx.translate(sealC[0], sealC[1]); ctx.rotate(-0.07);
        ctx.strokeStyle = v('--vermilion'); ctx.lineWidth = 6;
        ctx.strokeRect(-70, -70, 140, 140);
        ctx.fillStyle = v('--vermilion');
        ctx.font = '700 44px "Gowun Batang", serif';
        ctx.fillText('쇼미', 0, -8); ctx.fillText('사주', 0, 44);
        ctx.restore();
        ctx.fillStyle = v('--ink-soft');
        ctx.font = '400 30px "IBM Plex Mono", monospace';
        if (mode === 'story') { ctx.fillText(siteLabel, W / 2, H - 160); }
        else { ctx.textAlign = 'left'; ctx.fillText(siteLabel, 60, 1010); }
        return c;
      }

      const download = (c: HTMLCanvasElement, name: string, method: string) => {
        const a = document.createElement('a');
        a.download = name;
        a.href = c.toDataURL('image/png');
        a.click();
        trackEvent('share', { method, content_type: 'saju_chart', language: document.documentElement.lang });
      };
      document.getElementById('share-png')!.addEventListener('click', async () =>
        download(await drawCard('square'), 'my-saju.png', 'image'));
      document.getElementById('share-story')!.addEventListener('click', async () =>
        download(await drawCard('story'), 'my-saju-story.png', 'image_story'));

      // Native share sheet (mobile: includes KakaoTalk/Instagram/etc. — no SDK).
      const nativeBtn = document.getElementById('share-native')!;
      if (navigator.share) {
        nativeBtn.hidden = false;
        nativeBtn.addEventListener('click', async () => {
          const c = await drawCard('square');
          const blob: Blob = await new Promise((res) => c.toBlob((b) => res(b!), 'image/png'));
          const file = new File([blob], 'my-saju.png', { type: 'image/png' });
          const payload: ShareData = { title: document.title, url: location.href };
          try {
            if (navigator.canShare?.({ files: [file] })) await navigator.share({ ...payload, files: [file] });
            else await navigator.share(payload);
            trackEvent('share', { method: 'native', content_type: 'saju_chart', language: document.documentElement.lang });
          } catch { /* user dismissed the sheet */ }
        });
      }
    }

    // Run only after every helper and const above has been initialized.
    // Keeping this at the end prevents a temporal-dead-zone failure in the bundled module.
    setupReadingMode();
    setupLayerControls();
    if (!validQuery) {
      document.getElementById('loading-state')!.hidden = true;
      document.getElementById('no-query')!.hidden = false;
    } else {
      try {
        const timeUnknown = q.get('tu') === '1';
        const res: SajuResult = computeSaju({
          ...values,
          gender,
          timeUnknown,
          useTrueSolarTime: q.get('ts') === '1',
        });
        render(res, timeUnknown);
        document.getElementById('loading-state')!.hidden = true;
        document.getElementById('result')!.hidden = false;
        setupSectionNavigation();
        setupTimingPath();
        trackEvent('chart_view', {
          language: document.documentElement.lang,
          pillar_status: timeUnknown ? 'three_pillars' : 'four_pillars',
          solar_correction: q.get('ts') === '1',
          reading_focus: selectedReadingFocus,
        });
      } catch (error) {
        console.error('Unable to render Saju chart', error);
        document.getElementById('loading-state')!.hidden = true;
        document.getElementById('no-query')!.hidden = false;
        document.getElementById('render-error')!.hidden = false;
        trackEvent('chart_error', { error_type: 'render_failure', language: document.documentElement.lang });
      }
    }
  </script>

