    .focus-evidence__body > p { margin: .75rem 0; color: var(--ink-soft); font-size: .72rem; line-height: 1.65; }
    .focus-evidence__sources { display: flex; flex-wrap: wrap; gap: .35rem; }
    .focus-evidence__sources span { padding: .3rem .5rem; border: 1px solid color-mix(in srgb, var(--focus-accent) 16%, var(--line)); border-radius: 999px; color: var(--focus-accent); background: color-mix(in srgb, var(--focus-accent) 5%, white); font-size: .58rem; font-weight: 740; }
    #focus-details { display: inline-flex; align-items: center; gap: .45rem; margin-top: .75rem; padding: 0; border: 0; color: var(--focus-accent); background: transparent; font: inherit; font-size: .68rem; font-weight: 800; cursor: pointer; }
    #focus-details i { display: grid; inline-size: 1.35rem; aspect-ratio: 1; place-items: center; border-radius: 50%; color: white; background: var(--focus-accent); font-size: .7rem; font-style: normal; }
    .focus-guidance-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .55rem; margin-top: .8rem; }
    .focus-guidance-grid article { min-width: 0; padding: .65rem .7rem; border: 1px solid color-mix(in srgb, var(--focus-accent) 14%, var(--line)); border-radius: .75rem; background: rgb(255 255 255 / .62); }
    .focus-guidance-grid small { color: var(--focus-accent); font-size: .54rem; font-weight: 780; }
    .focus-guidance-grid p { display: -webkit-box; overflow: hidden; margin: .35rem 0 0; color: var(--ink-soft); font-size: .6rem; line-height: 1.5; -webkit-box-orient: vertical; -webkit-line-clamp: 3; }
    .health-disclaimer { margin: .75rem 0 0; padding: .65rem .75rem; border: 1px solid #e7c6b2; border-radius: .75rem; color: #7c4636; background: #fff3ec; font-size: .62rem; line-height: 1.55; }
    .health-disclaimer[hidden] { display: none; }
    #reading-focus, #original-chart, #element-balance, #ten-gods-analysis, #hidden-stems-analysis, #strength-analysis, #relations-analysis, #shinsal-analysis, #luck-analysis, #seun-analysis { scroll-margin-top: 9rem; }

    .chart-matrix-panel {
      position: relative;
      overflow: hidden;
      margin-block: clamp(2rem, 5vw, 4rem);
      padding: clamp(1.1rem, 3.5vw, 2rem);
      background:
        linear-gradient(135deg, color-mix(in srgb, var(--jade-pale) 35%, white), rgb(255 255 255 / .92) 42%),
        var(--paper-raised);
    }
    .chart-matrix-panel::before { content: ''; position: absolute; inline-size: 18rem; aspect-ratio: 1; inset: -10rem -7rem auto auto; border: 1px solid rgb(36 84 66 / .08); border-radius: 50%; box-shadow: 0 0 0 3rem rgb(36 84 66 / .025), 0 0 0 6rem rgb(36 84 66 / .018); pointer-events: none; }
    .chart-matrix-heading { position: relative; display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-5); }
    .chart-matrix-heading h2 { margin: 0; font-size: clamp(1.5rem, 3vw, 2rem); }
    .chart-matrix-heading p:not(.panel-overline) { max-inline-size: 42rem; margin: .5rem 0 0; color: var(--ink-soft); font-size: var(--text-sm); }
    .chart-layer-controls { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: .45rem; }
    .chart-layer-controls button { min-height: 2.35rem; padding: .5rem .72rem; border: 1px solid var(--line); border-radius: 999px; color: var(--ink-soft); background: rgb(255 255 255 / .7); font-size: .68rem; font-weight: 760; cursor: pointer; transition: color var(--dur-fast), border-color var(--dur-fast), background var(--dur-fast); }
    .chart-layer-controls button[aria-pressed="true"] { border-color: var(--indigo); color: white; background: var(--indigo); box-shadow: 0 5px 14px rgb(36 84 66 / .16); }
    .hide-layer--ten-gods [data-layer="ten-gods"], .hide-layer--hidden [data-layer="hidden"], .hide-layer--stages [data-layer="stages"], .hide-layer--stars [data-layer="stars"] { display: none !important; }

    .pillars {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: clamp(.75rem, 2vw, 1.25rem);
      margin-block: clamp(1.5rem, 4vw, 2.5rem);
    }
    .pillar {
      position: relative;
      display: flex;
      min-width: 0;
      min-height: 0;
      flex-direction: column;
      justify-content: flex-start;
      gap: .8rem;
      overflow: hidden;
      padding: clamp(1rem, 2.5vw, 1.5rem);
      border: 1px solid color-mix(in srgb, var(--pillar-color, var(--ink)) 20%, var(--line));
      border-top: 0;
      border-radius: var(--radius-lg);
      background:
        radial-gradient(circle at 50% 36%, color-mix(in srgb, var(--pillar-color, var(--ink)) 11%, transparent), transparent 46%),
        linear-gradient(155deg, #fff, color-mix(in srgb, var(--paper-raised) 88%, var(--pillar-color, var(--ink))));
      box-shadow: 0 16px 42px rgb(35 53 44 / .09);
      transition: transform var(--dur-fast) var(--ease-reveal), box-shadow var(--dur-fast), border-color var(--dur-fast);
    }
    .pillar::before {
      content: '';
      position: absolute;
      inset: 0 0 auto;
      block-size: .42rem;
      background: var(--pillar-color, var(--ink));
    }
    .pillar::after {
      content: '';
      position: absolute;
      inline-size: 6rem;
      block-size: 6rem;
      inset: auto -3rem -3rem auto;
      border: 1px solid color-mix(in srgb, var(--pillar-color, var(--ink)) 25%, transparent);
      border-radius: 50%;
    }
    .pillar:hover { transform: translateY(-3px); border-color: color-mix(in srgb, var(--pillar-color, var(--ink)) 38%, var(--line)); box-shadow: 0 24px 55px rgb(35 53 44 / .14); }
    .pillar--day { border-color: color-mix(in srgb, var(--indigo) 48%, var(--line)); box-shadow: 0 18px 48px rgb(36 84 66 / .16), inset 0 0 0 1px rgb(36 84 66 / .08); }
    .pillar--day::before { block-size: .58rem; background: linear-gradient(90deg, var(--indigo), #3e8b6c); }
    .pillar-top { display: flex; min-height: 2rem; align-items: center; justify-content: space-between; gap: var(--space-2); }
    .pillar-label { color: var(--ink-soft); font-size: var(--text-sm); font-weight: 750; }
    .ten-god {
      overflow: hidden;
      max-inline-size: 58%;
      padding: .28rem .55rem;
      border: 1px solid color-mix(in srgb, var(--pillar-color) 22%, var(--line));
      border-radius: 999px;
      color: var(--pillar-color);
      background: color-mix(in srgb, var(--pillar-color) 8%, white);
      font-size: var(--text-xs);
      font-weight: 720;
      line-height: 1.2;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .glyph-stack { display: grid; justify-items: center; align-content: center; }
    .matrix-glyph-label { margin-block: .28rem; color: var(--ink-soft); font-family: var(--font-body); font-size: .62rem; font-weight: 760; }
    .pillar-glyph { font-family: var(--font-display); font-size: clamp(3.2rem, 5.5vw, 4.5rem); font-weight: 700; line-height: .95; }
    .glyph-tile { display: grid; inline-size: clamp(4.5rem, 7.5vw, 6rem); aspect-ratio: 1; place-items: center; border: 1px solid color-mix(in srgb, currentColor 30%, var(--line)); border-radius: clamp(.8rem, 2vw, 1.2rem); box-shadow: inset 0 0 0 .25rem rgb(255 255 255 / .45), 0 8px 18px rgb(35 53 44 / .08); }
    .glyph-bridge { inline-size: 1px; block-size: .8rem; margin-block: .25rem; background: linear-gradient(var(--pillar-color), transparent); opacity: .38; }
    .pillar-layer { position: relative; z-index: 1; min-width: 0; border: 1px solid var(--line); border-radius: .78rem; background: rgb(255 255 255 / .62); }
    .pillar-hidden-layer { padding: .55rem; }
    .pillar-hidden-layer > b { display: block; margin-bottom: .45rem; color: var(--ink-soft); font-size: .62rem; }
    .pillar-hidden-layer > div { display: grid; gap: .3rem; }
    .pillar-hidden-layer span { display: grid; grid-template-columns: 2.25rem auto 1fr; align-items: center; gap: .38rem; padding: .3rem .4rem; border-radius: .5rem; background: color-mix(in srgb, var(--paper-sunken) 60%, white); }
    .pillar-hidden-layer small { color: var(--ink-soft); font-size: .55rem; }
    .pillar-hidden-layer strong { font-family: var(--font-display); font-size: 1.05rem; }
    .pillar-hidden-layer i { overflow: hidden; color: var(--ink-soft); font-size: .58rem; font-style: normal; font-weight: 720; text-overflow: ellipsis; white-space: nowrap; }
    .pillar-stage-layer { display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; }
    .pillar-stage-layer span { display: grid; gap: .2rem; padding: .55rem .35rem; text-align: center; }
    .pillar-stage-layer span + span { border-inline-start: 1px solid var(--line); }
    .pillar-stage-layer small, .pillar-nayin-layer small { color: var(--ink-soft); font-size: .55rem; }
    .pillar-stage-layer strong { color: var(--indigo); font-size: .72rem; }
    .pillar-nayin-layer { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: .2rem .5rem; padding: .55rem .65rem; }
    .pillar-nayin-layer small { grid-column: 1 / -1; }
    .pillar-nayin-layer strong { font-family: var(--font-display); font-size: .82rem; }
    .pillar-nayin-layer span { color: var(--ink-soft); font-size: .58rem; font-weight: 700; }
    .pillar-star-layer { display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; }
    .pillar-star-layer > div { display: grid; gap: .18rem; padding: .5rem .35rem; text-align: center; }
    .pillar-star-layer > div + div { border-inline-start: 1px solid var(--line); }
    .pillar-star-layer span { color: var(--ink-soft); font-size: .55rem; }
    .pillar-star-layer strong { color: #8d4b31; font-size: .65rem; }
    .pillar-star-layer p { grid-column: 1 / -1; margin: 0; padding: .5rem; border-top: 1px solid var(--line); color: var(--indigo); font-size: .58rem; font-weight: 720; line-height: 1.45; text-align: center; }
    .pillar-bottom { display: grid; justify-items: center; gap: .35rem; margin-top: auto; text-align: center; }
    .pillar-bottom > strong { font-family: var(--font-display); font-size: var(--text-lg); }
    .element-pair {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .3rem;
      color: var(--ink-soft);
      font-size: clamp(.62rem, 1.25vw, var(--text-xs));
      line-height: 1.35;
      text-align: center;
    }
    .element-pair b { color: var(--line); font-weight: 400; }
    .element-dot { display: inline-block; flex: 0 0 auto; inline-size: .55rem; block-size: .55rem; border-radius: 50%; }

    /* ── strength (신강/신약) + favorable elements panel ── */
    .strength-verdict { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; margin-block-end: var(--space-3); }
    .verdict-badge { font-family: var(--font-display); font-size: var(--text-lg); padding: var(--space-1) var(--space-3); border-radius: 999px; background: var(--paper-sunken); }
    .verdict--extremeStrong, .verdict--strong { color: var(--indigo); }
    .verdict--extremeWeak, .verdict--weak { color: var(--gold); }
    .strength-marks { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-block-end: var(--space-4); }
    .strength-mark { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-soft); border: 1px solid var(--line); border-radius: 999px; padding: var(--space-1) var(--space-3); }
    .strength-mark.is-got { color: var(--indigo); border-color: color-mix(in srgb, var(--indigo) 45%, var(--line)); background: color-mix(in srgb, var(--indigo) 7%, transparent); }
    .favorable-list { display: grid; gap: var(--space-2); }
    .favorable-row { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
    .favorable-label { font-size: var(--text-sm); color: var(--ink-soft); min-inline-size: 5.5rem; }
    .favorable-chips { display: flex; gap: var(--space-2); flex-wrap: wrap; }
    .element-chip { display: inline-flex; align-items: center; gap: var(--space-1); font-size: var(--text-sm); font-weight: 600; border-radius: 999px; padding: var(--space-1) var(--space-3); }

    /* ── 태원 · 명궁 auxiliary pillars ── */
    .palace-cards { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
    @media (max-width: 480px) { .palace-cards { grid-template-columns: 1fr; } }
    .palace-card { display: grid; justify-items: center; gap: var(--space-1); padding: var(--space-4); background: var(--paper-sunken); border: 1px solid var(--line); border-radius: var(--radius); text-align: center; }
    .palace-label { font-size: var(--text-sm); color: var(--ink-soft); }
    .palace-hanja { font-family: var(--font-display); font-size: var(--text-2xl); line-height: var(--leading-tight); }
    .palace-ko { font-family: var(--font-mono); font-size: var(--text-sm); }
    .palace-hint { font-size: var(--text-xs); }

    /* ── 월운 monthly strip ── */
    .wolun { margin-block-start: var(--space-4); }
    .wolun h3 { margin-block-end: var(--space-2); }
    .wolun-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: var(--space-2); }
    @media (max-width: 720px) { .wolun-grid { grid-template-columns: repeat(4, 1fr); } }
    @media (max-width: 480px) { .wolun-grid { grid-template-columns: repeat(3, 1fr); } }
    .wolun-card { display: grid; justify-items: center; gap: 2px; padding: var(--space-2); background: var(--paper-sunken); border: 1px solid var(--line); border-radius: var(--radius-sm); text-align: center; }
    .wolun-card small { color: var(--ink-soft); font-family: var(--font-mono); font-size: var(--text-xs); }
    .wolun-card strong { font-family: var(--font-display); font-size: var(--text-lg); line-height: 1.2; }
    .wolun-card span { font-size: var(--text-xs); }
    .wolun-card em { font-style: normal; font-size: var(--text-xs); color: var(--ink-soft); }

    /* ── 격국 + 삼재 panels ── */
    .gyeokguk-result, .samjae-result { display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; margin-block-end: var(--space-3); }
    .gyeokguk-badge { color: var(--indigo); }
    .gyeokguk-meta { display: grid; gap: var(--space-1); font-size: var(--text-sm); }
    .samjae-badge { color: var(--gold); }
    .samjae-badge--none { color: var(--ink-soft); }
    .pillar-empty { align-items: center; justify-content: flex-start; }
    .pillar-empty .hint { margin: auto; text-align: center; }

    .chart-facts { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .6rem; }
    .chart-facts article { position: relative; display: grid; min-height: 5.4rem; align-content: center; gap: .3rem; overflow: hidden; padding: .75rem .85rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: rgb(255 255 255 / .64); }
    .chart-facts article > span { position: absolute; inset: auto .35rem -.55rem auto; color: rgb(36 84 66 / .07); font-family: var(--font-display); font-size: 3.5rem; line-height: 1; }
    .chart-facts small { position: relative; color: var(--ink-soft); font-size: .6rem; font-weight: 750; }
    .chart-facts strong { position: relative; overflow-wrap: anywhere; font-size: .75rem; line-height: 1.4; }

    .section-title { margin: clamp(3.5rem, 7vw, 6rem) 0 var(--space-6); }
    .insight-grid { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(0, .85fr); gap: var(--space-5); }
    .panel { padding: clamp(1.4rem, 4vw, 2.4rem); margin-block-end: var(--space-5); }
    .panel h2 { margin: 0; font-size: clamp(1.35rem, 2.4vw, 1.85rem); }
    .panel-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-6); }
    .panel-index { color: color-mix(in srgb, var(--ink-soft) 30%, transparent); font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: .08em; }
    .panel-overline { margin: 0 0 .35rem; color: var(--vermilion); font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
    .soft { color: var(--ink-soft); font-size: var(--text-sm); }

    .day-master-panel { background: linear-gradient(135deg, color-mix(in srgb, var(--jade-pale) 60%, white), var(--paper-raised) 62%); }
    .day-master-layout { display: grid; grid-template-columns: auto 1fr; align-items: center; gap: clamp(1.25rem, 4vw, 2.5rem); }
    .dm-symbol {
      position: relative;
      display: grid;
      inline-size: clamp(6.8rem, 14vw, 9rem);
      aspect-ratio: 1;
      place-items: center;
      align-content: center;
      border: 1px solid color-mix(in srgb, currentColor 22%, transparent);
      border-radius: 50%;
      box-shadow: inset 0 0 0 .6rem rgb(255 255 255 / .45), 0 12px 25px rgb(36 84 66 / .1);
    }
    .dm-symbol::before { content: ''; position: absolute; inset: .65rem; border: 1px dashed currentColor; border-radius: 50%; opacity: .18; }
    .dm-symbol span { font-family: var(--font-display); font-size: clamp(3rem, 7vw, 4.5rem); font-weight: 700; line-height: 1; }
    .dm-symbol small { color: var(--ink-soft); font-size: var(--text-xs); font-weight: 700; }
    .day-master-layout p { margin: 0; color: var(--ink-soft); }

    .yy-layout { display: grid; grid-template-columns: auto 1fr; align-items: center; gap: clamp(1rem, 3vw, 2rem); }
    .yy-donut {
      --yang-angle: 180deg;
      position: relative;
      display: grid;
      inline-size: clamp(7.5rem, 13vw, 9.25rem);
      aspect-ratio: 1;
      place-items: center;
      border-radius: 50%;
      background: conic-gradient(var(--vermilion) 0 var(--yang-angle), var(--el-water) var(--yang-angle) 360deg);
      box-shadow: 0 16px 30px rgb(36 84 66 / .12);
      transform: rotate(-90deg);
    }
    .yy-donut::before { content: ''; position: absolute; inset: -.4rem; border: 1px solid var(--line); border-radius: 50%; }
    .yy-center { display: grid; inline-size: 68%; aspect-ratio: 1; place-items: center; align-content: center; border-radius: 50%; background: var(--paper-raised); box-shadow: inset 0 0 18px rgb(35 53 44 / .06); transform: rotate(90deg); }
    .yy-center strong { font-family: var(--font-mono); font-size: var(--text-lg); line-height: 1; }
    .yy-center span { color: var(--ink-soft); font-family: var(--font-display); font-size: var(--text-xs); }
    .yy-legend { display: flex; flex-wrap: wrap; gap: .55rem 1rem; margin-bottom: var(--space-3); }
    .yy-legend span { display: inline-flex; align-items: center; gap: .35rem; color: var(--ink-soft); font-family: var(--font-mono); font-size: var(--text-xs); }
    .yy-legend i { inline-size: .55rem; block-size: .55rem; border-radius: 50%; }
    .yang-dot { background: var(--vermilion); }
    .yin-dot { background: var(--el-water); }
    .yy-details p { margin: 0; color: var(--ink-soft); font-size: var(--text-sm); }

    .element-panel { margin-block-start: var(--space-5); }
    .element-dashboard { display: grid; grid-template-columns: minmax(17rem, .85fr) minmax(0, 1.15fr); align-items: center; gap: clamp(1.5rem, 5vw, 4rem); }
    .radar-wrap { display: grid; place-items: center; min-width: 0; border-radius: var(--radius); background: radial-gradient(circle, rgb(36 84 66 / .06), transparent 66%); }
    #element-radar { display: block; inline-size: min(100%, 25rem); block-size: auto; overflow: visible; }
    .radar-level { fill: rgb(36 84 66 / .018); stroke: var(--chart-line); stroke-width: 1; }
    .radar-level:last-child { stroke: color-mix(in srgb, var(--indigo) 30%, transparent); }
    .radar-axis { stroke: var(--chart-line); stroke-width: 1; stroke-dasharray: 3 5; }
    #radar-shape { fill: rgb(36 84 66 / .22); stroke: var(--indigo); stroke-width: 2.5; stroke-linejoin: round; filter: drop-shadow(0 7px 9px rgb(36 84 66 / .14)); transform-origin: 180px 165px; }
    .radar-point { stroke: #fff; stroke-width: 2.5; }
    .radar-label { font-family: var(--font-body); font-size: 13px; font-weight: 750; text-anchor: middle; dominant-baseline: middle; }
    .element-breakdown { min-width: 0; }
    .element-bars { display: grid; gap: var(--space-4); }
    .ebar { display: grid; grid-template-columns: minmax(4.5rem, 6rem) 1fr 3.2rem; align-items: center; gap: var(--space-3); font-size: var(--text-sm); }
    .ebar-label { display: inline-flex; align-items: center; gap: .55rem; font-weight: 720; }
    .ebar-track { display: block; overflow: hidden; height: .72rem; border-radius: 99px; background: var(--paper-sunken); box-shadow: inset 0 1px 2px rgb(24 32 28 / .08); }
    .ebar-fill { display: block; inline-size: var(--bar-width); block-size: 100%; border-radius: 99px; transform-origin: left center; }
    .ebar-n { display: grid; grid-template-columns: auto 1fr; align-items: baseline; gap: .25rem; font-family: var(--font-mono); text-align: end; }
    .ebar-n strong { color: var(--ink); font-size: var(--text-base); }
    .ebar-n small { color: var(--ink-soft); font-size: .65rem; }
    .pattern-summary { margin-top: var(--space-6); padding: var(--space-5); border-inline-start: 3px solid var(--vermilion); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; background: color-mix(in srgb, var(--peach-pale) 54%, transparent); }
    .pattern-summary p { margin: 0; }
    .pattern-summary p + p { margin-top: var(--space-2); }

    .table-scroll { overflow-x: auto; }
    .ten-god-distribution { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .65rem; margin-bottom: var(--space-5); }
    .ten-god-family { --family-accent: var(--indigo); min-width: 0; padding: .8rem; border: 1px solid color-mix(in srgb, var(--family-accent) 18%, var(--line)); border-radius: var(--radius-sm); background: linear-gradient(145deg, color-mix(in srgb, var(--family-accent) 8%, white), rgb(255 255 255 / .72)); }
    .ten-god-family--2 { --family-accent: #a05a42; }
    .ten-god-family--3 { --family-accent: #9b712d; }
