---
import Base from '../../layouts/Base.astro';
import GlossaryTooltip from '../../components/GlossaryTooltip.astro';
import { LOCALES } from '../../i18n/locales';
import { t, ns } from '../../i18n/t';
import { withBase } from '../../lib/paths';

export function getStaticPaths() {
  return LOCALES.map((l) => ({ params: { lang: l.code } }));
}
const { lang } = Astro.params;
const focusStrings = ns(lang, 'fortune');
const strings = {
  ...ns(lang, 'reading'),
  ...Object.fromEntries(Object.entries(focusStrings).map(([key, value]) => [`focus.${key}`, value])),
  cta: t(lang, 'hero.cta'),
  siteName: t(lang, 'meta.siteName'),
  genderFemale: t(lang, 'form.genderF'),
  genderMale: t(lang, 'form.genderM'),
};
const READING_FOCUSES = [
  { key: 'basic', mark: '命' }, { key: 'personality', mark: '氣' }, { key: 'wealth', mark: '財' },
  { key: 'health', mark: '身' }, { key: 'career', mark: '業' }, { key: 'relationships', mark: '緣' },
  { key: 'noble', mark: '貴' }, { key: 'movement', mark: '動' }, { key: 'timing', mark: '運' },
] as const;
const EMPTY_READING_FEATURES = [
  { mark: '命', title: 'reading.originalChart', body: 'reading.originalChartContext' },
  { mark: '行', title: 'reading.elements', body: 'reading.elementContext' },
  { mark: '藏', title: 'reading.hiddenStems', body: 'reading.hiddenStemsContext' },
  { mark: '合', title: 'reading.allRelations', body: 'reading.relationsContext' },
  { mark: '星', title: 'reading.shinsal', body: 'reading.shinsalContext' },
  { mark: '運', title: 'reading.daeun', body: 'reading.daeunContext' },
] as const;
---
<Base lang={lang} title={t(lang, 'meta.reading.title')} path="reading" noindex>
  <script type="application/json" id="i18n-reading" set:html={JSON.stringify(strings)} />

  <section id="loading-state" class="loading-state" aria-live="polite">
    <span class="loading-mark" aria-hidden="true"></span>
    <h1>{t(lang, 'reading.yourPillars')}</h1>
    <p>{t(lang, 'readingLoading')}</p>
    <a href={withBase(`/${lang}/`)}>{t(lang, 'hero.cta')}</a>
  </section>

  <section id="result" data-reading-mode="beginner" hidden>
    <header class="result-hero">
      <div class="result-kicker" aria-hidden="true"><span></span> 木 · 火 · 土 · 金 · 水</div>
      <h1>{t(lang, 'reading.yourPillars')}</h1>
      <p id="birth-summary" class="birth-summary"></p>
      <div class="element-ribbon" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
    </header>
    <p id="boundary-note" class="note" hidden></p>

    <div class="reading-mode-bar">
      <div><span aria-hidden="true">層</span><div><small>{t(lang, 'experience.modeLabel')}</small><strong>{t(lang, 'reading.chartAtGlance')}</strong></div></div>
      <div role="group" aria-label={t(lang, 'experience.modeLabel')}>
        <button type="button" data-reading-mode="beginner" aria-pressed="true">{t(lang, 'experience.beginner')}</button>
        <button type="button" data-reading-mode="expert" aria-pressed="false">{t(lang, 'experience.expert')}</button>
      </div>
    </div>

    <nav class="reading-jumpbar" aria-label={t(lang, 'reading.chartAtGlance')}>
      <span class="reading-jumpbar__label" aria-hidden="true">≡</span>
      <div class="reading-jumpbar__items">
        <button type="button" data-scroll-target="reading-focus">{t(lang, 'reading.chartAtGlance')}</button>
        <button type="button" data-scroll-target="original-chart">{t(lang, 'reading.originalChart')}</button>
        <button type="button" data-scroll-target="element-balance">{t(lang, 'reading.elements')}</button>
        <button class="expert-only-nav" type="button" data-scroll-target="ten-gods-analysis">{t(lang, 'reading.tenGods')}</button>
        <button type="button" data-scroll-target="strength-analysis">{t(lang, 'reading.strength')}</button>
        <button class="expert-only-nav" type="button" data-scroll-target="relations-analysis">{t(lang, 'reading.allRelations')}</button>
        <button class="expert-only-nav" type="button" data-scroll-target="shinsal-analysis">{t(lang, 'reading.shinsal')}</button>
        <button type="button" data-scroll-target="luck-analysis">{t(lang, 'reading.daeun')}</button>
      </div>
    </nav>

    <section id="reading-focus" class="reading-focus" aria-labelledby="reading-focus-title">
      <div class="reading-focus__heading">
        <p class="panel-overline">{t(lang, 'fortune.eyebrow')}</p>
        <h2 id="reading-focus-title">{t(lang, 'fortune.resultTitle')}</h2>
        <span>{t(lang, 'fortune.resultSubtitle')}</span>
      </div>
      <div class="focus-tabs" role="group" aria-label={t(lang, 'fortune.resultTitle')}>
        {READING_FOCUSES.map((focus) => (
          <button type="button" data-reading-focus={focus.key} aria-pressed="false">
            <span aria-hidden="true">{focus.mark}</span>{t(lang, `fortune.${focus.key}.title`)}
          </button>
        ))}
      </div>
      <article id="focus-content" class="focus-content" aria-live="polite">
        <span id="focus-mark" class="focus-content__mark" aria-hidden="true">命</span>
        <div class="focus-content__copy">
          <p id="focus-kicker"></p>
          <h3 id="focus-title"></h3>
          <p id="focus-summary"></p>
          <div id="focus-metrics" class="focus-metrics"></div>
          <details id="focus-evidence" class="focus-evidence">
            <summary>{t(lang, 'fortune.viewDetails')}</summary>
            <div class="focus-evidence__body">
              <p id="focus-evidence-copy"></p>
              <div id="focus-evidence-sources" class="focus-evidence__sources"></div>
              <button id="focus-details" type="button"><span id="focus-details-label"></span><i aria-hidden="true">↓</i></button>
            </div>
          </details>
          <div class="focus-guidance-grid">
            <article><small>{t(lang, 'reading.chartAtGlance')}</small><p id="focus-structure"></p></article>
            <article><small>{t(lang, 'fortune.timing.title')}</small><p id="focus-timing"></p></article>
            <article><small>{t(lang, 'reading.readingGuide.title')}</small><p id="focus-limit"></p></article>
          </div>
          <p id="health-disclaimer" class="health-disclaimer" hidden>{t(lang, 'experience.healthDisclaimer')}</p>
        </div>
      </article>
    </section>

    <section id="original-chart" class="card chart-matrix-panel">
      <div class="chart-matrix-heading">
        <div>
          <p class="panel-overline">ORIGINAL CHART</p>
          <h2>{t(lang, 'reading.originalChart')}</h2>
          <p>{t(lang, 'reading.originalChartContext')}</p>
        </div>
        <div class="chart-layer-controls" role="group" aria-label={t(lang, 'reading.displayLayers')}>
          <button type="button" data-layer-toggle="ten-gods" aria-pressed="true">{t(lang, 'reading.showTenGods')}</button>
          <button type="button" data-layer-toggle="hidden" aria-pressed="true">{t(lang, 'reading.showHiddenStems')}</button>
          <button type="button" data-layer-toggle="stages" aria-pressed="true">{t(lang, 'reading.showTwelveStage')}</button>
          <button type="button" data-layer-toggle="stars" aria-pressed="true">{t(lang, 'reading.showShinsal')}</button>
        </div>
      </div>
      <div id="pillars" class="pillars"></div>
      <div id="chart-facts" class="chart-facts"></div>
    </section>

    <h2 class="section-title">{t(lang, 'reading.chartAtGlance')}</h2>
    <div class="insight-grid">
      <section class="card panel day-master-panel">
        <div class="panel-heading">
          <h2><button class="gloss" data-gloss="ilgan" type="button">{t(lang, 'reading.dayMaster')}</button></h2>
          <span class="panel-index" aria-hidden="true">01</span>
        </div>
        <div class="day-master-layout">
          <div class="dm-symbol" id="dm-symbol">
            <span id="dm-char" lang="ko"></span>
            <small id="dm-reading"></small>
          </div>
          <p id="dm-text"></p>
        </div>
      </section>
      <section class="card panel yin-yang-panel">
        <div class="panel-heading">
          <h2>{t(lang, 'reading.yinYangBalance')}</h2>
          <span class="panel-index" aria-hidden="true">02</span>
        </div>
        <div class="yy-layout">
          <div id="yy-donut" class="yy-donut" role="img">
            <div class="yy-center"><strong id="yy-ratio">0%</strong><span>陽</span></div>
          </div>
          <div class="yy-details">
            <div class="yy-legend" aria-hidden="true">
              <span><i class="yang-dot"></i>陽 <strong id="yy-yang-count">0</strong></span>
              <span><i class="yin-dot"></i>陰 <strong id="yy-yin-count">0</strong></span>
            </div>
            <p id="yy-text"></p>
          </div>
        </div>
      </section>
    </div>

    <section id="element-balance" class="card panel element-panel">
      <div class="panel-heading">
        <div>
          <p class="panel-overline">{t(lang, 'reading.elementPattern')}</p>
          <h2><button class="gloss" data-gloss="ohaeng" type="button">{t(lang, 'reading.elements')}</button></h2>
        </div>
        <span class="panel-index" aria-hidden="true">03</span>
      </div>
      <div class="element-dashboard">
        <div class="radar-wrap">
          <svg id="element-radar" viewBox="0 0 360 340" role="img" aria-label={t(lang, 'reading.elements')}>
            <g id="radar-grid"></g>
            <polygon id="radar-shape" points="180,170 180,170 180,170 180,170 180,170"></polygon>
            <g id="radar-points"></g>
            <g id="radar-labels"></g>
          </svg>
        </div>
        <div class="element-breakdown">
          <div id="element-bars" class="element-bars"></div>
          <div class="pattern-summary">
            <p id="dominant-text"></p>
            <p id="missing-text" class="soft"></p>
          </div>
        </div>
      </div>
      <p class="soft context-note">{t(lang, 'reading.elementContext')}</p>
    </section>

    <section id="ten-gods-analysis" class="card panel gods-panel" data-expert-only>
      <div class="panel-heading">
        <h2><button class="gloss" data-gloss="sipseong" type="button">{t(lang, 'reading.tenGods')}</button></h2>
        <span class="panel-index" aria-hidden="true">04</span>
      </div>
      <div id="ten-god-distribution" class="ten-god-distribution" role="list"></div>
      <div class="table-scroll"><table id="tengods" class="tengods"></table></div>
      <p class="soft context-note">{t(lang, 'reading.tenGodsContext')} {t(lang, 'reading.hiddenStemsContext')}</p>
    </section>

    <section id="hidden-stems-analysis" class="card panel hidden-stems-panel" data-expert-only>
      <div class="panel-heading">
        <h2>{t(lang, 'reading.hiddenStems')}</h2>
        <span class="panel-index" aria-hidden="true">05</span>
      </div>
      <div id="hidden-stems" class="hidden-stems-grid"></div>
      <p class="soft context-note">{t(lang, 'reading.hiddenStemsContext')}</p>
    </section>

    <div class="analysis-grid">
      <section id="strength-analysis" class="card panel strength-panel">
        <div class="panel-heading">
          <h2><button class="gloss" data-gloss="singang" type="button">{t(lang, 'reading.strength')}</button></h2>
          <span class="panel-index" aria-hidden="true">06</span>
        </div>
        <div id="strength-verdict" class="strength-verdict"></div>
        <div id="strength-marks" class="strength-marks"></div>
        <div class="relation-section">
          <h3><button class="gloss" data-gloss="yongsin" type="button">{t(lang, 'reading.favorableTitle')}</button></h3>
          <div id="favorable-list" class="favorable-list"></div>
        </div>
        <div class="relation-section">
          <h3><button class="gloss" data-gloss="johu" type="button">{t(lang, 'reading.johuTitle')}</button></h3>
          <div id="johu-list" class="favorable-list"></div>
        </div>
        <p class="soft context-note">{t(lang, 'reading.strengthContext')} {t(lang, 'reading.johuContext')}</p>
      </section>
      <section id="palace-analysis" class="card panel palace-panel">
        <div class="panel-heading">
          <h2>
            <button class="gloss" data-gloss="taewon" type="button">{t(lang, 'reading.taewonLabel')}</button>
            ·
            <button class="gloss" data-gloss="myeonggung" type="button">{t(lang, 'reading.myeonggungLabel')}</button>
          </h2>
          <span class="panel-index" aria-hidden="true">07</span>
        </div>
        <div id="palace-cards" class="palace-cards"></div>
        <p class="soft context-note">{t(lang, 'reading.palaceContext')}</p>
      </section>
    </div>

    <div class="analysis-grid">
      <section id="gyeokguk-analysis" class="card panel gyeokguk-panel">
        <div class="panel-heading">
          <h2><button class="gloss" data-gloss="gyeokguk" type="button">{t(lang, 'reading.gyeokguk')}</button></h2>
          <span class="panel-index" aria-hidden="true">08</span>
        </div>
        <div id="gyeokguk-result" class="gyeokguk-result"></div>
        <p class="soft context-note">{t(lang, 'reading.gyeokgukContext')}</p>
      </section>
      <section id="samjae-analysis" class="card panel samjae-panel">
        <div class="panel-heading">
          <h2><button class="gloss" data-gloss="samjae" type="button">{t(lang, 'reading.samjae')}</button></h2>
          <span class="panel-index" aria-hidden="true">09</span>
        </div>
        <div id="samjae-result" class="samjae-result"></div>
        <p class="soft context-note">{t(lang, 'reading.samjaeContext')}</p>
      </section>
    </div>

    <div class="analysis-grid">
      <section id="relations-analysis" class="card panel relations-panel" data-expert-only>
        <div class="panel-heading">
          <h2>{t(lang, 'reading.allRelations')}</h2>
          <span class="panel-index" aria-hidden="true">10</span>
        </div>
        <div class="relation-section"><h3>{t(lang, 'reading.branchRelations')}</h3><div id="branch-relations" class="relation-list"></div></div>
        <div class="relation-section"><h3>{t(lang, 'reading.stemRelations')}</h3><div id="stem-relations" class="relation-list"></div></div>
        <div class="relation-section"><h3>{t(lang, 'reading.harmonies')}</h3><div id="harmony-groups" class="harmony-list"></div></div>
        <p class="soft context-note">{t(lang, 'reading.relationsContext')}</p>
      </section>
      <section id="shinsal-analysis" class="card panel shinsal-panel" data-expert-only>
        <div class="panel-heading">
          <h2>{t(lang, 'reading.shinsal')}</h2>
          <span class="panel-index" aria-hidden="true">11</span>
        </div>
        <div id="shinsal-list" class="shinsal-list"></div>
        <p class="soft context-note">{t(lang, 'reading.shinsalContext')}</p>
      </section>
    </div>

    <section id="luck-analysis" class="card panel luck-panel daeun-panel">
      <div class="panel-heading">
        <div>
          <p class="panel-overline">10 YEAR CYCLES</p>
          <h2>{t(lang, 'reading.daeun')}</h2>
        </div>
        <span class="panel-index" aria-hidden="true">12</span>
      </div>
      <nav class="timing-path" aria-label={t(lang, 'fortune.timing.title')}>
        <button type="button" data-timing-target="daeun-list"><span>大運</span><strong>{t(lang, 'reading.daeun')}</strong><small id="timing-path-daeun">—</small></button>
        <i aria-hidden="true">→</i>
        <button type="button" data-timing-target="seun-list"><span>歲運</span><strong>{t(lang, 'reading.seun')}</strong><small id="timing-path-seun">—</small></button>
        <i aria-hidden="true">→</i>
        <button type="button" data-timing-target="wolun-list"><span>月運</span><strong>{t(lang, 'reading.wolunTitle').replace('{year}', '')}</strong><small id="timing-path-wolun">—</small></button>
      </nav>
      <div class="current-timing">
        <div class="current-timing__heading">
          <span aria-hidden="true">今</span>
          <div>
            <h3>{t(lang, 'fortune.timing.title')}</h3>
          </div>
        </div>
        <div id="current-timing-cards" class="current-timing__cards"></div>
      </div>
      <p id="daeun-meta" class="luck-meta"></p>
      <div id="daeun-list" class="luck-strip"></div>
      <div id="daeun-detail" class="luck-detail"></div>
      <p class="soft context-note">{t(lang, 'reading.daeunContext')}</p>
    </section>

    <section id="seun-analysis" class="card panel luck-panel seun-panel">
      <div class="panel-heading">
        <div>
          <p class="panel-overline">YEARLY CYCLES</p>
          <h2>{t(lang, 'reading.seun')}</h2>
        </div>
        <span class="panel-index" aria-hidden="true">13</span>
      </div>
      <div id="seun-list" class="luck-strip luck-strip--annual"></div>
      <div id="seun-detail" class="luck-detail"></div>
      <div class="wolun">
        <h3 id="wolun-title"></h3>
        <div id="wolun-list" class="wolun-grid"></div>
        <p class="soft context-note">{t(lang, 'reading.wolunContext')}</p>
      </div>
      <p class="soft context-note">{t(lang, 'reading.seunContext')}</p>
    </section>

    <section class="pillar-guide">
      <h2>{t(lang, 'reading.pillarRoles')}</h2>
      <div class="role-grid">
        {(['year', 'month', 'day', 'hour'] as const).map((role) => (
          <article class="role-card">
            <span aria-hidden="true">{role === 'year' ? '年' : role === 'month' ? '月' : role === 'day' ? '日' : '時'}</span>
            <h3>{t(lang, `reading.role.${role}.title`)}</h3>
            <p>{t(lang, `reading.role.${role}.body`)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="card reading-guide">
      <div aria-hidden="true" class="guide-mark">讀</div>
      <div>
        <h2>{t(lang, 'reading.readingGuide.title')}</h2>
        <p>{t(lang, 'reading.readingGuide.body')}</p>
      </div>
    </section>

    <div class="actions card">
      <button id="share-native" class="btn-primary" type="button" hidden>{t(lang, 'reading.shareNative')}</button>
      <button id="share-url" class="btn-secondary" type="button">{t(lang, 'reading.share')}</button>
      <button id="share-png" class="btn-secondary" type="button">{t(lang, 'reading.sharePng')}</button>
      <button id="share-story" class="btn-secondary" type="button">{t(lang, 'reading.shareStory')}</button>
      <a class="btn-secondary" href={withBase(`/${lang}/learn/`)} data-analytics-event="navigation_click" data-analytics-destination="learn_from_chart" data-analytics-area="reading_actions">{t(lang, 'reading.learnMore')}</a>
      <a class="btn-secondary" href={withBase(`/${lang}/methodology/`)} data-analytics-event="navigation_click" data-analytics-destination="methodology_from_chart" data-analytics-area="reading_actions">{t(lang, 'methodology.title')}</a>
    </div>
    <p class="disclaimer">{t(lang, 'reading.disclaimer')}</p>
  </section>

  <section id="no-query" class="reading-empty" hidden>
    <header class="reading-empty__hero">
      <div>
        <p class="panel-overline">{t(lang, 'fortune.eyebrow')}</p>
        <h1>{t(lang, 'reading.yourPillars')}</h1>
        <p>{t(lang, 'reading.readingGuide.body')}</p>
        <p id="render-error" class="note" hidden>{t(lang, 'readingError')}</p>
        <a class="btn-primary" href={`${withBase(`/${lang}/`)}#birth-form`} data-analytics-event="navigation_click" data-analytics-destination="birth_form" data-analytics-area="reading_empty">{t(lang, 'hero.cta')} <span aria-hidden="true">→</span></a>
      </div>
      <div class="reading-empty__mark" aria-hidden="true"><span>命</span><i></i></div>
    </header>

    <section class="reading-empty__features" aria-labelledby="reading-empty-features-title">
      <div class="reading-empty__heading">
        <h2 id="reading-empty-features-title">{t(lang, 'reading.chartAtGlance')}</h2>
        <p>{t(lang, 'fortune.resultSubtitle')}</p>
      </div>
      <div class="reading-empty__grid">
        {EMPTY_READING_FEATURES.map((feature, index) => (
          <article class="reading-empty__feature">
            <div><span aria-hidden="true">{feature.mark}</span><small>{String(index + 1).padStart(2, '0')}</small></div>
            <h3>{t(lang, feature.title)}</h3>
            <p>{t(lang, feature.body)}</p>
          </article>
        ))}
      </div>
    </section>
  </section>

  <GlossaryTooltip lang={lang} />

  <script>
    import KoreanLunarCalendar from 'korean-lunar-calendar';
    import {
      BRANCHES_HANJA,
      STEMS_HANJA,
      cheonEulBranchesForDayStem,
      computeAnnualLuck,
      computeSaju,
      hiddenStemsForBranch,
      ipchunUtcMs,
      nayinForPillar,
      sunApparentLongitude,
      twelveShinsalForBranch,
      twelveStageForStemBranch,
      voidBranchesForPillar,
      type AnnualLuck,
      type LuckCycle,
      type Pillar,
      type PillarRole,
      type SajuResult,
      type ShinsalName,
      type TwelveShinsalName,
      type TwelveStage,
    } from '../../lib/saju-engine';
    import {
      extraShinsal, favorableElements, gyeokguk, johuYongsin, monthlyLuck,
      myeonggungPillar, samjae, strengthAnalysis, taewonPillar,
      type MiniPillar,
    } from '../../lib/saju-extras';
    import { trackEvent } from '../../lib/analytics';

    const S: Record<string, string> = JSON.parse(document.getElementById('i18n-reading')!.textContent!);
    const READING_MODE_KEY = 'showmethesaju.reading-mode.v1';
    const rawState = location.hash.length > 1 ? location.hash.slice(1) : location.search;
    const q = new URLSearchParams(rawState);
    if (!location.hash && location.search && q.size) {
      const migrated = new URL(location.href);
      migrated.search = '';
      migrated.hash = q.toString();
      location.replace(migrated);
    }
    const readingFocuses = ['basic', 'personality', 'wealth', 'health', 'career', 'relationships', 'noble', 'movement', 'timing'] as const;
    type ReadingFocus = typeof readingFocuses[number];
    let selectedReadingFocus: ReadingFocus = readingFocuses.includes(q.get('focus') as ReadingFocus)
      ? q.get('focus') as ReadingFocus : 'basic';
    const fmt = (template: string, vars: Record<string, string | number>) =>
      Object.entries(vars).reduce((text, [key, value]) => text.replaceAll(`{${key}}`, String(value)), template);
    const tenGodLabel = (name: string | null) => name ? (S[`tg.${name}`] ?? name) : S['notApplicable'];
    const stageLabel = (stage: TwelveStage) => S[`stage.${stage}`] ?? stage;
    const twelveShinsalLabel = (name: TwelveShinsalName) => S[`twelve.${name}`] ?? name;

    function setupReadingMode() {
      const result = document.getElementById('result')!;
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('button[data-reading-mode]'));
      const apply = (mode: 'beginner' | 'expert', track = false) => {
        result.dataset.readingMode = mode;
        buttons.forEach((button) => button.setAttribute('aria-pressed', String(button.dataset.readingMode === mode)));
        try { localStorage.setItem(READING_MODE_KEY, mode); } catch { /* optional display preference */ }
        if (track) trackEvent('reading_mode_select', { display_mode: mode, language: document.documentElement.lang });
      };
      buttons.forEach((button) => button.addEventListener('click', () => apply(button.dataset.readingMode === 'expert' ? 'expert' : 'beginner', true)));
      let saved: 'beginner' | 'expert' = 'beginner';
      try { if (localStorage.getItem(READING_MODE_KEY) === 'expert') saved = 'expert'; } catch { /* use beginner */ }
      apply(saved);
    }

    const values = {
      year: Number(q.get('y')), month: Number(q.get('m')), day: Number(q.get('d')),
      hour: Number(q.get('h')), minute: Number(q.get('mi')),
      tzOffsetMinutes: Number(q.get('tz')), longitude: Number(q.get('lon')),
    };
    const gender = q.get('g') === 'f' ? 'female' : q.get('g') === 'm' ? 'male' : undefined;
    const dateCheck = new Date(Date.UTC(values.year, values.month - 1, values.day));
    const requiredState = ['y', 'm', 'd', 'h', 'mi', 'tz', 'lon'];
    const validQuery = requiredState.every((key) => q.has(key)) && (!q.has('g') || Boolean(gender)) && Object.values(values).every(Number.isFinite) &&
      values.year >= 1900 && values.year <= 2050 &&
      dateCheck.getUTCFullYear() === values.year && dateCheck.getUTCMonth() === values.month - 1 && dateCheck.getUTCDate() === values.day &&
      values.hour >= 0 && values.hour <= 23 && values.minute >= 0 && values.minute <= 59 &&
      values.tzOffsetMinutes >= -840 && values.tzOffsetMinutes <= 840 &&
      values.longitude >= -180 && values.longitude <= 180;

    function pillarCard(p: Pillar | null, label: string, role: PillarRole, i: number, r: SajuResult): string {
      if (!p) return `<article class="pillar pillar-empty reveal" style="--reveal-i:${i}">
        <header class="pillar-top"><span class="pillar-label">${label}</span></header>
        <p class="hint">${S['hourUnknown']}</p>
      </article>`;
      const stemGod = role === 'day' ? S['daySelf'] : tenGodLabel(p.tenGod);
      const branchGod = r.hiddenStems[role].at(-1)?.tenGod ?? null;
      const dayStage = twelveStageForStemBranch(r.day.stem, p.branch);
      const pillarStage = twelveStageForStemBranch(p.stem, p.branch);
      const nayin = nayinForPillar(p.stem, p.branch);
      const yearStar = twelveShinsalForBranch(r.year.branch, p.branch);
      const dayStar = twelveShinsalForBranch(r.day.branch, p.branch);
      const stars = r.shinsal.filter((item) => item.targetRole === role).map((item) => item.name);
      const hidden = r.hiddenStems[role].map((item) =>
        `<span><small>${S[`qi.${item.phase}`]}</small><strong class="element-text--${item.element}" lang="ko">${item.stemHanja}</strong><i>${tenGodLabel(item.tenGod)}</i></span>`
      ).join('');
      return `<article class="pillar pillar--${p.stemElement} ${role === 'day' ? 'pillar--day' : ''} reveal" data-pillar-role="${role}" style="--reveal-i:${i}">
        <header class="pillar-top"><span class="pillar-label">${label}</span><span class="ten-god" data-layer="ten-gods">${stemGod}</span></header>
        <div class="glyph-stack" lang="ko">
          <span class="matrix-glyph-label" data-layer="ten-gods">${S['stemTenGod']} · ${stemGod}</span>
          <span class="pillar-glyph glyph-tile element-bg-soft--${p.stemElement} element-text--${p.stemElement}">${p.stemHanja}</span>
          <span class="glyph-bridge" aria-hidden="true"></span>
          <span class="pillar-glyph glyph-tile element-bg-soft--${p.branchElement} element-text--${p.branchElement}">${p.branchHanja}</span>
          <span class="matrix-glyph-label" data-layer="ten-gods">${S['branchTenGod']} · ${tenGodLabel(branchGod)}</span>
        </div>
        <div class="pillar-layer pillar-hidden-layer" data-layer="hidden"><b>${S['hiddenStems']}</b><div>${hidden}</div></div>
        <div class="pillar-layer pillar-stage-layer" data-layer="stages">
          <span><small>${S['twelveStageDay']}</small><strong>${stageLabel(dayStage)}</strong></span>
          <span><small>${S['twelveStagePillar']}</small><strong>${stageLabel(pillarStage)}</strong></span>
        </div>
        <div class="pillar-layer pillar-nayin-layer"><small>${S['nayin']}</small><strong lang="ko">${nayin.hanja}</strong><span>${document.documentElement.lang === 'ko' ? nayin.ko : S[`el.${nayin.element}`]}</span></div>
        <div class="pillar-layer pillar-star-layer" data-layer="stars">
          <div><span>${S['yearBasis']}</span><strong>${twelveShinsalLabel(yearStar)}</strong></div>
          <div><span>${S['dayBasis']}</span><strong>${twelveShinsalLabel(dayStar)}</strong></div>
          ${stars.length ? `<p>${[...new Set(stars)].map((name) => shinsalLabel(name)).join(' · ')}</p>` : ''}
        </div>
        <footer class="pillar-bottom"><strong>${p.stemKo}${p.branchKo}</strong><span class="element-pair"><i class="element-dot element-bg--${p.stemElement}"></i>${S[`el.${p.stemElement}`]}<b>·</b><i class="element-dot element-bg--${p.branchElement}"></i>${S[`el.${p.branchElement}`]}</span></footer>
      </article>`;
    }

    const elementOrder = ['wood', 'fire', 'earth', 'metal', 'water'] as const;
    const svgPoint = (index: number, ratio: number, radius = 112) => {
      const angle = (-90 + index * 72) * Math.PI / 180;
      return [180 + Math.cos(angle) * radius * ratio, 165 + Math.sin(angle) * radius * ratio] as const;
    };
    const svgPoints = (ratio: number, radius = 112) => elementOrder
      .map((_, index) => svgPoint(index, ratio, radius).map((n) => n.toFixed(1)).join(','))
      .join(' ');

    function renderElementRadar(counts: SajuResult['elementCounts'], total: number) {
      const grid = document.getElementById('radar-grid')!;
      grid.innerHTML = [0.25, 0.5, 0.75, 1]
        .map((level) => `<polygon class="radar-level" points="${svgPoints(level)}"></polygon>`)
        .join('') + elementOrder.map((_, index) => {
          const [x, y] = svgPoint(index, 1);
          return `<line class="radar-axis" x1="180" y1="165" x2="${x.toFixed(1)}" y2="${y.toFixed(1)}"></line>`;
        }).join('');

      const dataPoints = elementOrder.map((element, index) => svgPoint(index, counts[element] / total));
      document.getElementById('radar-shape')!.setAttribute('points', dataPoints
        .map(([x, y]) => `${x.toFixed(1)},${y.toFixed(1)}`)
        .join(' '));
      document.getElementById('radar-points')!.innerHTML = dataPoints.map(([x, y], index) =>
        `<circle class="radar-point element-fill--${elementOrder[index]}" cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="5"></circle>`
      ).join('');
      document.getElementById('radar-labels')!.innerHTML = elementOrder.map((element, index) => {
        const [x, y] = svgPoint(index, 1, 142);
        return `<text class="radar-label element-fill--${element}" x="${x.toFixed(1)}" y="${y.toFixed(1)}">${S[`el.${element}`]}</text>`;
      }).join('');
      document.getElementById('element-radar')!.setAttribute('aria-label', elementOrder
        .map((element) => `${S[`el.${element}`]} ${counts[element]}`).join(', '));
    }

    const roleLabels: Record<PillarRole, string> = {
      year: S['pillarYear'], month: S['pillarMonth'], day: S['pillarDay'], hour: S['pillarHour'],
    };
    const relationLabel = (type: string) => S[`rel.${type}`] ?? type;
    const shinsalLabel = (name: string) => S[`shinsal.${name}`] ?? name;
    const ageLabel = (totalMonths: number) => fmt(S['ageYearsMonths'], {
      years: Math.floor(totalMonths / 12), months: totalMonths % 12,
    });

    function currentTiming(r: SajuResult) {
      const now = new Date();
      const civilYear = now.getFullYear();
      const currentSajuYear = now.getTime() < ipchunUtcMs(civilYear) ? civilYear - 1 : civilYear;
      let ageMonths = (civilYear - values.year) * 12 + (now.getMonth() + 1 - values.month);
      if (now.getDate() < values.day) ageMonths--;
      let activeDaeunIndex = -1;
      r.daeun?.cycles.forEach((cycle, index) => {
        if (cycle.startAgeMonths <= ageMonths) activeDaeunIndex = index;
      });
      const activeDaeun = activeDaeunIndex >= 0 ? r.daeun?.cycles[activeDaeunIndex] : undefined;
      const annual = computeAnnualLuck(r, currentSajuYear, 1)[0];
      const julianDay = now.getTime() / 86400000 + 2440587.5;
      const solarMonthIndex = Math.floor((((sunApparentLongitude(julianDay) - 315) % 360) + 360) % 360 / 30);
      const month = monthlyLuck(annual.pillar.stem, r.day.stem, currentSajuYear)[solarMonthIndex];
      return { now, currentSajuYear, ageMonths, activeDaeunIndex, activeDaeun, annual, month };
    }

    function hiddenStemMarkup(branch: number, r: SajuResult) {
      return hiddenStemsForBranch(branch, r.day.stem).map((hidden) =>
        `<span class="hidden-chip">
          <small>${S[`qi.${hidden.phase}`]}</small>
          <strong class="element-text--${hidden.element}" lang="ko">${hidden.stemHanja}</strong>
          <span>${tenGodLabel(hidden.tenGod)}</span>
        </span>`
      ).join('');
    }

    function renderHiddenStems(r: SajuResult) {
      const rows: [PillarRole, Pillar | null][] = [
        ['hour', r.hour], ['day', r.day], ['month', r.month], ['year', r.year],
      ];
      document.getElementById('hidden-stems')!.innerHTML = rows.map(([role, pillar]) =>
        `<article class="hidden-pillar">
          <header><span>${roleLabels[role]}</span>${pillar ? `<strong lang="ko">${pillar.branchHanja}</strong>` : ''}</header>
          <div>${pillar ? hiddenStemMarkup(pillar.branch, r) : `<span class="soft">${S['hourUnknown']}</span>`}</div>
        </article>`
      ).join('');
    }

    function renderChartFacts(r: SajuResult) {
      const locale = document.documentElement.lang || 'en';
      const solarDate = new Intl.DateTimeFormat(locale, { dateStyle: 'long', timeZone: 'UTC' })
        .format(new Date(Date.UTC(values.year, values.month - 1, values.day)));
      const calendar = new KoreanLunarCalendar();
      let lunarDate = S['notApplicable'];
      if (calendar.setSolarDate(values.year, values.month, values.day)) {
        const lunar = calendar.getLunarCalendar();
        lunarDate = fmt(S['lunarDateFormat'], {
          year: lunar.year,
          month: lunar.month,
          day: lunar.day,
        });
        if (lunar.intercalation) lunarDate += ` · ${S['leapMonthShort']}`;
      }
      const today = new Date();
      let age = today.getFullYear() - values.year;
      if (today.getMonth() + 1 < values.month || (today.getMonth() + 1 === values.month && today.getDate() < values.day)) age--;
      const monthCommander = r.hiddenStems.month.at(-1);
      const branchText = (branches: number[]) => branches.map((branch) => BRANCHES_HANJA[branch]).join(' · ');
      const facts = [
        [S['solarBirth'], solarDate, '陽'],
        [S['lunarBirth'], lunarDate, '陰'],
        [S['currentAge'], age >= 0 ? fmt(S['ageYears'], { age }) : S['notApplicable'], '今'],
        [S['monthCommander'], monthCommander ? `${monthCommander.stemHanja} · ${tenGodLabel(monthCommander.tenGod)}` : S['notApplicable'], '令'],
        [S['dayVoid'], branchText(voidBranchesForPillar(r.day.stem, r.day.branch)), '空'],
        [S['yearVoid'], branchText(voidBranchesForPillar(r.year.stem, r.year.branch)), '旬'],
        [S['cheonEulBranches'], branchText(cheonEulBranchesForDayStem(r.day.stem)), '貴'],
        [S['daeunDirection'], r.daeun ? S[r.daeun.direction] : S['genderRequired'], '運'],
      ];
      document.getElementById('chart-facts')!.innerHTML = facts.map(([label, value, mark]) =>
        `<article><span aria-hidden="true">${mark}</span><small>${label}</small><strong>${value}</strong></article>`
      ).join('');
    }

    function setupLayerControls() {
      const board = document.querySelector('.chart-matrix-panel')!;
      document.querySelectorAll<HTMLButtonElement>('[data-layer-toggle]').forEach((button) => {
        button.addEventListener('click', () => {
          const layer = button.dataset.layerToggle!;
          const next = button.getAttribute('aria-pressed') !== 'true';
          button.setAttribute('aria-pressed', String(next));
          board.classList.toggle(`hide-layer--${layer}`, !next);
          trackEvent('chart_layer_toggle', { layer_name: layer, layer_state: next ? 'shown' : 'hidden', language: document.documentElement.lang });
        });
      });
    }

    function renderReadingFocus(r: SajuResult) {
      const visiblePillars = [r.hour, r.day, r.month, r.year].filter((pillar): pillar is Pillar => Boolean(pillar));
      const visibleGods = visiblePillars.map((pillar) => pillar.tenGod).filter((god): god is NonNullable<typeof god> => Boolean(god));
      const hiddenGods = Object.values(r.hiddenStems).flat().map((stem) => stem.tenGod);
      const allGods = [...visibleGods, ...hiddenGods];
      const countGods = (...names: string[]) => allGods.filter((god) => names.includes(god)).length;
      const wealthCount = countGods('편재', '정재');
      const authorityCount = countGods('편관', '정관');
      const outputCount = countGods('식신', '상관');
      const wealthElementByDayMaster = { wood: 'earth', fire: 'metal', earth: 'water', metal: 'wood', water: 'fire' } as const;
      const wealthElement = wealthElementByDayMaster[r.dayMaster.element];
      const elementEntries = Object.entries(r.elementCounts) as [keyof SajuResult['elementCounts'], number][];
      const totalElements = elementEntries.reduce((sum, [, count]) => sum + count, 0);
      const maxElementCount = Math.max(...elementEntries.map(([, count]) => count));
      const minElementCount = Math.min(...elementEntries.map(([, count]) => count));
      const dominantElement = elementEntries.find(([, count]) => count === maxElementCount)?.[0] ?? r.dayMaster.element;
      const lowElements = elementEntries.filter(([, count]) => count === minElementCount).map(([element]) => S[`el.${element}`]).join(' · ');
      const yang = visiblePillars.reduce((sum, pillar) => sum + Number(pillar.stemYang) + Number(pillar.branchYang), 0);
      const yin = visiblePillars.length * 2 - yang;
      const relationPairs = new Set(r.relations.map((relation) => [relation.leftRole, relation.rightRole].sort().join('-'))).size;
      const relationshipStars = r.shinsal.filter((item) => item.name === 'peachBlossom').length;
      const heavenlyNobleCount = r.shinsal.filter((item) => item.name === 'cheonEul').length;
      const literaryCount = r.shinsal.filter((item) => item.name === 'munChang').length;
      const virtueCount = r.shinsal.filter((item) => item.name === 'cheonDeok' || item.name === 'wolDeok').length;
      const travelCount = r.shinsal.filter((item) => item.name === 'travelHorse').length;
      const strength = strengthAnalysis(r);
      const structure = gyeokguk(r);
      const { currentSajuYear, activeDaeun, annual } = currentTiming(r);
      const metric = (label: string, value: string | number) => `<span><small>${label}</small><strong>${value}</strong></span>`;
      const configs: Record<ReadingFocus, { mark: string; summary: string; metrics: string; target: string; targetLabel: string; context: string; sources: string[] }> = {
        basic: {
          mark: '命',
          summary: fmt(S['focus.basic.summary'], { dayMaster: `${r.dayMaster.hanja} ${r.dayMaster.ko}`, element: S[`el.${dominantElement}`], count: maxElementCount, total: totalElements, yang, yin }),
          metrics: metric(S['focus.metric.dayMaster'], `${r.dayMaster.hanja} · ${S[`el.${r.dayMaster.element}`]}`) + metric(S['focus.metric.dominantElement'], S[`el.${dominantElement}`]) + metric(S['focus.metric.yinYang'], `${yang} / ${yin}`),
          target: '#original-chart',
          targetLabel: S['originalChart'],
          context: S['elementContext'],
          sources: [S['dayMaster'], S['elements'], S['yinYangBalance']],
        },
        personality: {
          mark: '氣',
          summary: fmt(S['focus.personality.summary'], { dayMaster: `${r.dayMaster.hanja} ${r.dayMaster.ko}`, strength: S[`strengthV.${strength.verdict}`], structure: S[`gg.${structure.name}`] }),
          metrics: metric(S['focus.metric.dayMaster'], `${r.dayMaster.hanja} · ${S[`el.${r.dayMaster.element}`]}`) + metric(S['focus.metric.strength'], S[`strengthV.${strength.verdict}`]) + metric(S['focus.metric.structure'], S[`gg.${structure.name}`]),
          target: '#strength-analysis',
          targetLabel: S['strength'],
          context: `${S['strengthContext']} ${S['gyeokgukContext']}`,
          sources: [S['dayMaster'], S['strength'], S['gyeokguk']],
        },
        wealth: {
          mark: '財',
          summary: fmt(S['focus.wealth.summary'], { wealthCount, element: S[`el.${wealthElement}`] }),
          metrics: metric(S['focus.metric.wealthElement'], S[`el.${wealthElement}`]) + metric(S['focus.metric.wealthStars'], wealthCount) + metric(S['focus.metric.currentDaeun'], activeDaeun?.pillar.hanja ?? S['focus.unavailable']),
          target: '#ten-gods-analysis',
          targetLabel: S['tenGods'],
          context: `${S['tenGodsContext']} ${S['hiddenStemsContext']}`,
          sources: [S['tenGods'], S['hiddenStems'], S['daeun']],
        },
        health: {
          mark: '身',
          summary: fmt(S['focus.health.summary'], { dominant: S[`el.${dominantElement}`], lowElements }),
          metrics: metric(S['focus.metric.dominantElement'], S[`el.${dominantElement}`]) + metric(S['focus.metric.leastElements'], lowElements) + metric(S['focus.metric.visibleBalance'], `${maxElementCount} : ${minElementCount}`),
          target: '#element-balance',
          targetLabel: S['elements'],
          context: S['elementContext'],
          sources: [S['elements'], S['yinYangBalance'], S['strength']],
        },
        career: {
          mark: '業',
          summary: fmt(S['focus.career.summary'], { authorityCount, outputCount }),
          metrics: metric(S['focus.metric.authorityStars'], authorityCount) + metric(S['focus.metric.outputStars'], outputCount) + metric(S['focus.metric.monthPillar'], r.month.hanja),
          target: '#ten-gods-analysis',
          targetLabel: S['tenGods'],
          context: `${S['tenGodsContext']} ${S['hiddenStemsContext']}`,
          sources: [S['tenGods'], S['hiddenStems'], S['pillarMonth']],
        },
        relationships: {
          mark: '緣',
          summary: fmt(S['focus.relationships.summary'], { dayBranch: `${r.day.branchHanja} ${r.day.branchKo}`, relationCount: relationPairs, starCount: relationshipStars }),
          metrics: metric(S['focus.metric.dayBranch'], r.day.branchHanja) + metric(S['focus.metric.relations'], relationPairs) + metric(S['focus.metric.relationshipStars'], relationshipStars),
          target: '#relations-analysis',
          targetLabel: S['allRelations'],
          context: `${S['relationsContext']} ${S['shinsalContext']}`,
          sources: [S['pillarDay'], S['allRelations'], S['shinsal']],
        },
        noble: {
          mark: '貴',
          summary: fmt(S['focus.noble.summary'], { nobleCount: heavenlyNobleCount, literaryCount, virtueCount }),
          metrics: metric(S['focus.metric.heavenlyNoble'], heavenlyNobleCount) + metric(S['focus.metric.literaryStar'], literaryCount) + metric(S['focus.metric.virtueStars'], virtueCount),
          target: '#shinsal-analysis',
          targetLabel: S['shinsal'],
          context: S['shinsalContext'],
          sources: [S['shinsal'], S['cheonEulBranches'], S['pillarRoles']],
        },
        movement: {
          mark: '動',
          summary: fmt(S['focus.movement.summary'], { travelCount, relationCount: relationPairs, daeunPillar: activeDaeun?.pillar.hanja ?? S['focus.unavailable'] }),
          metrics: metric(S['focus.metric.travelHorse'], travelCount) + metric(S['focus.metric.relations'], relationPairs) + metric(S['focus.metric.currentDaeun'], activeDaeun?.pillar.hanja ?? S['focus.unavailable']),
          target: '#shinsal-analysis',
          targetLabel: S['shinsal'],
          context: `${S['shinsalContext']} ${S['relationsContext']}`,
          sources: [S['shinsal'], S['allRelations'], S['daeun']],
        },
        timing: {
          mark: '運',
          summary: fmt(S['focus.timing.summary'], { direction: r.daeun ? S[r.daeun.direction] : S['focus.unavailable'], daeunPillar: activeDaeun?.pillar.hanja ?? S['focus.unavailable'], year: currentSajuYear, annualPillar: annual.pillar.hanja }),
          metrics: metric(S['focus.metric.direction'], r.daeun ? S[r.daeun.direction] : S['focus.unavailable']) + metric(S['focus.metric.currentDaeun'], activeDaeun?.pillar.hanja ?? S['focus.unavailable']) + metric(S['focus.metric.annualPillar'], annual.pillar.hanja),
          target: '#luck-analysis',
          targetLabel: S['daeun'],
          context: `${S['daeunContext']} ${S['seunContext']}`,
          sources: [S['daeun'], S['seun'], fmt(S['wolunTitle'], { year: currentSajuYear })],
        },
      };

      const paint = (focus: ReadingFocus, track = false) => {
        const config = configs[focus];
        selectedReadingFocus = focus;
        document.querySelectorAll<HTMLButtonElement>('[data-reading-focus]').forEach((button) => {
          button.setAttribute('aria-pressed', String(button.dataset.readingFocus === focus));
        });
        const content = document.getElementById('focus-content')!;
        content.dataset.focus = focus;
        document.getElementById('focus-mark')!.textContent = config.mark;
        document.getElementById('focus-kicker')!.textContent = S['focus.selected'];
        document.getElementById('focus-title')!.textContent = S[`focus.${focus}.title`];
        document.getElementById('focus-summary')!.textContent = config.summary;
        document.getElementById('focus-metrics')!.innerHTML = config.metrics;
        document.getElementById('focus-evidence-copy')!.textContent = config.context;
        document.getElementById('focus-evidence-sources')!.innerHTML = config.sources
          .map((source) => `<span>${source}</span>`).join('');
        document.getElementById('focus-structure')!.textContent = config.sources.join(' · ');
        document.getElementById('focus-timing')!.textContent = `${S['daeun']} ${activeDaeun?.pillar.hanja ?? S['focus.unavailable']} · ${S['seun']} ${annual.pillar.hanja}`;
        document.getElementById('focus-limit')!.textContent = config.context;
        document.getElementById('health-disclaimer')!.hidden = focus !== 'health';
        document.getElementById('focus-details-label')!.textContent = config.targetLabel;
        (document.getElementById('focus-details') as HTMLButtonElement).dataset.target = config.target;
        const url = new URL(location.href);
        q.set('focus', focus);
        url.search = '';
        url.hash = q.toString();
        if (url.href !== location.href) location.replace(url);
        if (track) trackEvent('reading_focus_select', { reading_focus: focus, selection_area: 'result', language: document.documentElement.lang });
      };

      document.querySelectorAll<HTMLButtonElement>('[data-reading-focus]').forEach((button) => {
        button.addEventListener('click', () => paint(button.dataset.readingFocus as ReadingFocus, true));
      });
      document.getElementById('focus-details')!.addEventListener('click', () => {
        document.querySelector((document.getElementById('focus-details') as HTMLButtonElement).dataset.target || '#original-chart')
          ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      document.getElementById('focus-evidence')!.addEventListener('toggle', (event) => {
        if ((event.currentTarget as HTMLDetailsElement).open) {
          trackEvent('reading_evidence_open', { reading_focus: selectedReadingFocus, language: document.documentElement.lang });
        }
      });
      paint(selectedReadingFocus);
    }

    function renderTenGodDistribution(r: SajuResult) {
      const visibleGods = [r.hour, r.month, r.year]
        .filter((pillar): pillar is Pillar => Boolean(pillar))
        .map((pillar) => pillar.tenGod)
        .filter((god): god is NonNullable<typeof god> => Boolean(god));
      const hiddenGods = Object.values(r.hiddenStems).flat().map((stem) => stem.tenGod);
      const allGods = [...visibleGods, ...hiddenGods];
      const families = [
        ['비견', '겁재'],
        ['식신', '상관'],
        ['편재', '정재'],
        ['편관', '정관'],
        ['편인', '정인'],
      ] as const;
      const total = allGods.length || 1;
      document.getElementById('ten-god-distribution')!.innerHTML = families.map((names, index) => {
        const count = allGods.filter((god) => names.includes(god as typeof names[number])).length;
        const percent = Math.round(count / total * 100);
        const label = names.map(tenGodLabel).join(' · ');
        return `<article class="ten-god-family ten-god-family--${index + 1}" role="listitem" aria-label="${label}: ${count} / ${total}">
          <div><span>${label}</span><strong>${count}<small> / ${total}</small></strong></div>
          <span class="ten-god-family__track" aria-hidden="true"><i style="--family-width:${percent}%"></i></span>
        </article>`;
      }).join('');
    }

