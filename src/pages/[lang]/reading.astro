    function setupTimingPath() {
      document.querySelectorAll<HTMLButtonElement>('[data-timing-target]').forEach((button) => {
        button.addEventListener('click', () => {
          const target = document.getElementById(button.dataset.timingTarget || '');
          target?.scrollIntoView({ behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth', block: 'center' });
          trackEvent('timing_tier_navigate', { timing_tier: button.dataset.timingTarget?.split('-')[0], language: document.documentElement.lang });
        });
      });
    }

    function setupSectionNavigation() {
      const buttons = [...document.querySelectorAll<HTMLButtonElement>('[data-scroll-target]')];
      const targets = buttons
        .map((button) => document.getElementById(button.dataset.scrollTarget || ''))
        .filter((target): target is HTMLElement => Boolean(target));
      const activate = (id: string) => buttons.forEach((button) => {
        if (button.dataset.scrollTarget === id) button.setAttribute('aria-current', 'location');
        else button.removeAttribute('aria-current');
      });
      buttons.forEach((button) => button.addEventListener('click', () => {
        const target = document.getElementById(button.dataset.scrollTarget || '');
        target?.scrollIntoView({
          behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
          block: 'start',
        });
        if (target) activate(target.id);
        trackEvent('reading_section_navigate', {
          section_name: button.dataset.scrollTarget,
          language: document.documentElement.lang,
        });
      }));
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (visible) activate((visible.target as HTMLElement).id);
        }, { rootMargin: '-22% 0px -62% 0px', threshold: [0, 0.15, 0.45] });
        targets.forEach((target) => observer.observe(target));
      }
    }

    function renderExtras(r: SajuResult) {
      // Strength verdict + 득령/득지/득세 marks + 억부 favorable-element candidates.
      const st = strengthAnalysis(r);
      document.getElementById('strength-verdict')!.innerHTML =
        `<strong class="verdict-badge verdict--${st.verdict}">${S[`strengthV.${st.verdict}`]}</strong>
         <span class="soft">${fmt(S['supportScore'], { support: st.supportWeight, total: st.totalWeight })}</span>`;
      const marks = [
        ['deukryeong', st.deukryeong], ['deukji', st.deukji], ['deukse', st.deukse],
      ] as const;
      document.getElementById('strength-marks')!.innerHTML = marks.map(([key, got]) =>
        `<span class="strength-mark${got ? ' is-got' : ''}">${got ? '✓' : '✗'} ${S[key]}</span>`).join('');

      const fav = favorableElements(r.dayMaster.element, st.verdict);
      const chip = (el: string) =>
        `<span class="element-chip element-bg-soft--${el} element-text--${el}"><i class="element-dot element-bg--${el}"></i>${S[`el.${el}`]}</span>`;
      document.getElementById('favorable-list')!.innerHTML = fav.balanced
        ? `<p class="soft">${S['favorableBalanced']}</p>`
        : `<div class="favorable-row"><span class="favorable-label">${S['favorable']}</span><span class="favorable-chips">${fav.favorable.map(chip).join('')}</span></div>
           <div class="favorable-row"><span class="favorable-label">${S['unfavorable']}</span><span class="favorable-chips">${fav.unfavorable.map(chip).join('')}</span></div>`;

      // 조후용신 (궁통보감 참고): primary + supporting stems for day × month.
      const johu = johuYongsin(r);
      const johuChip = (s: { hanja: string; element: string }) =>
        `<span class="element-chip element-bg-soft--${s.element} element-text--${s.element}" lang="ko">${s.hanja} <small>${S[`el.${s.element}`]}</small></span>`;
      document.getElementById('johu-list')!.innerHTML =
        `<div class="favorable-row"><span class="favorable-label">${S['johuPrimary']}</span><span class="favorable-chips">${johuChip(johu.primary)}</span></div>
         <div class="favorable-row"><span class="favorable-label">${S['johuSecondary']}</span><span class="favorable-chips">${johu.secondary.length ? johu.secondary.map(johuChip).join('') : `<span class="soft">—</span>`}</span></div>`;

      // 태원 · 명궁 auxiliary pillars.
      const palaceCard = (label: string, p: MiniPillar | null, hint: string) => `
        <div class="palace-card">
          <span class="palace-label">${label}</span>
          ${p ? `<strong class="palace-hanja" lang="ko"><span class="element-text--${p.stemElement}">${p.hanja[0]}</span><span class="element-text--${p.branchElement}">${p.hanja[1]}</span></strong>
          <span class="palace-ko">${p.ko}</span>` : `<span class="soft">${S['myeonggungUnavailable']}</span>`}
          <span class="palace-hint soft">${hint}</span>
        </div>`;
      document.getElementById('palace-cards')!.innerHTML =
        palaceCard(S['taewonLabel'], taewonPillar(r), S['taewonHint']) +
        palaceCard(S['myeonggungLabel'], myeonggungPillar(r), S['myeonggungHint']);

      // 격국: 십정격 from the month branch's protruding hidden stem.
      const gg = gyeokguk(r);
      document.getElementById('gyeokguk-result')!.innerHTML = `
        <strong class="verdict-badge gyeokguk-badge">${S[`gg.${gg.name}`]}</strong>
        <div class="gyeokguk-meta">
          <span>${S['gyeokgukStem']} <strong lang="ko">${gg.stemHanja}</strong> · ${tenGodLabel(gg.god)}</span>
          <span class="soft">${gg.tugan ? S['gyeokgukTugan'] : S['gyeokgukNoTugan']}</span>
        </div>`;

      // 삼재: current ipchun-adjusted year vs the birth-year trine group.
      const nowYear = new Date().getFullYear();
      const sajuYearNow = Date.now() >= ipchunUtcMs(nowYear) ? nowYear : nowYear - 1;
      const sj = samjae(r.year.branch, sajuYearNow);
      const sjBranches = sj.groupBranches.map((b) => BRANCHES_HANJA[b]).join('·');
      const windowText = fmt(S['samjaeWindow'], {
        branches: sjBranches, start: sj.windowStartYear, end: sj.windowStartYear + 2,
      });
      document.getElementById('samjae-result')!.innerHTML = sj.stage === 0
        ? `<strong class="verdict-badge samjae-badge samjae-badge--none">${S['samjaeNone']}</strong>
           <div class="gyeokguk-meta"><span class="soft">${fmt(S['samjaeNext'], { start: sj.windowStartYear })}</span><span class="soft" lang="ko">${windowText}</span></div>`
        : `<strong class="verdict-badge samjae-badge">${S[`samjaeStage.${sj.stage}`]}</strong>
           <div class="gyeokguk-meta"><span lang="ko">${windowText}</span></div>`;
    }

