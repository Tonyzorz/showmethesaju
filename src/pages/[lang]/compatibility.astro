---
import Base from '../../layouts/Base.astro';
import { LOCALES } from '../../i18n/locales';
import { t, ns } from '../../i18n/t';
import { withBase } from '../../lib/paths';
import { CITIES } from '../../lib/cities';

export function getStaticPaths() { return LOCALES.map((l) => ({ params: { lang: l.code } })); }
const { lang } = Astro.params;

// Client strings: gunghap namespace + the shared labels it borrows from reading/form.
const R = ns(lang, 'reading');
const pick = (prefix: string) =>
  Object.fromEntries(Object.entries(R).filter(([k]) => k.startsWith(prefix)));
const strings = {
  ...ns(lang, 'gunghap'),
  ...ns(lang, 'experience'),
  ...pick('el.'), ...pick('strengthV.'), ...pick('tg.'), ...pick('qi.'),
  pillarYear: R['pillarYear'], pillarMonth: R['pillarMonth'],
  pillarDay: R['pillarDay'], pillarHour: R['pillarHour'],
  hiddenStems: R['hiddenStems'], hiddenStemsContext: R['hiddenStemsContext'],
  daeun: R['daeun'], seun: R['seun'], forward: R['forward'], reverse: R['reverse'],
  share: R['share'], sharePng: R['sharePng'], shared: R['shared'],
  errFuture: t(lang, 'form.errFuture'),
  errLunarRange: t(lang, 'form.errLunarRange'),
};

const personFields = [
  { key: 'a', label: t(lang, 'gunghap.personA') },
  { key: 'b', label: t(lang, 'gunghap.personB') },
];
---
<Base lang={lang} title={t(lang, 'meta.compat.title')} description={t(lang, 'compat.body')} path="compatibility">
  <script type="application/json" id="i18n-gunghap" set:html={JSON.stringify(strings)} />

  <section class="compat-hero">
    <span class="feature-mark" aria-hidden="true">合</span>
    <h1>{t(lang, 'compat.headline')}</h1>
    <p>{t(lang, 'compat.body')}</p>
    <p class="trust-line">{t(lang, 'gunghap.formNote')}</p>
  </section>

  <section id="comparison-history" class="card comparison-history" hidden>
    <header><div><small>{t(lang, 'experience.profileLocal')}</small><h2>{t(lang, 'experience.historyTitle')}</h2></div><button id="clear-comparison-history" type="button">{t(lang, 'experience.historyClear')}</button></header>
    <div id="comparison-history-list" data-empty={t(lang, 'experience.historyEmpty')}></div>
  </section>

  <form id="gunghap-form" class="card gform" data-lang={lang}>
    <h2 class="gform-title">{t(lang, 'gunghap.formTitle')}</h2>
    <div class="gform-grid">
      {personFields.map((person) => (
        <section class="person" data-person={person.key}>
          <header class="person-head">
            <span class="person-badge">{person.key === 'a' ? '甲' : '乙'}</span>
            <h3>{person.label}</h3>
          </header>
          <label class="saved-person-profile">
            <span>{t(lang, 'experience.profileTitle')}</span>
            <select class="field" data-profile-for={person.key}><option value="">— {t(lang, 'experience.profileEmpty')} —</option></select>
          </label>

          <div class="input-step" data-input-step={`${person.key}-date`}>
            <div class="input-step__heading">
              <span class="input-step__number">01</span>
              <label for={`${person.key}-date`}>{t(lang, 'form.date')}</label>
              <span class="input-step__check" aria-hidden="true">✓</span>
            </div>
            <div class="field-shell">
              <span class="field-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7 3v3m10-3v3M4 9h16M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" /></svg>
              </span>
              <input id={`${person.key}-date`} class="field" type="date" name={`${person.key}-date`} required min="1900-01-01" />
            </div>
            <fieldset class="choice-field">
              <legend>{t(lang, 'form.calendar')}</legend>
              <div class="choice-grid">
                <label class="choice-tile"><input type="radio" name={`${person.key}-cal`} value="solar" checked /><span>{t(lang, 'form.solar')}</span></label>
                <label class="choice-tile"><input type="radio" name={`${person.key}-cal`} value="lunar" /><span>{t(lang, 'form.lunar')}</span></label>
              </div>
              <label class="choice-tile choice-tile--wide lunar-only" hidden><input type="checkbox" name={`${person.key}-leap`} /><span>{t(lang, 'form.lunarLeap')}</span></label>
            </fieldset>
          </div>

          <div class="input-step" data-input-step={`${person.key}-time`}>
            <div class="input-step__heading">
              <span class="input-step__number">02</span>
              <label for={`${person.key}-time`}>{t(lang, 'form.time')}</label>
              <span class="input-step__check" aria-hidden="true">✓</span>
            </div>
            <div class="field-shell">
              <span class="field-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
              </span>
              <input id={`${person.key}-time`} class="field" type="time" name={`${person.key}-time`} value="12:00" />
            </div>
            <label class="switch-row">
              <span>{t(lang, 'form.timeUnknown')}</span>
              <span class="switch-control"><input type="checkbox" name={`${person.key}-tu`} /><i aria-hidden="true"></i></span>
            </label>
          </div>

          <div class="input-step" data-input-step={`${person.key}-gender`}>
            <div class="input-step__heading">
              <span class="input-step__number">03</span>
              <span class="input-step__label">{t(lang, 'form.gender')}</span>
              <span class="input-step__check" aria-hidden="true">✓</span>
            </div>
            <fieldset class="choice-field">
              <legend class="visually-hidden">{t(lang, 'form.gender')}</legend>
              <div class="choice-grid">
                <label class="choice-tile choice-tile--gender"><input type="radio" name={`${person.key}-gender`} value="f" required /><span><b aria-hidden="true">♀</b>{t(lang, 'form.genderF')}</span></label>
                <label class="choice-tile choice-tile--gender"><input type="radio" name={`${person.key}-gender`} value="m" /><span><b aria-hidden="true">♂</b>{t(lang, 'form.genderM')}</span></label>
              </div>
            </fieldset>
          </div>

          <div class="input-step" data-input-step={`${person.key}-place`}>
            <div class="input-step__heading">
              <span class="input-step__number">04</span>
              <label for={`${person.key}-city`}>{t(lang, 'form.place')}</label>
              <span class="input-step__check" aria-hidden="true">✓</span>
            </div>
            <div class="field-shell">
              <span class="field-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z" /><circle cx="12" cy="10" r="2.5" /></svg>
              </span>
              <select id={`${person.key}-city`} class="field" name={`${person.key}-city`}>
                <option value="">— {t(lang, 'form.place')} (auto) —</option>
                {CITIES.map((c) => <option value={c.tz} data-lon={c.lon}>{c.name}</option>)}
              </select>
            </div>
          </div>
        </section>
      ))}
    </div>
    <p class="form-error" role="alert" hidden></p>
    <button class="btn-primary" type="submit"><span>{t(lang, 'gunghap.cta')}</span><span class="button-arrow" aria-hidden="true">→</span></button>
  </form>

  <section id="gunghap-result" hidden>
    <header class="card gunghap-result-hero">
      <div class="result-head">
        <div>
          <p class="result-overline">{t(lang, 'gunghap.formTitle')}</p>
          <h2>{t(lang, 'gunghap.resultTitle')}</h2>
          <p class="result-note">{t(lang, 'gunghap.resultNote')}</p>
        </div>
        <a class="btn-secondary" href={withBase(`/${lang}/compatibility/`)}>{t(lang, 'gunghap.reset')}</a>
      </div>
      <div id="pair-signature" class="pair-signature"></div>
      <div class="result-actions">
        <button id="share-compatibility" class="btn-secondary" type="button">{t(lang, 'reading.share')}</button>
        <button id="share-compatibility-png" class="btn-secondary" type="button">{t(lang, 'reading.sharePng')}</button>
      </div>
    </header>
    <section id="compat-summary" class="compat-summary" aria-labelledby="compat-summary-title">
      <div class="compat-summary__heading"><div><p>{t(lang, 'gunghap.formTitle')}</p><h2 id="compat-summary-title">{t(lang, 'experience.summaryTitle')}</h2></div><span>{t(lang, 'gunghap.resultNote')}</span></div>
      <div id="compat-summary-grid" class="compat-summary-grid"></div>
    </section>
    <nav class="gunghap-jumpbar" aria-label={t(lang, 'gunghap.resultTitle')}>
      <span aria-hidden="true">≡</span>
      <div>
        <button type="button" data-gunghap-target="compat-summary">{t(lang, 'experience.summaryTitle')}</button>
        <button type="button" data-gunghap-target="pair-charts">{t(lang, 'gunghap.formTitle')}</button>
        <button type="button" data-gunghap-target="gsection-inner">{t(lang, 'gunghap.inner')}</button>
        <button type="button" data-gunghap-target="gsection-cross">{t(lang, 'gunghap.crossPillars')}</button>
        <button type="button" data-gunghap-target="gsection-spouse">{t(lang, 'gunghap.spousePalaceDetail')}</button>
        <button type="button" data-gunghap-target="gsection-tengods">{t(lang, 'gunghap.tengods')}</button>
        <button type="button" data-gunghap-target="gsection-elements">{t(lang, 'gunghap.elements')}</button>
        <button type="button" data-gunghap-target="gsection-timing">{t(lang, 'gunghap.timingComparison')}</button>
      </div>
    </nav>
    <section id="pair-charts" class="pair-charts-section" aria-label={t(lang, 'gunghap.formTitle')}>
      <div id="person-charts" class="person-charts"></div>
    </section>
    <div id="gunghap-sections" class="gunghap-sections"></div>
    <section class="card book-band">
      <div>
        <h2>{t(lang, 'gunghap.bookTitle')}</h2>
        <p>{t(lang, 'gunghap.bookBody')}</p>
      </div>
      <a class="btn-primary" href="https://pf.kakao.com/" rel="noopener" target="_blank" data-analytics-event="booking_click" data-analytics-destination="kakao_booking" data-analytics-area="gunghap">{t(lang, 'footer.booking')} <span aria-hidden="true">↗</span></a>
    </section>
  </section>

  <section class="card culture">
    <h2>{t(lang, 'gunghap.culture.title')}</h2>
    <p>{t(lang, 'gunghap.culture.body')}</p>
  </section>

  <script>
    import KoreanLunarCalendar from 'korean-lunar-calendar';
    import { tzOffsetMinutes } from '../../lib/cities';
    import { branchPair, computeGunghap, type GunghapResult, type PairRelation } from '../../lib/gunghap';
    import { computeAnnualLuck, ipchunUtcMs, type PillarRole, type SajuInput, type SajuResult } from '../../lib/saju-engine';
    import { trackEvent } from '../../lib/analytics';
    import {
      clearComparisonHistory, loadComparisonHistory, loadProfiles, rememberComparison,
      type BirthProfileData,
    } from '../../lib/local-data';

    const S: Record<string, string> = JSON.parse(document.getElementById('i18n-gunghap')!.textContent!);
    const fmt = (template: string, vars: Record<string, string | number>) =>
      Object.entries(vars).reduce((text, [k, v]) => text.replaceAll(`{${k}}`, String(v)), template);
    const form = document.getElementById('gunghap-form') as HTMLFormElement;
    const errEl = form.querySelector('.form-error') as HTMLElement;
    const steps = Array.from(form.querySelectorAll<HTMLElement>('[data-input-step]'));
    const historyPanel = document.getElementById('comparison-history')!;
    const historyList = document.getElementById('comparison-history-list')!;

    // Same interaction model as the main birth form: dynamic max date,
    // step completion marks, error highlighting on the offending step.
    const today = new Date();
    const maxDate = [today.getFullYear(), String(today.getMonth() + 1).padStart(2, '0'), String(today.getDate()).padStart(2, '0')].join('-');
    form.querySelectorAll<HTMLInputElement>('input[type="date"]').forEach((input) => { input.max = maxDate; });

    const stepByName = (name: string) => form.querySelector<HTMLElement>(`[data-input-step="${name}"]`);
    function clearError() {
      errEl.hidden = true;
      steps.forEach((step) => step.classList.remove('has-error'));
      form.querySelectorAll('[aria-invalid="true"]').forEach((field) => field.removeAttribute('aria-invalid'));
    }
    function showError(message: string, stepName: string, focusEl?: HTMLElement | null) {
      errEl.textContent = message;
      errEl.hidden = false;
      stepByName(stepName)?.classList.add('has-error');
      focusEl?.setAttribute('aria-invalid', 'true');
      focusEl?.focus();
    }

    function updateSteps() {
      for (const key of ['a', 'b']) {
        const date = (form.elements.namedItem(`${key}-date`) as HTMLInputElement).value;
        const tu = (form.elements.namedItem(`${key}-tu`) as HTMLInputElement).checked;
        const time = (form.elements.namedItem(`${key}-time`) as HTMLInputElement);
        const gender = form.querySelector<HTMLInputElement>(`input[name="${key}-gender"]:checked`);
        time.disabled = tu;
        time.closest('.field-shell')?.classList.toggle('is-disabled', tu);
        stepByName(`${key}-date`)?.classList.toggle('is-complete', Boolean(date));
        stepByName(`${key}-time`)?.classList.toggle('is-complete', tu || Boolean(time.value));
        stepByName(`${key}-gender`)?.classList.toggle('is-complete', Boolean(gender));
        stepByName(`${key}-place`)?.classList.toggle('is-complete', Boolean(stepByName(`${key}-place`)?.classList.contains('is-touched')));
      }
    }
    steps.forEach((step) => {
      step.addEventListener('focusin', () => step.classList.add('is-active'));
      step.addEventListener('focusout', () => requestAnimationFrame(() => {
        if (!step.contains(document.activeElement)) step.classList.remove('is-active');
      }));
      ['input', 'change'].forEach((eventName) => step.addEventListener(eventName, () => {
        step.classList.add('is-touched');
        clearError();
        updateSteps();
      }));
    });
    (['a', 'b'] as const).forEach((key, personIndex) => {
      form.querySelectorAll(`input[name="${key}-cal"]`).forEach((radio) =>
        radio.addEventListener('change', () => {
          const only = form.querySelectorAll('.lunar-only')[personIndex] as HTMLElement;
          only.hidden = (form.elements.namedItem(`${key}-cal`) as RadioNodeList).value !== 'lunar';
        })
      );
    });
    updateSteps();

    let gunghapFormStarted = false;
    form.addEventListener('input', () => {
      if (gunghapFormStarted) return;
      gunghapFormStarted = true;
      trackEvent('gunghap_form_start', { language: document.documentElement.lang });
    }, { once: true });

    function applySavedProfile(key: 'a' | 'b', data: BirthProfileData) {
      (form.elements.namedItem(`${key}-date`) as HTMLInputElement).value = data.date;
      (form.elements.namedItem(`${key}-time`) as HTMLInputElement).value = data.time;
      (form.elements.namedItem(`${key}-tu`) as HTMLInputElement).checked = data.timeUnknown;
      form.querySelector<HTMLInputElement>(`input[name="${key}-cal"][value="${data.calendar}"]`)!.checked = true;
      (form.elements.namedItem(`${key}-leap`) as HTMLInputElement).checked = data.leap;
      form.querySelector<HTMLInputElement>(`input[name="${key}-gender"][value="${data.gender}"]`)!.checked = true;
      (form.elements.namedItem(`${key}-city`) as HTMLSelectElement).value = data.city;
      const personIndex = key === 'a' ? 0 : 1;
      (form.querySelectorAll('.lunar-only')[personIndex] as HTMLElement).hidden = data.calendar !== 'lunar';
      form.querySelectorAll<HTMLElement>(`[data-input-step^="${key}-"]`).forEach((step) => step.classList.add('is-touched'));
      updateSteps(); clearError();
    }

    const profiles = loadProfiles();
    form.querySelectorAll<HTMLSelectElement>('[data-profile-for]').forEach((select) => {
      for (const profile of profiles) {
        const option = document.createElement('option'); option.value = profile.id; option.textContent = profile.name;
        select.append(option);
      }
      select.addEventListener('change', () => {
        const profile = profiles.find((item) => item.id === select.value);
        const key = select.dataset.profileFor as 'a' | 'b';
        if (profile && (key === 'a' || key === 'b')) {
          applySavedProfile(key, profile.data);
          trackEvent('profile_load', { storage_type: 'local', selection_area: 'gunghap', language: document.documentElement.lang });
        }
      });
    });

    function renderComparisonHistory() {
      const items = loadComparisonHistory();
      historyPanel.hidden = !items.length;
      historyList.replaceChildren();
      if (!items.length) return;
      const formatter = new Intl.DateTimeFormat(document.documentElement.lang, { dateStyle: 'medium' });
      for (const item of items) {
        const link = document.createElement('a');
        link.href = `#${item.fragment}`;
        const signature = document.createElement('strong'); signature.textContent = item.signature;
        const date = document.createElement('small'); date.textContent = formatter.format(new Date(item.createdAt));
        link.append(signature, date); historyList.append(link);
        link.addEventListener('click', () =>
          trackEvent('comparison_history_open', { storage_type: 'local', language: document.documentElement.lang }));
      }
    }
    document.getElementById('clear-comparison-history')!.addEventListener('click', () => {
      clearComparisonHistory(); renderComparisonHistory();
      trackEvent('comparison_history_clear', { storage_type: 'local', language: document.documentElement.lang });
    });
    renderComparisonHistory();

    type PersonParams = Record<string, string>;
    function readPerson(f: FormData, key: string): PersonParams | { error: string; step: string } {
      let [y, m, d] = String(f.get(`${key}-date`) || '').split('-').map(Number);
      if (!y) return { error: S['errBothRequired'], step: `${key}-date` };
      const tu = f.get(`${key}-tu`) === 'on';
      const [h, mi] = tu ? [12, 0] : String(f.get(`${key}-time`) || '12:00').split(':').map(Number);
      if (new Date(y, m - 1, d) > new Date()) return { error: S['errFuture'], step: `${key}-date` };
      if (f.get(`${key}-cal`) === 'lunar') {
        if (y < 1900 || y > 2050) return { error: S['errLunarRange'], step: `${key}-date` };
        try {
          const cal = new KoreanLunarCalendar();
          if (!cal.setLunarDate(y, m, d, f.get(`${key}-leap`) === 'on')) throw new Error('invalid');
          const s = cal.getSolarCalendar();
          y = s.year; m = s.month; d = s.day;
        } catch { return { error: S['errLunarRange'], step: `${key}-date` }; }
      }
      const citySel = form.elements.namedItem(`${key}-city`) as HTMLSelectElement;
      const tz = citySel.value || Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      const tzMin = tzOffsetMinutes(tz, y, m, d, h, mi);
      return {
        [`${key}y`]: String(y), [`${key}m`]: String(m), [`${key}d`]: String(d),
        [`${key}h`]: String(h), [`${key}i`]: String(mi), [`${key}u`]: tu ? '1' : '0',
        [`${key}z`]: String(tzMin),
        [`${key}g`]: String(f.get(`${key}-gender`) || ''),
      };
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearError();
      const f = new FormData(form);
      const a = readPerson(f, 'a');
      const b = readPerson(f, 'b');
      const bad = ('error' in a && a) || ('error' in b && b);
      if (bad) {
        showError(bad.error, bad.step, stepByName(bad.step)?.querySelector<HTMLElement>('input') ?? null);
        trackEvent('gunghap_form_error', { language: document.documentElement.lang });
        return;
      }
      const q = new URLSearchParams({ ...(a as PersonParams), ...(b as PersonParams) });
      trackEvent('gunghap_submit', { language: document.documentElement.lang });
      location.replace(`${location.pathname}#${q}`);
      renderFromParams(q, true);
    });

    function miniChart(r: SajuResult, label: string, person: 'a' | 'b'): string {
      const symbol = r.gender === 'female' ? '♀' : r.gender === 'male' ? '♂' : '';
      const roles = [
        [r.hour, S['pillarHour'], 'hour'], [r.day, S['pillarDay'], 'day'],
        [r.month, S['pillarMonth'], 'month'], [r.year, S['pillarYear'], 'year'],
      ] as const;
      return `<article class="card mini-chart mini-chart--${person}">
        <header class="mini-chart__head">
          <span class="mini-chart__person">${person === 'a' ? '甲' : '乙'}</span>
          <div><small>${label} ${symbol}</small><h3 lang="ko">${r.dayMaster.hanja} <span>${r.dayMaster.ko}</span></h3></div>
          <span class="mini-chart__element element-bg-soft--${r.dayMaster.element} element-text--${r.dayMaster.element}">${S[`el.${r.dayMaster.element}`]}</span>
        </header>
        <div class="mini-pillars">${roles.map(([p, roleLabel, role]) => p
          ? `<div class="mini-pillar ${role === 'day' ? 'mini-pillar--day' : ''}">
              <small>${roleLabel}</small>
              <strong lang="ko"><span class="element-text--${p.stemElement}">${p.stemHanja}</span><span class="element-text--${p.branchElement}">${p.branchHanja}</span></strong>
              <span>${p.stemKo}${p.branchKo}</span>
            </div>`
          : `<div class="mini-pillar"><small>${roleLabel}</small><strong>—</strong><span></span></div>`).join('')}
        </div>
      </article>`;
    }

    const relBadge = (rel: PairRelation) => {
      const tense = ['punishment', 'clash', 'break', 'harm', 'grudge', 'ghostGate'].includes(rel);
      return `<span class="rel-badge ${tense ? 'rel-badge--tense' : 'rel-badge--smooth'}">${S[`rel.${rel}`] ?? rel}</span>`;
    };
    const relBlock = (rels: PairRelation[]) =>
      rels.length ? `<div class="rel-badges">${rels.map(relBadge).join('')}</div>` : `<p class="soft">${S['relNone']}</p>`;
    const section = (key: string, index: string, mark: string, title: string, body: string, note: string, wide = false) =>
      `<section id="gsection-${key}" class="card gsection gsection--${key}${wide ? ' gsection--wide' : ''}">
        <header class="gsection__head">
          <span class="gsection__mark" aria-hidden="true">${mark}</span>
          <div><small>${index}</small><h3>${title}</h3></div>
        </header>
        <div class="gsection__body">${body}</div>
        <footer class="gsection__note"><span aria-hidden="true">i</span><p>${note}</p></footer>
      </section>`;
    const elLabel = (el: string) => S[`el.${el}`] ?? el;
    const tgLabel = (god: string) => S[`tg.${god}`] ?? god;
    const roleLabels: Record<PillarRole, string> = {
      year: S['pillarYear'], month: S['pillarMonth'], day: S['pillarDay'], hour: S['pillarHour'],
    };

    function crossPillarComparison(g: GunghapResult) {
      const roles: PillarRole[] = ['year', 'month', 'day', 'hour'];
      const columns = roles.map((role) => `<div class="compat-matrix__axis"><small>${S['personB']}</small><strong>${roleLabels[role]}</strong></div>`).join('');
      const rows = roles.map((aRole) => {
        const aPillar = g.a[aRole];
        const cells = roles.map((bRole) => {
          const bPillar = g.b[bRole];
          if (!aPillar || !bPillar) return `<span class="compat-matrix__empty" aria-hidden="true">—</span>`;
          const relations = branchPair(aPillar.branch, bPillar.branch);
          const state = relations.some((rel) => ['punishment', 'clash', 'break', 'harm', 'grudge', 'ghostGate'].includes(rel))
            ? 'tense' : relations.length ? 'smooth' : 'neutral';
          return `<button type="button" class="compat-matrix__cell compat-matrix__cell--${state}" data-matrix-a="${aRole}" data-matrix-b="${bRole}" aria-label="${S['personA']} ${roleLabels[aRole]} ${aPillar.branchHanja}, ${S['personB']} ${roleLabels[bRole]} ${bPillar.branchHanja}">
            <span lang="ko">${aPillar.branchHanja}<i>↔</i>${bPillar.branchHanja}</span><small>${relations.length || '—'}</small>
          </button>`;
        }).join('');
        return `<div class="compat-matrix__axis compat-matrix__axis--row"><small>${S['personA']}</small><strong>${roleLabels[aRole]}</strong></div>${cells}`;
      }).join('');
      return `<p class="matrix-instruction">${S['matrixInstruction']}</p><div class="compat-matrix" role="group" aria-label="${S['crossPillars']}"><span></span>${columns}${rows}</div><div id="matrix-detail" class="matrix-detail" aria-live="polite"></div>`;
    }

    function spousePalaceHiddenStems(g: GunghapResult) {
      const card = (r: SajuResult, label: string, person: 'a' | 'b') =>
        `<article class="spouse-palace spouse-palace--${person}">
          <header>
            <span>${label}</span>
            <strong lang="ko">${r.day.branchHanja}</strong>
            <small>${S['pillarDay']}</small>
          </header>
          <div>${r.hiddenStems.day.map((stem) => `<details class="spouse-hidden-chip">
            <summary><small>${S[`qi.${stem.phase}`]}</small><strong class="element-text--${stem.element}" lang="ko">${stem.stemHanja}</strong><span>${tgLabel(stem.tenGod)}</span></summary>
            <p>${fmt(S['hiddenStemLine'], { phase: S[`qi.${stem.phase}`], branch: r.day.branchHanja, god: tgLabel(stem.tenGod), element: elLabel(stem.element) })}</p>
          </details>`).join('')}</div>
        </article>`;
      return `<div class="spouse-palace-grid">${card(g.a, S['personA'], 'a')}${card(g.b, S['personB'], 'b')}</div>`;
    }

    function setupCompatibilityMatrix(g: GunghapResult) {
      const detail = document.getElementById('matrix-detail')!;
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-matrix-a][data-matrix-b]'));
      const select = (button: HTMLButtonElement, track = false) => {
        const aRole = button.dataset.matrixA as PillarRole;
        const bRole = button.dataset.matrixB as PillarRole;
        const aPillar = g.a[aRole]!;
        const bPillar = g.b[bRole]!;
        buttons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
        detail.innerHTML = `<div><small>${S['personA']} · ${roleLabels[aRole]}</small><strong lang="ko">${aPillar.branchHanja}</strong></div><span aria-hidden="true">↔</span><div><small>${S['personB']} · ${roleLabels[bRole]}</small><strong lang="ko">${bPillar.branchHanja}</strong></div><aside>${relBlock(branchPair(aPillar.branch, bPillar.branch))}</aside>`;
        if (track) trackEvent('gunghap_matrix_select', { relation_state: branchPair(aPillar.branch, bPillar.branch).length ? 'present' : 'neutral', language: document.documentElement.lang });
      };
      buttons.forEach((button) => button.addEventListener('click', () => select(button, true)));
      if (buttons[0]) select(buttons[0]);
    }

    function elementComparison(g: GunghapResult) {
      const elements = ['wood', 'fire', 'earth', 'metal', 'water'] as const;
      const totalA = Object.values(g.a.elementCounts).reduce((sum, count) => sum + count, 0) || 1;
      const totalB = Object.values(g.b.elementCounts).reduce((sum, count) => sum + count, 0) || 1;
      return `<div class="element-compare">
        <div class="element-compare__legend"><span><i></i>${S['personA']}</span><span><i></i>${S['personB']}</span></div>
        ${elements.map((element) => {
          const countA = g.a.elementCounts[element];
          const countB = g.b.elementCounts[element];
          return `<div class="element-compare__row" role="img" aria-label="${elLabel(element)} · ${S['personA']} ${countA} · ${S['personB']} ${countB}">
            <strong><i class="element-bg--${element}"></i>${elLabel(element)}</strong>
            <div class="element-compare__tracks">
              <span><i style="--compare-width:${Math.round(countA / totalA * 100)}%"></i></span>
              <span><i style="--compare-width:${Math.round(countB / totalB * 100)}%"></i></span>
            </div>
            <small>${countA} · ${countB}</small>
          </div>`;
        }).join('')}
      </div>`;
    }

    function compatibilityTiming(r: SajuResult) {
      const now = new Date();
      let sajuYear = now.getUTCFullYear();
      if (Date.now() < ipchunUtcMs(sajuYear)) sajuYear -= 1;
      const activeDaeun = r.daeun?.cycles.find((cycle, index, cycles) =>
        sajuYear >= cycle.startYear && (index === cycles.length - 1 || sajuYear < cycles[index + 1].startYear)) ?? null;
      return { sajuYear, activeDaeun, annual: computeAnnualLuck(r, sajuYear, 1)[0] };
    }

    function timingComparison(g: GunghapResult) {
      const a = compatibilityTiming(g.a);
      const b = compatibilityTiming(g.b);
      const card = (label: string, r: SajuResult, timing: ReturnType<typeof compatibilityTiming>, person: 'a' | 'b') =>
        `<article class="compat-timing-card compat-timing-card--${person}">
          <header><span>${label}</span><small>${timing.sajuYear}</small></header>
          <div><small>${S['daeun']}</small><strong lang="ko">${timing.activeDaeun?.pillar.hanja ?? '—'}</strong><span>${r.daeun ? S[r.daeun.direction] : '—'}</span></div>
          <div><small>${S['seun']}</small><strong lang="ko">${timing.annual.pillar.hanja}</strong><span>${tgLabel(timing.annual.pillar.tenGod ?? '')}</span></div>
        </article>`;
      return `<div class="compat-timing-grid">${card(S['personA'], g.a, a, 'a')}<div class="compat-timing-link"><span>歲</span>${relBlock(branchPair(a.annual.pillar.branch, b.annual.pillar.branch))}</div>${card(S['personB'], g.b, b, 'b')}</div>`;
    }

    function renderCompatibilitySummary(g: GunghapResult, stemLine: string) {
      const tenseRelations = g.crossPillarRelations.flatMap((item) => item.relations)
        .filter((relation) => ['punishment', 'clash', 'break', 'harm', 'grudge', 'ghostGate'].includes(relation));
      const aTiming = compatibilityTiming(g.a);
      const bTiming = compatibilityTiming(g.b);
      const inner = g.dayRelations.length ? g.dayRelations.map((rel) => S[`rel.${rel}`] ?? rel).join(' · ') : S['relNone'];
      const fills = [...g.bFillsForA, ...g.aFillsForB];
      const cards = [
        ['言', S['summaryCommunication'], stemLine, 'gsection-stems'],
        ['心', S['summaryEmotional'], inner, 'gsection-inner'],
        ['交', S['summaryFriction'], `${tenseRelations.length} · ${S['crossPillars']}`, 'gsection-cross'],
        ['補', S['summarySupport'], fills.length ? fills.map(elLabel).join(' · ') : S['fillsNone'], 'gsection-elements'],
        ['運', S['summaryTiming'], `${aTiming.activeDaeun?.pillar.hanja ?? '—'} ↔ ${bTiming.activeDaeun?.pillar.hanja ?? '—'} · ${aTiming.sajuYear}`, 'gsection-timing'],
      ];
      document.getElementById('compat-summary-grid')!.innerHTML = cards.map(([mark, title, body, target]) =>
        `<a class="compat-summary-card" href="#${target}"><span aria-hidden="true">${mark}</span><div><small>${S['viewEvidence']}</small><h3>${title}</h3><p>${body}</p></div><i aria-hidden="true">↘</i></a>`
      ).join('');
    }

    function setupCompatibilitySharing(g: GunghapResult) {
      const share = document.getElementById('share-compatibility') as HTMLButtonElement;
      const save = document.getElementById('share-compatibility-png') as HTMLButtonElement;
      share.onclick = async () => {
        try { await navigator.clipboard.writeText(location.href); share.textContent = S['shared']; }
        catch { /* Clipboard permission can be denied; the URL remains visible. */ }
        trackEvent('share', { method: 'link', content_type: 'gunghap', language: document.documentElement.lang });
      };
      save.onclick = () => {
        const canvas = document.createElement('canvas'); canvas.width = 1200; canvas.height = 630;
        const ctx = canvas.getContext('2d')!;
        const gradient = ctx.createLinearGradient(0, 0, 1200, 630); gradient.addColorStop(0, '#173b31'); gradient.addColorStop(1, '#3d735e');
        ctx.fillStyle = gradient; ctx.fillRect(0, 0, 1200, 630);
        ctx.fillStyle = 'rgba(255,255,255,.08)'; ctx.beginPath(); ctx.arc(1050, 90, 260, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#efad7a'; ctx.font = '700 24px sans-serif'; ctx.fillText(S['resultTitle'], 90, 90);
        ctx.fillStyle = '#fff'; ctx.font = '700 90px serif'; ctx.textAlign = 'center';
        ctx.fillText(g.a.dayMaster.hanja, 350, 310); ctx.fillText('合', 600, 310); ctx.fillText(g.b.dayMaster.hanja, 850, 310);
        ctx.font = '600 28px sans-serif'; ctx.fillStyle = 'rgba(255,255,255,.78)';
        ctx.fillText(`${elLabel(g.a.dayMaster.element)}  ↔  ${elLabel(g.b.dayMaster.element)}`, 600, 390);
        ctx.font = '500 22px sans-serif'; ctx.fillText(S['resultNote'].slice(0, 88), 600, 475);
        ctx.textAlign = 'start'; ctx.font = '700 20px sans-serif'; ctx.fillStyle = '#fff'; ctx.fillText('SHOW ME THE SAJU', 90, 560);
        const link = document.createElement('a'); link.download = 'our-gunghap.png'; link.href = canvas.toDataURL('image/png'); link.click();
        trackEvent('share', { method: 'image', content_type: 'gunghap', language: document.documentElement.lang });
      };
    }

    function render(g: GunghapResult) {
      const stemLine = g.stems.type === 'combination'
        ? fmt(S['stem.combination'], { el: elLabel(g.stems.transformElement!) })
        : S[`stem.${g.stems.type}`];

      document.getElementById('pair-signature')!.innerHTML = `
        <div class="signature-person signature-person--a">
          <small>${S['personA']}</small>
          <strong class="element-text--${g.a.dayMaster.element}" lang="ko">${g.a.dayMaster.hanja}</strong>
          <span>${elLabel(g.a.dayMaster.element)}</span>
        </div>
        <div class="signature-bridge">
          <div aria-hidden="true"><i></i><b>合</b><i></i></div>
          <p>${stemLine}</p>
        </div>
        <div class="signature-person signature-person--b">
          <small>${S['personB']}</small>
          <strong class="element-text--${g.b.dayMaster.element}" lang="ko">${g.b.dayMaster.hanja}</strong>
          <span>${elLabel(g.b.dayMaster.element)}</span>
        </div>`;

      document.getElementById('person-charts')!.innerHTML =
        miniChart(g.a, S['personA'], 'a') + miniChart(g.b, S['personB'], 'b');

      const fills = [
        g.bFillsForA.length ? fmt(S['fillsForA'], { els: g.bFillsForA.map(elLabel).join(', ') }) : '',
        g.aFillsForB.length ? fmt(S['fillsForB'], { els: g.aFillsForB.map(elLabel).join(', ') }) : '',
      ].filter(Boolean);

      document.getElementById('gunghap-sections')!.innerHTML = [
        section('outer', '01', '年', S['outer'], relBlock(g.yearRelations), S['outerNote']),
        section('inner', '02', '日', S['inner'], relBlock(g.dayRelations), S['innerNote']),
        section('cross', '03', '交', S['crossPillars'], crossPillarComparison(g), S['crossPillarsNote'], true),
        section('spouse', '04', '藏', S['spousePalaceDetail'], spousePalaceHiddenStems(g), S['spousePalaceNote'], true),
        section('stems', '05', '干', S['stems'], `<p class="glead glead--feature">${stemLine}</p>`, S['stemsNote']),
        section('tengods', '06', '神', S['tengods'],
          `<div class="pair-insight-list"><p>${fmt(S['tenGodOfB'], { god: tgLabel(g.tenGodOfBForA) })}</p>
           <p>${fmt(S['tenGodOfA'], { god: tgLabel(g.tenGodOfAForB) })}</p></div>`,
          S['tengodsNote']),
        section('elements', '07', '行', S['elements'],
          `<div class="fill-summary">${fills.length ? fills.map((line) => `<p>${line}</p>`).join('') : `<p>${S['fillsNone']}</p>`}</div>${elementComparison(g)}`,
          S['elementsNote'], true),
        section('strength', '08', '氣', S['strength'],
          `<div class="strength-compare">
            <article><small>${S['myStrength']}</small><strong>${S[`strengthV.${g.strengthA}`]}</strong></article>
            <span aria-hidden="true">↔</span>
            <article><small>${S['theirStrength']}</small><strong>${S[`strengthV.${g.strengthB}`]}</strong></article>
          </div>`,
          S['strengthNote'], true),
        section('timing', '09', '運', S['timingComparison'], timingComparison(g), S['timingNote'], true),
      ].join('');
      renderCompatibilitySummary(g, stemLine);
      setupCompatibilityMatrix(g);
      setupCompatibilitySharing(g);
    }

    // Result rendering must run after every helper above is initialized.
    // State lives in the URL fragment, so it is not sent to the host.
    function renderFromParams(q: URLSearchParams, scrollToResult = false) {
      const required = ['y', 'm', 'd', 'h', 'i', 'u', 'z', 'g'];
      if (![...required.map((key) => `a${key}`), ...required.map((key) => `b${key}`)].every((key) => q.has(key))) return;
      if (!['f', 'm'].includes(q.get('ag') ?? '') || !['f', 'm'].includes(q.get('bg') ?? '')) return;
      const input = (key: string): SajuInput => ({
        year: +q.get(`${key}y`)!, month: +q.get(`${key}m`)!, day: +q.get(`${key}d`)!,
        hour: +q.get(`${key}h`)!, minute: +q.get(`${key}i`)!,
        timeUnknown: q.get(`${key}u`) === '1',
        tzOffsetMinutes: +q.get(`${key}z`)!,
        gender: q.get(`${key}g`) === 'f' ? 'female' : q.get(`${key}g`) === 'm' ? 'male' : undefined,
      });
      try {
        const g: GunghapResult = computeGunghap(input('a'), input('b'));
        render(g);
        rememberComparison(q.toString(), `${g.a.dayMaster.hanja} · ${g.b.dayMaster.hanja}`);
        renderComparisonHistory();
        form.hidden = true;
        const result = document.getElementById('gunghap-result')!;
        result.hidden = false;
        document.querySelector<HTMLButtonElement>('[data-gunghap-target="compat-summary"]')?.setAttribute('aria-current', 'location');
        if (scrollToResult) requestAnimationFrame(() => result.scrollIntoView({
          behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
          block: 'start',
        }));
        trackEvent('gunghap_view', { language: document.documentElement.lang });
      } catch (err) {
        // Malformed fragment or legacy query state: fall back to the empty form.
        console.error('[gunghap] failed to render result:', err);
      }
    }
    const rawState = location.hash.length > 1 ? location.hash.slice(1) : location.search;
    const q = new URLSearchParams(rawState);
    if (!location.hash && location.search && q.size) {
      const migrated = new URL(location.href);
      migrated.search = '';
      migrated.hash = q.toString();
      location.replace(migrated);
    }
    document.querySelectorAll<HTMLButtonElement>('[data-gunghap-target]').forEach((button) => {
      button.addEventListener('click', () => {
        const target = document.getElementById(button.dataset.gunghapTarget || '');
        target?.scrollIntoView({
          behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
          block: 'start',
        });
        document.querySelectorAll<HTMLButtonElement>('[data-gunghap-target]').forEach((item) => {
          if (item === button) item.setAttribute('aria-current', 'location');
          else item.removeAttribute('aria-current');
        });
        trackEvent('gunghap_section_navigate', {
          section_name: button.dataset.gunghapTarget,
          language: document.documentElement.lang,
        });
      });
    });
    window.addEventListener('hashchange', () => {
      const next = new URLSearchParams(location.hash.slice(1));
      renderFromParams(next, true);
    });
    renderFromParams(q);
  </script>

