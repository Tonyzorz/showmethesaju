    .choice-tile { position: relative; cursor: pointer; }
    .choice-tile input { position: absolute; inline-size: 1px; block-size: 1px; opacity: 0; pointer-events: none; }
    .choice-tile > span { display: flex; min-height: 2.45rem; align-items: center; justify-content: center; border: 1px solid var(--line); border-radius: .75rem; padding: .5rem .75rem; color: var(--ink-soft); background: rgb(255 255 255 / .62); font-size: var(--text-xs); font-weight: 750; transition: color var(--dur-fast), border-color var(--dur-fast), background var(--dur-fast), box-shadow var(--dur-fast), transform var(--dur-fast); }
    .choice-tile:hover > span { border-color: #aebdb5; transform: translateY(-1px); }
    .choice-tile input:checked + span { color: var(--indigo); border-color: color-mix(in srgb, var(--indigo) 52%, white); background: color-mix(in srgb, #dcebe2 68%, white); box-shadow: inset 0 0 0 1px rgb(36 84 66 / .08); }
    .choice-tile input:focus-visible + span { outline: 3px solid color-mix(in srgb, var(--indigo) 68%, white); outline-offset: 2px; }
    .choice-tile--wide { display: block; margin-top: .5rem; }
    .choice-tile--gender > span { gap: .55rem; min-height: 3rem; }
    .choice-tile--gender b { display: grid; inline-size: 1.45rem; block-size: 1.45rem; place-items: center; border-radius: 50%; color: var(--vermilion); background: var(--peach-pale, var(--paper-sunken)); font-size: .95rem; }
    .choice-tile--gender input:checked + span b { color: white; background: var(--indigo); }
    .switch-row { display: flex; min-height: 2rem; align-items: center; justify-content: space-between; gap: 1rem; color: var(--ink-soft); font-size: var(--text-xs); font-weight: 700; cursor: pointer; }
    .switch-control { position: relative; flex: 0 0 auto; inline-size: 2.75rem; block-size: 1.55rem; }
    .switch-control input { position: absolute; inset: 0; inline-size: 100%; block-size: 100%; margin: 0; opacity: 0; cursor: pointer; }
    .switch-control i { display: block; inline-size: 100%; block-size: 100%; border: 1px solid #c8ceca; border-radius: 999px; background: #e7e8e4; transition: border-color var(--dur-fast), background var(--dur-fast), box-shadow var(--dur-fast); }
    .switch-control i::after { content: ''; position: absolute; inline-size: 1.1rem; block-size: 1.1rem; inset: .225rem auto auto .25rem; border-radius: 50%; background: white; box-shadow: 0 2px 6px rgb(35 53 44 / .22); transition: transform var(--dur-fast) var(--ease-reveal); }
    .switch-control input:checked + i { border-color: var(--indigo); background: var(--indigo); }
    .switch-control input:checked + i::after { transform: translateX(1.18rem); }
    .switch-control input:focus-visible + i { outline: 3px solid color-mix(in srgb, var(--indigo) 68%, white); outline-offset: 2px; }
    .form-error { margin: .2rem 0 0; padding: .7rem .85rem; border-radius: var(--radius-sm); color: #9f3226; background: #fff0eb; font-size: var(--text-xs); font-weight: 700; }
    .gform .btn-primary { width: 100%; margin-top: .2rem; display: inline-flex; align-items: center; justify-content: center; }
    .button-arrow { display: grid; inline-size: 1.65rem; block-size: 1.65rem; margin-inline-start: .25rem; place-items: center; border-radius: 50%; background: rgb(255 255 255 / .16); font-size: 1rem; transition: transform var(--dur-fast); }
    .gform .btn-primary:hover .button-arrow { transform: translateX(3px); }

    /* ── results ── */
    #gunghap-result { scroll-margin-top: 5.5rem; }
    #gunghap-result[hidden] { display: none; }
    .card.gunghap-result-hero { position: relative; isolation: isolate; overflow: hidden; padding: clamp(1.5rem, 4vw, 3rem); color: white; border: 0; background: radial-gradient(circle at 88% 8%, rgb(255 255 255 / .16), transparent 13rem), linear-gradient(128deg, #173b31, #245442 55%, #396e5a); box-shadow: 0 28px 70px rgb(24 52 42 / .22); }
    .card.gunghap-result-hero::after { content: '合'; position: absolute; z-index: -1; inset: auto -1rem -4rem auto; color: rgb(255 255 255 / .06); font-family: var(--font-display); font-size: clamp(10rem, 24vw, 18rem); line-height: 1; transform: rotate(-7deg); }
    .result-head { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-5); }
    .result-head > div { max-width: 48rem; }
    .result-head h2 { margin: 0; color: white; font-size: clamp(1.7rem, 4vw, 2.8rem); }
    .result-overline { margin: 0 0 .45rem; color: #efad7a; font-family: var(--font-mono); font-size: .68rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
    .result-note { max-width: 45rem; margin: .7rem 0 0; color: rgb(255 255 255 / .72); font-size: .82rem; line-height: 1.7; }
    .result-head .btn-secondary { flex: 0 0 auto; border-color: rgb(255 255 255 / .28); color: white; background: rgb(255 255 255 / .1); backdrop-filter: blur(8px); }
    .result-head .btn-secondary:hover { background: rgb(255 255 255 / .18); }

    .pair-signature { display: grid; grid-template-columns: minmax(7rem, .7fr) minmax(12rem, 1.6fr) minmax(7rem, .7fr); align-items: center; gap: clamp(.75rem, 3vw, 1.5rem); margin-top: clamp(1.5rem, 4vw, 2.5rem); }
    .signature-person { display: grid; min-height: 8.5rem; place-items: center; align-content: center; gap: .25rem; border: 1px solid rgb(255 255 255 / .22); border-radius: 1.2rem; color: var(--ink); background: rgb(255 255 255 / .9); box-shadow: inset 0 0 0 .35rem rgb(255 255 255 / .35), 0 14px 30px rgb(11 35 27 / .18); }
    .signature-person small { color: var(--ink-soft); font-size: .66rem; font-weight: 760; }
    .signature-person strong { font-family: var(--font-display); font-size: clamp(2.8rem, 6vw, 4.2rem); line-height: 1; }
    .signature-person span { color: var(--ink-soft); font-size: .65rem; font-weight: 730; }
    .signature-bridge { min-width: 0; text-align: center; }
    .signature-bridge > div { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: .75rem; }
    .signature-bridge i { display: block; block-size: 1px; background: linear-gradient(90deg, transparent, rgb(255 255 255 / .48)); }
    .signature-bridge i:last-child { background: linear-gradient(90deg, rgb(255 255 255 / .48), transparent); }
    .signature-bridge b { display: grid; inline-size: 3.2rem; aspect-ratio: 1; place-items: center; border: 1px solid rgb(255 255 255 / .32); border-radius: 50%; color: white; background: rgb(255 255 255 / .08); font-family: var(--font-display); font-size: 1.45rem; box-shadow: 0 0 0 .45rem rgb(255 255 255 / .04); }
    .signature-bridge p { max-width: 30rem; margin: .75rem auto 0; color: rgb(255 255 255 / .76); font-size: .72rem; line-height: 1.55; }
    .result-actions { display: flex; justify-content: center; gap: .55rem; margin-top: 1.25rem; }
    .result-actions .btn-secondary { min-height: 2.4rem; border-color: rgb(255 255 255 / .28); color: white; background: rgb(255 255 255 / .09); }

    .compat-summary { scroll-margin-top: 8rem; margin-block: clamp(1.5rem, 4vw, 2.5rem); }
    .compat-summary__heading { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; margin-bottom: 1rem; }
    .compat-summary__heading p { margin: 0; color: var(--vermilion); font-family: var(--font-mono); font-size: .6rem; font-weight: 800; letter-spacing: .07em; }
    .compat-summary__heading h2 { margin: .18rem 0 0; font-size: var(--text-xl); }
    .compat-summary__heading > span { max-width: 38rem; color: var(--ink-soft); font-size: .68rem; line-height: 1.55; text-align: end; }
    .compat-summary-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .65rem; }
    .compat-summary-card { position: relative; display: grid; min-width: 0; min-height: 10.5rem; align-content: start; gap: .75rem; overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius); padding: .9rem; color: var(--ink); background: linear-gradient(145deg, rgb(255 255 255 / .9), rgb(247 247 242 / .7)); text-decoration: none; box-shadow: 0 10px 28px rgb(35 53 44 / .05); transition: transform var(--dur-fast), border-color var(--dur-fast), box-shadow var(--dur-fast); }
    .compat-summary-card:hover { border-color: color-mix(in srgb, var(--indigo) 36%, var(--line)); box-shadow: 0 16px 36px rgb(35 53 44 / .11); transform: translateY(-3px); }
    .compat-summary-card > span { display: grid; inline-size: 2.45rem; aspect-ratio: 1; place-items: center; border-radius: .75rem; color: var(--vermilion); background: var(--peach-pale); font-family: var(--font-display); font-size: 1rem; }
    .compat-summary-card small { color: var(--indigo); font-size: .54rem; font-weight: 780; }
    .compat-summary-card h3 { margin: .16rem 0 .4rem; font-size: .78rem; }
    .compat-summary-card p { display: -webkit-box; overflow: hidden; margin: 0; color: var(--ink-soft); font-size: .62rem; line-height: 1.5; -webkit-box-orient: vertical; -webkit-line-clamp: 3; }
    .compat-summary-card > i { position: absolute; inset: .75rem .75rem auto auto; color: var(--ink-soft); font-style: normal; font-size: .7rem; }

    .gunghap-jumpbar { position: sticky; z-index: 14; top: 4.5rem; display: flex; align-items: center; gap: .55rem; margin-block: 1rem 0; padding: .5rem; border: 1px solid color-mix(in srgb, var(--line) 82%, transparent); border-radius: 999px; background: color-mix(in srgb, var(--paper-raised) 90%, transparent); box-shadow: 0 12px 30px rgb(31 43 37 / .08); backdrop-filter: blur(18px) saturate(125%); }
    .gunghap-jumpbar > span { display: grid; inline-size: 2rem; aspect-ratio: 1; flex: 0 0 auto; place-items: center; border-radius: 50%; color: white; background: var(--indigo); font-size: .8rem; }
    .gunghap-jumpbar > div { display: flex; min-width: 0; gap: .25rem; overflow-x: auto; scrollbar-width: none; }
    .gunghap-jumpbar > div::-webkit-scrollbar { display: none; }
    .gunghap-jumpbar button { flex: 0 0 auto; min-height: 2rem; padding: .38rem .65rem; border: 0; border-radius: 999px; color: var(--ink-soft); background: transparent; font: inherit; font-size: .64rem; font-weight: 740; cursor: pointer; }
    .gunghap-jumpbar button:hover { color: var(--ink); background: var(--paper-sunken); }
    .gunghap-jumpbar button[aria-current="location"] { color: white; background: var(--indigo); }

    .pair-charts-section, .gsection { scroll-margin-top: 9rem; }
    .person-charts { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-4); margin-block: clamp(1.5rem, 4vw, 2.5rem); }
    .card.mini-chart { --person-accent: var(--indigo); min-width: 0; overflow: hidden; padding: clamp(1rem, 2.5vw, 1.5rem); border-color: color-mix(in srgb, var(--person-accent) 20%, var(--line)); background: linear-gradient(150deg, color-mix(in srgb, var(--person-accent) 7%, white), rgb(255 255 255 / .86)); box-shadow: 0 15px 40px rgb(35 53 44 / .08); }
    .mini-chart--b { --person-accent: #9f594a; }
    .mini-chart__head { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: .7rem; margin-bottom: 1rem; }
    .mini-chart__person { display: grid; inline-size: 2.3rem; aspect-ratio: 1; place-items: center; border-radius: .75rem; color: white; background: var(--person-accent); font-family: var(--font-display); font-size: 1rem; box-shadow: 0 7px 16px color-mix(in srgb, var(--person-accent) 25%, transparent); }
    .mini-chart__head small { display: block; color: var(--ink-soft); font-size: .62rem; font-weight: 720; }
    .mini-chart__head h3 { margin: .12rem 0 0; font-family: var(--font-display); font-size: 1.3rem; }
    .mini-chart__head h3 span { color: var(--ink-soft); font-family: var(--font-body); font-size: .68rem; font-weight: 650; }
    .mini-chart__element { padding: .35rem .55rem; border-radius: 999px; font-size: .62rem; font-weight: 760; }
    .mini-pillars { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .55rem; }
    .mini-pillar { position: relative; display: grid; min-width: 0; min-height: 8rem; justify-items: center; align-content: center; gap: .3rem; overflow: hidden; padding: .65rem .45rem; border: 1px solid var(--line); border-radius: .9rem; background: rgb(255 255 255 / .72); }
    .mini-pillar--day { border-color: color-mix(in srgb, var(--person-accent) 48%, var(--line)); background: white; box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--person-accent) 8%, transparent), 0 8px 18px color-mix(in srgb, var(--person-accent) 10%, transparent); }
    .mini-pillar--day::before { content: ''; position: absolute; inset: 0 0 auto; block-size: .28rem; background: var(--person-accent); }
    .mini-pillar small { color: var(--ink-soft); font-size: .58rem; font-weight: 720; }
    .mini-pillar strong { display: grid; grid-template-rows: repeat(2, 1fr); font-family: var(--font-display); font-size: 1.65rem; line-height: .92; }
    .mini-pillar > span { overflow: hidden; max-width: 100%; color: var(--ink-soft); font-family: var(--font-mono); font-size: .56rem; text-overflow: ellipsis; white-space: nowrap; }

    .gunghap-sections { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-4); }
    .card.gsection { --section-accent: var(--indigo); position: relative; display: grid; min-width: 0; align-content: start; overflow: hidden; padding: clamp(1.15rem, 3vw, 1.75rem); border-color: color-mix(in srgb, var(--section-accent) 18%, var(--line)); background: linear-gradient(145deg, color-mix(in srgb, var(--section-accent) 5%, white), rgb(255 255 255 / .88)); box-shadow: 0 15px 42px rgb(35 53 44 / .07); }
    .gsection::after { content: ''; position: absolute; inline-size: 8rem; aspect-ratio: 1; inset: -5rem -4rem auto auto; border: 1px solid color-mix(in srgb, var(--section-accent) 14%, transparent); border-radius: 50%; box-shadow: 0 0 0 1.8rem color-mix(in srgb, var(--section-accent) 2.5%, transparent); pointer-events: none; }
    .gsection--inner { --section-accent: #9b4d59; }
    .gsection--cross { --section-accent: #4e6f8e; }
    .gsection--spouse { --section-accent: #8b6740; }
    .gsection--stems { --section-accent: #546b95; }
    .gsection--tengods { --section-accent: #74598a; }
    .gsection--elements { --section-accent: #a06d29; }
    .gsection--strength { --section-accent: #42747a; }
    .gsection--timing { --section-accent: #496183; }
    .gsection--wide { grid-column: 1 / -1; }
    .gsection__head { position: relative; z-index: 1; display: flex; align-items: center; gap: .7rem; margin-bottom: 1rem; }
    .gsection__mark { display: grid; inline-size: 2.7rem; aspect-ratio: 1; flex: 0 0 auto; place-items: center; border-radius: .85rem; color: var(--section-accent); background: color-mix(in srgb, var(--section-accent) 10%, white); font-family: var(--font-display); font-size: 1.15rem; box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--section-accent) 14%, transparent); }
    .gsection__head small { color: var(--section-accent); font-family: var(--font-mono); font-size: .58rem; font-weight: 800; letter-spacing: .08em; }
    .gsection__head h3 { margin: .1rem 0 0; font-size: clamp(1.05rem, 2vw, 1.3rem); }
    .gsection__body { position: relative; z-index: 1; min-width: 0; min-height: 3.25rem; }
    .gsection--cross .gsection__body { overflow-x: auto; overscroll-behavior-inline: contain; scrollbar-width: thin; }
    .gsection__note { position: relative; z-index: 1; display: grid; grid-template-columns: auto 1fr; align-items: flex-start; gap: .55rem; margin-top: 1.1rem; padding-top: .9rem; border-top: 1px solid color-mix(in srgb, var(--section-accent) 12%, var(--line)); }
    .gsection__note > span { display: grid; inline-size: 1.2rem; aspect-ratio: 1; place-items: center; border-radius: 50%; color: white; background: var(--section-accent); font-family: var(--font-mono); font-size: .58rem; font-weight: 800; }
    .gsection__note p { margin: 0; color: var(--ink-soft); font-size: .68rem; line-height: 1.6; }
    .rel-badges { display: flex; flex-wrap: wrap; gap: .45rem; }
    .rel-badge { display: inline-flex; align-items: center; min-height: 2.25rem; border: 1px solid var(--line); border-radius: .7rem; padding: .45rem .65rem; font-size: .7rem; font-weight: 720; }
    .rel-badge--smooth { color: var(--indigo); border-color: color-mix(in srgb, var(--indigo) 34%, var(--line)); background: color-mix(in srgb, var(--jade-pale) 58%, white); }
    .rel-badge--tense { color: #985043; border-color: color-mix(in srgb, #b85a48 32%, var(--line)); background: color-mix(in srgb, #ffebe5 72%, white); }
    .glead { margin: 0; color: var(--ink-soft); font-size: .8rem; line-height: 1.65; }
    .glead--feature { padding: .8rem .9rem; border-inline-start: 3px solid var(--section-accent); border-radius: 0 .7rem .7rem 0; color: var(--ink); background: color-mix(in srgb, var(--section-accent) 6%, white); font-weight: 700; }
    .pair-insight-list { display: grid; gap: .55rem; }
    .pair-insight-list p, .fill-summary p { margin: 0; padding: .65rem .75rem; border: 1px solid color-mix(in srgb, var(--section-accent) 14%, var(--line)); border-radius: .7rem; color: var(--ink); background: rgb(255 255 255 / .7); font-size: .72rem; line-height: 1.55; }
    .fill-summary { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .55rem; margin-bottom: 1rem; }
    .fill-summary p:only-child { grid-column: 1 / -1; }
    .soft { color: var(--ink-soft); }

    .matrix-instruction { margin: 0 0 .75rem; color: var(--ink-soft); font-size: .66rem; }
    .compat-matrix { display: grid; grid-template-columns: minmax(4.5rem, .75fr) repeat(4, minmax(4.7rem, 1fr)); gap: .35rem; min-width: 31rem; }
    .compat-matrix__axis { display: grid; min-height: 3.2rem; align-content: center; justify-items: center; border-radius: .65rem; color: var(--ink-soft); background: color-mix(in srgb, var(--section-accent) 6%, white); }
    .compat-matrix__axis small { font-size: .5rem; }
    .compat-matrix__axis strong { font-size: .64rem; }
    .compat-matrix__cell { display: grid; min-height: 4rem; place-items: center; align-content: center; gap: .18rem; border: 1px solid var(--line); border-radius: .7rem; color: var(--ink); background: rgb(255 255 255 / .68); font: inherit; cursor: pointer; transition: transform var(--dur-fast), border-color var(--dur-fast), box-shadow var(--dur-fast); }
    .compat-matrix__cell:hover, .compat-matrix__cell[aria-pressed="true"] { z-index: 1; border-color: var(--section-accent); box-shadow: 0 8px 18px color-mix(in srgb, var(--section-accent) 15%, transparent); transform: translateY(-2px); }
    .compat-matrix__cell--smooth { background: color-mix(in srgb, var(--jade-pale) 58%, white); }
    .compat-matrix__cell--tense { background: color-mix(in srgb, #ffebe5 70%, white); }
    .compat-matrix__cell span { display: inline-flex; align-items: center; gap: .28rem; font-family: var(--font-display); font-size: .95rem; }
    .compat-matrix__cell i { color: var(--ink-soft); font-family: var(--font-body); font-size: .5rem; font-style: normal; }
    .compat-matrix__cell small { color: var(--ink-soft); font-family: var(--font-mono); font-size: .5rem; }
    .compat-matrix__empty { display: grid; place-items: center; border-radius: .7rem; color: var(--ink-soft); background: var(--paper-sunken); }
    .matrix-detail { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: .65rem; margin-top: .8rem; padding: .8rem; border: 1px solid color-mix(in srgb, var(--section-accent) 18%, var(--line)); border-radius: var(--radius); background: rgb(255 255 255 / .7); }
    .matrix-detail > div { display: grid; justify-items: center; gap: .2rem; }
    .matrix-detail > div small { color: var(--ink-soft); font-size: .55rem; }
    .matrix-detail > div strong { font-family: var(--font-display); font-size: 1.5rem; }
    .matrix-detail > aside { grid-column: 1 / -1; padding-top: .65rem; border-top: 1px solid var(--line); }

    .cross-pillar-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .7rem; }
    .cross-pillar-item { min-width: 0; padding: .8rem; border: 1px solid color-mix(in srgb, var(--section-accent) 15%, var(--line)); border-radius: .85rem; background: rgb(255 255 255 / .68); }
    .cross-pillar-item header { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: .55rem; margin-bottom: .65rem; }
    .cross-pillar-item header > span { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: .5rem; min-width: 0; }
    .cross-pillar-item header > span:last-child { grid-template-columns: auto 1fr; }
    .cross-pillar-item header > span:last-child small { order: 2; text-align: end; }
    .cross-pillar-item header small { overflow: hidden; color: var(--ink-soft); font-size: .58rem; font-weight: 720; text-overflow: ellipsis; white-space: nowrap; }
    .cross-pillar-item header strong { display: grid; inline-size: 2rem; aspect-ratio: 1; place-items: center; border: 1px solid color-mix(in srgb, var(--section-accent) 22%, var(--line)); border-radius: .55rem; color: var(--section-accent); background: white; font-family: var(--font-display); font-size: 1.15rem; }
    .cross-pillar-item header i { color: var(--section-accent); font-size: .75rem; font-style: normal; }
    .cross-pillar-item .rel-badge { min-height: 1.85rem; padding: .32rem .5rem; font-size: .62rem; }

    .spouse-palace-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .8rem; }
    .spouse-palace { --person-accent: var(--indigo); overflow: hidden; border: 1px solid color-mix(in srgb, var(--person-accent) 20%, var(--line)); border-radius: var(--radius); background: rgb(255 255 255 / .7); }
    .spouse-palace--b { --person-accent: #a55d4d; }
    .spouse-palace > header { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: .15rem .7rem; padding: .75rem .9rem; border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--person-accent) 6%, white); }
    .spouse-palace > header span { color: var(--person-accent); font-size: .66rem; font-weight: 800; }
    .spouse-palace > header strong { grid-row: 1 / 3; grid-column: 2; font-family: var(--font-display); font-size: 1.8rem; line-height: 1; }
    .spouse-palace > header small { color: var(--ink-soft); font-size: .57rem; }
    .spouse-palace > div { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .55rem; padding: .75rem; }
    .spouse-hidden-chip { min-width: 0; overflow: hidden; border-radius: .75rem; background: color-mix(in srgb, var(--paper-sunken) 58%, white); text-align: center; }
    .spouse-hidden-chip summary { display: grid; min-height: 5.2rem; justify-items: center; align-content: center; gap: .25rem; padding: .65rem .4rem; cursor: pointer; list-style: none; }
