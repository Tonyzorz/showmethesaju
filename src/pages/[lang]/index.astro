---
import Base from '../../layouts/Base.astro';
import { LOCALES } from '../../i18n/locales';
import { t } from '../../i18n/t';
import { CITIES } from '../../lib/cities';

export function getStaticPaths() {
  return LOCALES.map((l) => ({ params: { lang: l.code } }));
}
const { lang } = Astro.params;
const READING_FOCUSES = [
  { key: 'basic', mark: '命' },
  { key: 'personality', mark: '氣' },
  { key: 'wealth', mark: '財' },
  { key: 'health', mark: '身' },
  { key: 'career', mark: '業' },
  { key: 'relationships', mark: '緣' },
  { key: 'noble', mark: '貴' },
  { key: 'movement', mark: '動' },
  { key: 'timing', mark: '運' },
] as const;
---
<Base lang={lang} title={t(lang, 'meta.home.title')} description={t(lang, 'meta.home.description')} path="">
  <section class="hero">
    <div class="hero-copy">
      <div class="hero-symbols" aria-hidden="true">
        <span>木</span><span>火</span><span>土</span><span>金</span><span>水</span>
      </div>
      <h1>{t(lang, 'hero.headline')}</h1>
      <p class="hero-sub">{t(lang, 'hero.sub')}</p>
      <p class="trust-line">{t(lang, 'hero.trust')}</p>

    </div>

    <form id="birth-form" class="card birth-form" data-lang={lang}
      data-err-future={t(lang, 'form.errFuture')} data-err-lunar={t(lang, 'form.errLunarRange')}
      data-err-solar-city={t(lang, 'form.errSolarCity')} data-focus-cta={t(lang, 'fortune.cta')}>
      <div class="form-tools">
        <button id="open-onboarding" type="button"><span aria-hidden="true">?</span>{t(lang, 'explainer.title')}</button>
        <details class="profile-manager">
          <summary>{t(lang, 'experience.profileTitle')}</summary>
          <div class="profile-manager__body">
            <div id="profile-list" class="profile-list" data-empty={t(lang, 'experience.profileEmpty')} data-delete={t(lang, 'experience.profileDelete')}></div>
            <div class="profile-save-row">
              <label for="profile-name">{t(lang, 'experience.profileName')}</label>
              <div><input id="profile-name" class="field" type="text" maxlength="40" autocomplete="off" /><button id="save-profile" class="btn-secondary" type="button">{t(lang, 'experience.profileSave')}</button></div>
            </div>
            <p>{t(lang, 'experience.profileLocal')}</p>
          </div>
        </details>
      </div>
      <div class="form-progress" aria-hidden="true">
        <span data-progress-step="date">01</span>
        <i></i>
        <span data-progress-step="time">02</span>
        <i></i>
        <span data-progress-step="gender">03</span>
        <i></i>
        <span data-progress-step="place">04</span>
      </div>

      <div class="input-step" data-input-step="date">
        <div class="input-step__heading">
          <span class="input-step__number">01</span>
          <label for="birth-date">{t(lang, 'form.date')}</label>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <div class="field-shell">
          <span class="field-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M7 3v3m10-3v3M4 9h16M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" /></svg>
          </span>
          <input id="birth-date" class="field" type="date" name="date" required min="1900-01-01" />
        </div>
        <fieldset class="choice-field">
          <legend>{t(lang, 'form.calendar')}</legend>
          <div class="choice-grid">
            <label class="choice-tile"><input type="radio" name="cal" value="solar" checked /><span>{t(lang, 'form.solar')}</span></label>
            <label class="choice-tile"><input type="radio" name="cal" value="lunar" /><span>{t(lang, 'form.lunar')}</span></label>
          </div>
          <label class="choice-tile choice-tile--wide lunar-only" hidden><input type="checkbox" name="leap" /><span>{t(lang, 'form.lunarLeap')}</span></label>
        </fieldset>
      </div>

      <div class="input-step" data-input-step="time">
        <div class="input-step__heading">
          <span class="input-step__number">02</span>
          <label for="birth-time">{t(lang, 'form.time')}</label>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <div class="field-shell">
          <span class="field-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
          </span>
          <input id="birth-time" class="field" type="time" name="time" value="12:00" />
        </div>
        <label class="switch-row">
          <span>{t(lang, 'form.timeUnknown')}</span>
          <span class="switch-control"><input type="checkbox" name="timeUnknown" /><i aria-hidden="true"></i></span>
        </label>
      </div>

      <div class="input-step" data-input-step="gender">
        <div class="input-step__heading">
          <span class="input-step__number">03</span>
          <span class="input-step__label">{t(lang, 'form.gender')}</span>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <fieldset class="choice-field gender-field">
          <legend class="visually-hidden">{t(lang, 'form.gender')}</legend>
          <div class="choice-grid">
            <label class="choice-tile choice-tile--gender"><input type="radio" name="gender" value="f" required /><span><b aria-hidden="true">♀</b>{t(lang, 'form.genderF')}</span></label>
            <label class="choice-tile choice-tile--gender"><input type="radio" name="gender" value="m" /><span><b aria-hidden="true">♂</b>{t(lang, 'form.genderM')}</span></label>
          </div>
        </fieldset>
      </div>

      <div class="input-step" data-input-step="place">
        <div class="input-step__heading">
          <span class="input-step__number">04</span>
          <label for="birth-city">{t(lang, 'form.place')}</label>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <div class="field-shell">
          <span class="field-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z" /><circle cx="12" cy="10" r="2.5" /></svg>
          </span>
          <select id="birth-city" class="field" name="city">
            <option value="">— {t(lang, 'form.place')} (auto) —</option>
            {CITIES.map((c) => <option value={c.tz} data-lon={c.lon}>{c.name}</option>)}
          </select>
        </div>

        <details class="advanced">
          <summary>{t(lang, 'form.advanced')}</summary>
          <label class="switch-row switch-row--advanced">
            <span>{t(lang, 'form.trueSolar')}</span>
            <span class="switch-control"><input type="checkbox" name="trueSolar" /><i aria-hidden="true"></i></span>
          </label>
          <p class="hint">{t(lang, 'form.trueSolarHint')}</p>
        </details>
      </div>

      <div class="form-summary" aria-live="polite">
        <div><span>{t(lang, 'form.date')}</span><strong id="summary-date">—</strong></div>
        <div><span>{t(lang, 'form.time')}</span><strong id="summary-time">12:00</strong></div>
        <div><span>{t(lang, 'form.gender')}</span><strong id="summary-gender">—</strong></div>
        <div><span>{t(lang, 'form.place')}</span><strong id="summary-place">—</strong></div>
      </div>

      <p class="form-error" role="alert" hidden></p>
      <button class="btn-primary" type="submit"><span id="submit-label">{t(lang, 'hero.cta')}</span><span class="button-arrow" aria-hidden="true">→</span></button>
    </form>

    <section class="fortune-picker" aria-labelledby="fortune-picker-title">
      <div class="fortune-picker__heading">
        <div>
          <p>{t(lang, 'fortune.eyebrow')}</p>
          <h2 id="fortune-picker-title">{t(lang, 'fortune.title')}</h2>
        </div>
        <span>{t(lang, 'fortune.subtitle')}</span>
      </div>
      <div class="fortune-grid">
        {READING_FOCUSES.map((focus, index) => (
          <label class={`fortune-card fortune-card--${focus.key}`}>
            <input type="radio" name="focus" value={focus.key} form="birth-form" checked={index === 0} />
            <span class="fortune-card__surface">
              <span class="fortune-card__mark" aria-hidden="true">{focus.mark}</span>
              <span class="fortune-card__copy">
                <strong>{t(lang, `fortune.${focus.key}.title`)}</strong>
                <small>{t(lang, `fortune.${focus.key}.body`)}</small>
              </span>
              <span class="fortune-card__check" aria-hidden="true">✓</span>
            </span>
          </label>
        ))}
      </div>
    </section>
  </section>

  <dialog id="onboarding-dialog" class="onboarding-dialog" aria-labelledby="onboarding-title">
    <form method="dialog">
      <header>
        <span aria-hidden="true">命</span>
        <div><small>01 — 03</small><h2 id="onboarding-title">{t(lang, 'explainer.title')}</h2></div>
        <button class="onboarding-close" value="cancel" aria-label={t(lang, 'experience.onboardingSkip')}>×</button>
      </header>
      <div class="onboarding-steps" aria-live="polite">
        {[1, 2, 3].map((i) => (
          <article data-onboarding-step={i} hidden={i !== 1}>
            <span>{String(i).padStart(2, '0')}</span>
            <h3>{t(lang, `explainer.step${i}.title`)}</h3>
            <p>{t(lang, `explainer.step${i}.body`)}</p>
          </article>
        ))}
      </div>
      <div class="onboarding-progress" aria-hidden="true"><i></i><i></i><i></i></div>
      <footer>
        <button id="onboarding-skip" class="btn-secondary" value="cancel">{t(lang, 'experience.onboardingSkip')}</button>
        <button id="onboarding-next" class="btn-primary" type="button" data-next={t(lang, 'experience.onboardingNext')} data-start={t(lang, 'hero.cta')}>{t(lang, 'experience.onboardingNext')}</button>
      </footer>
    </form>
  </dialog>

  <section class="explainer">
    <h2>{t(lang, 'explainer.title')}</h2>
    <div class="steps">
      {[1, 2, 3].map((i) => (
        <div class="card step" data-step={String(i).padStart(2, '0')}>
          <h3>{t(lang, `explainer.step${i}.title`)}</h3>
          <p>{t(lang, `explainer.step${i}.body`)}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="card waitlist">
    <h2>{t(lang, 'waitlist.title')}</h2>
    <p>{t(lang, 'waitlist.body')}</p>
    <a class="btn-secondary" href="https://pf.kakao.com/" rel="noopener" target="_blank" data-analytics-event="booking_click" data-analytics-destination="kakao_booking" data-analytics-area="home_cta">{t(lang, 'footer.booking')} <span aria-hidden="true">↗</span></a>
  </section>

  <script>
    import KoreanLunarCalendar from 'korean-lunar-calendar';
    import { tzOffsetMinutes } from '../../lib/cities';
    import { withBase } from '../../lib/paths';
    import { trackEvent } from '../../lib/analytics';
    import {
      ONBOARDING_STORAGE_KEY, deleteProfile, loadProfiles, saveProfile,
      type BirthProfileData,
    } from '../../lib/local-data';

    const form = document.getElementById('birth-form') as HTMLFormElement;
    const dateInput = form.elements.namedItem('date') as HTMLInputElement;
    const timeInput = form.elements.namedItem('time') as HTMLInputElement;
    const timeUnknownInput = form.elements.namedItem('timeUnknown') as HTMLInputElement;
    const genderInputs = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="gender"]'));
    const cityInput = form.elements.namedItem('city') as HTMLSelectElement;
    const lunarOnly = form.querySelector('.lunar-only') as HTMLElement;
    const errEl = form.querySelector('.form-error') as HTMLElement;
    const steps = Array.from(form.querySelectorAll<HTMLElement>('[data-input-step]'));
    const summaryDate = form.querySelector('#summary-date') as HTMLElement;
    const summaryTime = form.querySelector('#summary-time') as HTMLElement;
    const summaryGender = form.querySelector('#summary-gender') as HTMLElement;
    const summaryPlace = form.querySelector('#summary-place') as HTMLElement;
    const focusInputs = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="focus"][form="birth-form"]'));
    const submitLabel = form.querySelector('#submit-label') as HTMLElement;
    const focusCta = form.dataset.focusCta!;
    const profileList = document.getElementById('profile-list')!;
    const profileName = document.getElementById('profile-name') as HTMLInputElement;
    const onboarding = document.getElementById('onboarding-dialog') as HTMLDialogElement;

    // Keep the static site current without requiring a rebuild each day.
    const today = new Date();
    dateInput.max = [today.getFullYear(), String(today.getMonth() + 1).padStart(2, '0'), String(today.getDate()).padStart(2, '0')].join('-');

    const stepByName = (name: string) => form.querySelector<HTMLElement>(`[data-input-step="${name}"]`);

    function clearError() {
      errEl.hidden = true;
      form.classList.remove('has-error');
      steps.forEach((step) => step.classList.remove('has-error'));
      form.querySelectorAll<HTMLElement>('[aria-invalid="true"]').forEach((field) => field.removeAttribute('aria-invalid'));
    }

    function showError(message: string, stepName: string) {
      errEl.textContent = message;
      errEl.hidden = false;
      form.classList.add('has-error');
      stepByName(stepName)?.classList.add('has-error');
      stepByName(stepName)?.querySelector<HTMLElement>('input, select')?.setAttribute('aria-invalid', 'true');
    }

    function formatDate(value: string) {
      if (!value) return '—';
      const [year, month, day] = value.split('-').map(Number);
      try {
        return new Intl.DateTimeFormat(document.documentElement.lang, {
          year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
        }).format(new Date(Date.UTC(year, month - 1, day)));
      } catch {
        return value;
      }
    }

    function updateFormState() {
      timeInput.disabled = timeUnknownInput.checked;
      timeInput.closest('.field-shell')?.classList.toggle('is-disabled', timeUnknownInput.checked);

      summaryDate.textContent = formatDate(dateInput.value);
      summaryTime.textContent = timeUnknownInput.checked
        ? (timeUnknownInput.closest('.switch-row')?.querySelector(':scope > span')?.textContent?.trim() || '—')
        : (timeInput.value || '—');
      const selectedGender = genderInputs.find((input) => input.checked);
      summaryGender.textContent = selectedGender?.nextElementSibling?.textContent?.trim() || '—';
      summaryPlace.textContent = cityInput.selectedOptions[0]?.textContent?.trim() || '—';

      const completed = {
        date: Boolean(dateInput.value),
        time: Boolean(stepByName('time')?.classList.contains('is-touched') && (timeUnknownInput.checked || timeInput.value)),
        gender: Boolean(selectedGender),
        place: Boolean(stepByName('place')?.classList.contains('is-touched')),
      };

      Object.entries(completed).forEach(([name, isComplete]) => {
        stepByName(name)?.classList.toggle('is-complete', isComplete);
        form.querySelector(`[data-progress-step="${name}"]`)?.classList.toggle('is-complete', isComplete);
      });
    }

    function setActiveStep(activeStep: HTMLElement | null) {
      steps.forEach((step) => step.classList.toggle('is-active', step === activeStep));
      form.querySelectorAll('[data-progress-step]').forEach((marker) => {
        marker.classList.toggle('is-active', marker.getAttribute('data-progress-step') === activeStep?.dataset.inputStep);
      });
    }

    steps.forEach((step) => {
      step.addEventListener('focusin', () => setActiveStep(step));
      step.addEventListener('focusout', () => {
        requestAnimationFrame(() => {
          const focusedStep = steps.find((candidate) => candidate.contains(document.activeElement));
          setActiveStep(focusedStep || null);
        });
      });
      ['input', 'change'].forEach((eventName) => step.addEventListener(eventName, () => {
        step.classList.add('is-touched');
        clearError();
        updateFormState();
      }));
    });

    form.querySelectorAll('input[name="cal"]').forEach((r) =>
      r.addEventListener('change', () => {
        lunarOnly.hidden = (form.elements.namedItem('cal') as RadioNodeList).value !== 'lunar';
        updateFormState();
      })
    );

    setActiveStep(stepByName('date') || null);
    updateFormState();

    let formStarted = false;
    form.addEventListener('input', () => {
      if (formStarted) return;
      formStarted = true;
      trackEvent('chart_form_start', { language: form.dataset.lang });
    }, { once: true });

    function currentProfileData(): BirthProfileData | null {
      const gender = genderInputs.find((input) => input.checked)?.value;
      if (!dateInput.value || (gender !== 'f' && gender !== 'm')) return null;
      return {
        date: dateInput.value,
        time: timeInput.value || '12:00',
        timeUnknown: timeUnknownInput.checked,
        calendar: (form.elements.namedItem('cal') as RadioNodeList).value === 'lunar' ? 'lunar' : 'solar',
        leap: (form.elements.namedItem('leap') as HTMLInputElement).checked,
        gender,
        city: cityInput.value,
        trueSolar: (form.elements.namedItem('trueSolar') as HTMLInputElement).checked,
      };
    }

    function loadProfileData(data: BirthProfileData) {
      dateInput.value = data.date;
      timeInput.value = data.time;
      timeUnknownInput.checked = data.timeUnknown;
      form.querySelector<HTMLInputElement>(`input[name="cal"][value="${data.calendar}"]`)!.checked = true;
      (form.elements.namedItem('leap') as HTMLInputElement).checked = data.leap;
      form.querySelector<HTMLInputElement>(`input[name="gender"][value="${data.gender}"]`)!.checked = true;
      cityInput.value = data.city;
      (form.elements.namedItem('trueSolar') as HTMLInputElement).checked = data.trueSolar;
      steps.forEach((step) => step.classList.add('is-touched'));
      lunarOnly.hidden = data.calendar !== 'lunar';
      clearError();
      updateFormState();
    }

    function renderProfiles() {
      const profiles = loadProfiles();
      profileList.replaceChildren();
      if (!profiles.length) {
        const empty = document.createElement('p');
        empty.className = 'profile-empty';
        empty.textContent = profileList.dataset.empty || '';
        profileList.append(empty);
        return;
      }
      for (const profile of profiles) {
        const row = document.createElement('div');
        const load = document.createElement('button');
        load.type = 'button'; load.className = 'profile-load';
        const name = document.createElement('strong'); name.textContent = profile.name;
        const meta = document.createElement('small'); meta.textContent = formatDate(profile.data.date);
        load.append(name, meta);
        load.addEventListener('click', () => {
          loadProfileData(profile.data);
          trackEvent('profile_load', { storage_type: 'local', language: form.dataset.lang });
        });
        const remove = document.createElement('button');
        remove.type = 'button'; remove.className = 'profile-delete'; remove.textContent = '×';
        remove.setAttribute('aria-label', `${profile.name} · ${profileList.dataset.delete || ''}`);
        remove.addEventListener('click', () => {
          deleteProfile(profile.id); renderProfiles();
          trackEvent('profile_delete', { storage_type: 'local', language: form.dataset.lang });
        });
        row.append(load, remove); profileList.append(row);
      }
    }

    document.getElementById('save-profile')!.addEventListener('click', () => {
      const data = currentProfileData();
      if (!data) {
        form.reportValidity();
        return;
      }
      const name = profileName.value.trim() || formatDate(data.date);
      saveProfile(name, data); profileName.value = ''; renderProfiles();
      trackEvent('profile_save', { storage_type: 'local', language: form.dataset.lang });
    });
    renderProfiles();

    let onboardingStep = 1;
    const onboardingPanels = Array.from(onboarding.querySelectorAll<HTMLElement>('[data-onboarding-step]'));
    const onboardingDots = Array.from(onboarding.querySelectorAll<HTMLElement>('.onboarding-progress i'));
    const onboardingNext = document.getElementById('onboarding-next') as HTMLButtonElement;
    function renderOnboardingStep() {
      onboardingPanels.forEach((panel, index) => { panel.hidden = index !== onboardingStep - 1; });
      onboardingDots.forEach((dot, index) => dot.classList.toggle('is-active', index < onboardingStep));
      onboardingNext.textContent = onboardingStep === 3 ? onboardingNext.dataset.start! : onboardingNext.dataset.next!;
    }
    function openOnboarding(track = true) {
      onboardingStep = 1; renderOnboardingStep();
      if (!onboarding.open) onboarding.showModal();
      if (track) trackEvent('onboarding_start', { language: form.dataset.lang });
    }
    document.getElementById('open-onboarding')!.addEventListener('click', () => openOnboarding());
    onboardingNext.addEventListener('click', () => {
      if (onboardingStep < 3) {
        onboardingStep += 1; renderOnboardingStep();
        trackEvent('onboarding_step', { step_number: onboardingStep, language: form.dataset.lang });
      } else {
        try { localStorage.setItem(ONBOARDING_STORAGE_KEY, 'complete'); } catch { /* optional local preference */ }
        onboarding.close(); form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        trackEvent('onboarding_complete', { language: form.dataset.lang });
      }
    });
    onboarding.addEventListener('close', () => {
      try { localStorage.setItem(ONBOARDING_STORAGE_KEY, 'seen'); } catch { /* optional local preference */ }
    });
    document.getElementById('onboarding-skip')!.addEventListener('click', () =>
      trackEvent('onboarding_skip', { step_number: onboardingStep, language: form.dataset.lang }));
    try {
      if (!localStorage.getItem(ONBOARDING_STORAGE_KEY)) requestAnimationFrame(() => openOnboarding(false));
    } catch { /* storage or dialogs may be unavailable; the form still works */ }

    function updateReadingFocus(track = false) {
      const selected = focusInputs.find((input) => input.checked) ?? focusInputs[0];
      const title = selected?.closest('.fortune-card')?.querySelector('strong')?.textContent?.trim() || '';
      submitLabel.textContent = focusCta.replace('{reading}', title);
      if (track && selected) {
        trackEvent('reading_focus_select', { reading_focus: selected.value, selection_area: 'home', language: form.dataset.lang });
        if (matchMedia('(max-width: 859px)').matches) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    focusInputs.forEach((input) => input.addEventListener('change', () => updateReadingFocus(true)));
    updateReadingFocus();

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearError();
      const f = new FormData(form);
      let [y, m, d] = String(f.get('date')).split('-').map(Number);
      const timeUnknown = f.get('timeUnknown') === 'on';
      const [h, mi] = timeUnknown ? [12, 0] : String(f.get('time') || '12:00').split(':').map(Number);

      if (new Date(y, m - 1, d) > new Date()) {
        showError(form.dataset.errFuture!, 'date');
        dateInput.focus();
        trackEvent('chart_form_error', { error_type: 'future_value', language: form.dataset.lang });
        return;
      }

      // Lunar → solar conversion happens here, once, at the input layer.
      if (f.get('cal') === 'lunar') {
        if (y < 1900 || y > 2050) {
          showError(form.dataset.errLunar!, 'date');
          dateInput.focus();
          trackEvent('chart_form_error', { error_type: 'lunar_range', language: form.dataset.lang });
          return;
        }
        try {
          const cal = new KoreanLunarCalendar();
          if (!cal.setLunarDate(y, m, d, f.get('leap') === 'on')) throw new Error('Invalid lunar date');
          const s = cal.getSolarCalendar();
          y = s.year; m = s.month; d = s.day;
        } catch {
          showError(form.dataset.errLunar!, 'date');
          dateInput.focus();
          trackEvent('chart_form_error', { error_type: 'lunar_conversion', language: form.dataset.lang });
          return;
        }
      }

      const citySel = form.elements.namedItem('city') as HTMLSelectElement;
      if (f.get('trueSolar') === 'on' && !citySel.value) {
        showError(form.dataset.errSolarCity!, 'place');
        citySel.focus();
        trackEvent('chart_form_error', { error_type: 'solar_city_required', language: form.dataset.lang });
        return;
      }
