---
import Base from '../../layouts/Base.astro';
import { LOCALES } from '../../i18n/locales';
import { t } from '../../i18n/t';
import { CITIES } from '../../lib/cities';

export function getStaticPaths() {
  return LOCALES.map((l) => ({ params: { lang: l.code } }));
}
const { lang } = Astro.params;
---
<Base lang={lang} title={t(lang, 'meta.home.title')} description={t(lang, 'meta.home.description')} path="">
  <section class="hero">
    <div class="hero-copy">
      <div class="hero-symbols" aria-hidden="true">
        <span>木</span><span>火</span><span>土</span><span>金</span><span>水</span>
      </div>
      <h1>{t(lang, 'hero.headline')}</h1>
      <p class="hero-sub">{t(lang, 'hero.sub')}</p>
      <p class="trust-line">{t(lang, 'hero.trust')}</p>
    </div>

    <form id="birth-form" class="card birth-form" data-lang={lang}
      data-err-future={t(lang, 'form.errFuture')} data-err-lunar={t(lang, 'form.errLunarRange')}
      data-err-solar-city={t(lang, 'form.errSolarCity')}>
      <div class="form-progress" aria-hidden="true">
        <span data-progress-step="date">01</span>
        <i></i>
        <span data-progress-step="time">02</span>
        <i></i>
        <span data-progress-step="gender">03</span>
        <i></i>
        <span data-progress-step="place">04</span>
      </div>

      <div class="input-step" data-input-step="date">
        <div class="input-step__heading">
          <span class="input-step__number">01</span>
          <label for="birth-date">{t(lang, 'form.date')}</label>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <div class="field-shell">
          <span class="field-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M7 3v3m10-3v3M4 9h16M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" /></svg>
          </span>
          <input id="birth-date" class="field" type="date" name="date" required min="1900-01-01" />
        </div>
        <fieldset class="choice-field">
          <legend>{t(lang, 'form.calendar')}</legend>
          <div class="choice-grid">
            <label class="choice-tile"><input type="radio" name="cal" value="solar" checked /><span>{t(lang, 'form.solar')}</span></label>
            <label class="choice-tile"><input type="radio" name="cal" value="lunar" /><span>{t(lang, 'form.lunar')}</span></label>
          </div>
          <label class="choice-tile choice-tile--wide lunar-only" hidden><input type="checkbox" name="leap" /><span>{t(lang, 'form.lunarLeap')}</span></label>
        </fieldset>
      </div>

      <div class="input-step" data-input-step="time">
        <div class="input-step__heading">
          <span class="input-step__number">02</span>
          <label for="birth-time">{t(lang, 'form.time')}</label>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <div class="field-shell">
          <span class="field-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
          </span>
          <input id="birth-time" class="field" type="time" name="time" value="12:00" />
        </div>
        <label class="switch-row">
          <span>{t(lang, 'form.timeUnknown')}</span>
          <span class="switch-control"><input type="checkbox" name="timeUnknown" /><i aria-hidden="true"></i></span>
        </label>
      </div>

      <div class="input-step" data-input-step="gender">
        <div class="input-step__heading">
          <span class="input-step__number">03</span>
          <span class="input-step__label">{t(lang, 'form.gender')}</span>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <fieldset class="choice-field gender-field">
          <legend class="visually-hidden">{t(lang, 'form.gender')}</legend>
          <div class="choice-grid">
            <label class="choice-tile choice-tile--gender"><input type="radio" name="gender" value="f" required /><span><b aria-hidden="true">♀</b>{t(lang, 'form.genderF')}</span></label>
            <label class="choice-tile choice-tile--gender"><input type="radio" name="gender" value="m" /><span><b aria-hidden="true">♂</b>{t(lang, 'form.genderM')}</span></label>
          </div>
        </fieldset>
      </div>

      <div class="input-step" data-input-step="place">
        <div class="input-step__heading">
          <span class="input-step__number">04</span>
          <label for="birth-city">{t(lang, 'form.place')}</label>
          <span class="input-step__check" aria-hidden="true">✓</span>
        </div>
        <div class="field-shell">
          <span class="field-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z" /><circle cx="12" cy="10" r="2.5" /></svg>
          </span>
          <select id="birth-city" class="field" name="city">
            <option value="">— {t(lang, 'form.place')} (auto) —</option>
            {CITIES.map((c) => <option value={c.tz} data-lon={c.lon}>{c.name}</option>)}
          </select>
        </div>

        <details class="advanced">
          <summary>{t(lang, 'form.advanced')}</summary>
          <label class="switch-row switch-row--advanced">
            <span>{t(lang, 'form.trueSolar')}</span>
            <span class="switch-control"><input type="checkbox" name="trueSolar" /><i aria-hidden="true"></i></span>
          </label>
          <p class="hint">{t(lang, 'form.trueSolarHint')}</p>
        </details>
      </div>

      <div class="form-summary" aria-live="polite">
        <div><span>{t(lang, 'form.date')}</span><strong id="summary-date">—</strong></div>
        <div><span>{t(lang, 'form.time')}</span><strong id="summary-time">12:00</strong></div>
        <div><span>{t(lang, 'form.gender')}</span><strong id="summary-gender">—</strong></div>
        <div><span>{t(lang, 'form.place')}</span><strong id="summary-place">—</strong></div>
      </div>

      <p class="form-error" role="alert" hidden></p>
      <button class="btn-primary" type="submit"><span>{t(lang, 'hero.cta')}</span><span class="button-arrow" aria-hidden="true">→</span></button>
    </form>
  </section>

  <section class="explainer">
    <h2>{t(lang, 'explainer.title')}</h2>
    <div class="steps">
      {[1, 2, 3].map((i) => (
        <div class="card step" data-step={String(i).padStart(2, '0')}>
          <h3>{t(lang, `explainer.step${i}.title`)}</h3>
          <p>{t(lang, `explainer.step${i}.body`)}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="card waitlist">
    <h2>{t(lang, 'waitlist.title')}</h2>
    <p>{t(lang, 'waitlist.body')}</p>
    <a class="btn-secondary" href="https://pf.kakao.com/" rel="noopener" target="_blank" data-analytics-event="booking_click" data-analytics-destination="kakao_booking" data-analytics-area="home_cta">{t(lang, 'footer.booking')} <span aria-hidden="true">↗</span></a>
  </section>

  <script>
    import KoreanLunarCalendar from 'korean-lunar-calendar';
    import { tzOffsetMinutes } from '../../lib/cities';
    import { withBase } from '../../lib/paths';
    import { trackEvent } from '../../lib/analytics';

    const form = document.getElementById('birth-form') as HTMLFormElement;
    const dateInput = form.elements.namedItem('date') as HTMLInputElement;
    const timeInput = form.elements.namedItem('time') as HTMLInputElement;
    const timeUnknownInput = form.elements.namedItem('timeUnknown') as HTMLInputElement;
    const genderInputs = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="gender"]'));
    const cityInput = form.elements.namedItem('city') as HTMLSelectElement;
    const lunarOnly = form.querySelector('.lunar-only') as HTMLElement;
    const errEl = form.querySelector('.form-error') as HTMLElement;
    const steps = Array.from(form.querySelectorAll<HTMLElement>('[data-input-step]'));
    const summaryDate = form.querySelector('#summary-date') as HTMLElement;
    const summaryTime = form.querySelector('#summary-time') as HTMLElement;
    const summaryGender = form.querySelector('#summary-gender') as HTMLElement;
    const summaryPlace = form.querySelector('#summary-place') as HTMLElement;

    // Keep the static site current without requiring a rebuild each day.
    const today = new Date();
    dateInput.max = [today.getFullYear(), String(today.getMonth() + 1).padStart(2, '0'), String(today.getDate()).padStart(2, '0')].join('-');

    const stepByName = (name: string) => form.querySelector<HTMLElement>(`[data-input-step="${name}"]`);

    function clearError() {
      errEl.hidden = true;
      form.classList.remove('has-error');
      steps.forEach((step) => step.classList.remove('has-error'));
    }

    function showError(message: string, stepName: string) {
      errEl.textContent = message;
      errEl.hidden = false;
      form.classList.add('has-error');
      stepByName(stepName)?.classList.add('has-error');
    }

    function formatDate(value: string) {
      if (!value) return '—';
      const [year, month, day] = value.split('-').map(Number);
      try {
        return new Intl.DateTimeFormat(document.documentElement.lang, {
          year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
        }).format(new Date(Date.UTC(year, month - 1, day)));
      } catch {
        return value;
      }
    }

    function updateFormState() {
      timeInput.disabled = timeUnknownInput.checked;
      timeInput.closest('.field-shell')?.classList.toggle('is-disabled', timeUnknownInput.checked);

      summaryDate.textContent = formatDate(dateInput.value);
      summaryTime.textContent = timeUnknownInput.checked
        ? (timeUnknownInput.closest('.switch-row')?.querySelector(':scope > span')?.textContent?.trim() || '—')
        : (timeInput.value || '—');
      const selectedGender = genderInputs.find((input) => input.checked);
      summaryGender.textContent = selectedGender?.nextElementSibling?.textContent?.trim() || '—';
      summaryPlace.textContent = cityInput.selectedOptions[0]?.textContent?.trim() || '—';

      const completed = {
        date: Boolean(dateInput.value),
        time: Boolean(stepByName('time')?.classList.contains('is-touched') && (timeUnknownInput.checked || timeInput.value)),
        gender: Boolean(selectedGender),
        place: Boolean(stepByName('place')?.classList.contains('is-touched')),
      };

      Object.entries(completed).forEach(([name, isComplete]) => {
        stepByName(name)?.classList.toggle('is-complete', isComplete);
        form.querySelector(`[data-progress-step="${name}"]`)?.classList.toggle('is-complete', isComplete);
      });
    }

    function setActiveStep(activeStep: HTMLElement | null) {
      steps.forEach((step) => step.classList.toggle('is-active', step === activeStep));
      form.querySelectorAll('[data-progress-step]').forEach((marker) => {
        marker.classList.toggle('is-active', marker.getAttribute('data-progress-step') === activeStep?.dataset.inputStep);
      });
    }

    steps.forEach((step) => {
      step.addEventListener('focusin', () => setActiveStep(step));
      step.addEventListener('focusout', () => {
        requestAnimationFrame(() => {
          const focusedStep = steps.find((candidate) => candidate.contains(document.activeElement));
          setActiveStep(focusedStep || null);
        });
      });
      ['input', 'change'].forEach((eventName) => step.addEventListener(eventName, () => {
        step.classList.add('is-touched');
        clearError();
        updateFormState();
      }));
    });

    form.querySelectorAll('input[name="cal"]').forEach((r) =>
      r.addEventListener('change', () => {
        lunarOnly.hidden = (form.elements.namedItem('cal') as RadioNodeList).value !== 'lunar';
        updateFormState();
      })
    );

    setActiveStep(stepByName('date') || null);
    updateFormState();

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearError();
      const f = new FormData(form);
      let [y, m, d] = String(f.get('date')).split('-').map(Number);
      const timeUnknown = f.get('timeUnknown') === 'on';
      const [h, mi] = timeUnknown ? [12, 0] : String(f.get('time') || '12:00').split(':').map(Number);

      if (new Date(y, m - 1, d) > new Date()) {
        showError(form.dataset.errFuture!, 'date');
        dateInput.focus();
        trackEvent('chart_form_error', { error_type: 'future_value', language: form.dataset.lang });
        return;
      }

      // Lunar → solar conversion happens here, once, at the input layer.
      if (f.get('cal') === 'lunar') {
        if (y < 1900 || y > 2050) {
          showError(form.dataset.errLunar!, 'date');
          dateInput.focus();
          trackEvent('chart_form_error', { error_type: 'lunar_range', language: form.dataset.lang });
          return;
        }
        try {
          const cal = new KoreanLunarCalendar();
          if (!cal.setLunarDate(y, m, d, f.get('leap') === 'on')) throw new Error('Invalid lunar date');
          const s = cal.getSolarCalendar();
          y = s.year; m = s.month; d = s.day;
        } catch {
          showError(form.dataset.errLunar!, 'date');
          dateInput.focus();
          trackEvent('chart_form_error', { error_type: 'lunar_conversion', language: form.dataset.lang });
          return;
        }
      }

      const citySel = form.elements.namedItem('city') as HTMLSelectElement;
      if (f.get('trueSolar') === 'on' && !citySel.value) {
        showError(form.dataset.errSolarCity!, 'place');
        citySel.focus();
        trackEvent('chart_form_error', { error_type: 'solar_city_required', language: form.dataset.lang });
        return;
      }
      const tz = citySel.value || Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      const lon = citySel.value ? Number(citySel.selectedOptions[0].dataset.lon) : 0;
      const tzMin = tzOffsetMinutes(tz, y, m, d, h, mi);

      const q = new URLSearchParams({
        y: String(y), m: String(m), d: String(d),
        h: String(h), mi: String(mi),
        tu: timeUnknown ? '1' : '0',
        tz: String(tzMin), lon: String(lon),
        ts: f.get('trueSolar') === 'on' ? '1' : '0',
        g: String(f.get('gender')),
      });
      trackEvent('chart_submit', {
        language: form.dataset.lang,
        calendar_type: String(f.get('cal')),
        pillar_status: timeUnknown ? 'three_pillars' : 'four_pillars',
        solar_correction: f.get('trueSolar') === 'on',
      });
      location.href = withBase(`/${form.dataset.lang}/reading/`) + `?${q}`;
    });
  </script>

  <style>
    .hero { position: relative; display: grid; gap: clamp(2.5rem, 6vw, 5.5rem); grid-template-columns: 1fr; margin-block-end: var(--space-24); }
    .hero::before { content: ''; position: absolute; z-index: -1; inline-size: 25rem; block-size: 25rem; inset: -7rem auto auto -11rem; border: 1px solid rgb(198 76 59 / .13); border-radius: 50%; box-shadow: 0 0 0 3.5rem rgb(198 76 59 / .025), 0 0 0 7rem rgb(36 84 66 / .025); }
    @media (min-width: 860px) { .hero { grid-template-columns: minmax(0, 1.05fr) minmax(25rem, .85fr); align-items: center; min-height: 35rem; } }
    .hero-copy { position: relative; }
    .hero-symbols { display: inline-flex; gap: .4rem; margin-block-end: var(--space-6); }
    .hero-symbols span { display: grid; inline-size: 2.05rem; block-size: 2.05rem; place-items: center; border: 1px solid var(--line); border-radius: 50%; color: var(--ink-soft); background: rgb(255 255 255 / .62); font-family: var(--font-display); font-size: .8rem; box-shadow: 0 5px 15px rgb(35 53 44 / .05); }
    .hero-symbols span:nth-child(1) { color: var(--el-wood); }
    .hero-symbols span:nth-child(2) { color: var(--el-fire); }
    .hero-symbols span:nth-child(3) { color: var(--el-earth); }
    .hero-symbols span:nth-child(4) { color: var(--el-metal); }
    .hero-symbols span:nth-child(5) { color: var(--el-water); }
    .hero h1 { max-width: 13ch; margin: 0 0 var(--space-6); font-size: var(--text-hero); text-wrap: balance; }
    .hero-sub { max-width: 34rem; font-size: clamp(1.05rem, 2vw, 1.28rem); color: var(--ink-soft); line-height: 1.65; }
    .trust-line { display: inline-flex; align-items: center; gap: .55rem; margin-top: var(--space-3); padding: .6rem .85rem; border: 1px solid var(--line); border-radius: 999px; color: var(--ink-soft); background: rgb(255 255 255 / .55); font-size: var(--text-xs); font-weight: 650; }
    .trust-line::before { content: '✓'; display: grid; inline-size: 1.2rem; block-size: 1.2rem; place-items: center; border-radius: 50%; color: white; background: var(--indigo); font-size: .68rem; }
    .birth-form { position: relative; padding: clamp(1.1rem, 3vw, 1.6rem); display: grid; gap: var(--space-3); box-shadow: var(--shadow-float); }
    .birth-form::before { content: ''; position: absolute; inset: 0 0 auto; height: .35rem; background: linear-gradient(90deg, var(--el-wood), var(--el-fire), var(--el-earth), var(--el-metal), var(--el-water)); }
    .form-progress { display: flex; align-items: center; justify-content: center; gap: .45rem; margin: .35rem auto .15rem; color: var(--ink-soft); font-family: var(--font-mono); font-size: .65rem; font-weight: 800; letter-spacing: .08em; }
    .form-progress span { display: grid; inline-size: 1.75rem; block-size: 1.75rem; place-items: center; border: 1px solid var(--line); border-radius: 50%; background: var(--paper-raised); transition: color var(--dur-fast), border-color var(--dur-fast), background var(--dur-fast), transform var(--dur-fast); }
    .form-progress i { inline-size: clamp(1.5rem, 5vw, 3.5rem); block-size: 1px; background: linear-gradient(90deg, var(--line), #d8ddd9); }
    .form-progress span.is-active { color: white; border-color: var(--vermilion); background: var(--vermilion); transform: scale(1.08); }
    .form-progress span.is-complete { color: white; border-color: var(--indigo); background: var(--indigo); }
    .input-step { position: relative; display: grid; gap: .8rem; padding: 1rem; border: 1px solid color-mix(in srgb, var(--line) 88%, transparent); border-radius: var(--radius); background: color-mix(in srgb, var(--paper-raised) 72%, transparent); box-shadow: 0 5px 18px rgb(35 53 44 / .035); transition: transform var(--dur-fast) var(--ease-reveal), border-color var(--dur-fast), background var(--dur-fast), box-shadow var(--dur-fast); }
    .input-step::before { content: ''; position: absolute; inset: .8rem auto .8rem 0; inline-size: 3px; border-radius: 0 3px 3px 0; background: var(--line); transition: background var(--dur-fast), transform var(--dur-fast); transform: scaleY(.45); }
    .input-step:hover { border-color: #cbd2cd; background: rgb(255 255 255 / .8); }
    .input-step.is-active, .input-step:focus-within { z-index: 1; border-color: color-mix(in srgb, var(--indigo) 52%, var(--line)); background: rgb(255 255 255 / .94); box-shadow: 0 13px 30px rgb(36 84 66 / .11); transform: translateY(-2px); }
    .input-step.is-active::before, .input-step:focus-within::before { background: var(--vermilion); transform: scaleY(1); }
    .input-step.is-complete::before { background: var(--indigo); }
    .input-step.has-error { border-color: color-mix(in srgb, var(--vermilion) 62%, var(--line)); background: color-mix(in srgb, #fff4ef 68%, white); }
    .input-step__heading { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: .65rem; }
    .input-step__heading label, .input-step__label { font-size: var(--text-sm); font-weight: 800; cursor: pointer; }
    .input-step__number { color: var(--vermilion); font-family: var(--font-mono); font-size: .68rem; font-weight: 850; letter-spacing: .08em; }
    .input-step__check { display: grid; inline-size: 1.35rem; block-size: 1.35rem; place-items: center; border-radius: 50%; color: white; background: var(--indigo); font-size: .72rem; opacity: 0; transform: scale(.72); transition: opacity var(--dur-fast), transform var(--dur-fast); }
    .input-step.is-complete .input-step__check { opacity: 1; transform: scale(1); }
    .field-shell { position: relative; }
    .field-shell .field { min-height: 3.25rem; padding-inline-start: 2.9rem; border-color: color-mix(in srgb, var(--line) 88%, transparent); background: color-mix(in srgb, var(--paper-sunken) 45%, white); font-weight: 650; }
    .field-shell .field:focus { background: white; }
    .field-icon { position: absolute; z-index: 1; inset: 50% auto auto .9rem; display: grid; inline-size: 1.2rem; block-size: 1.2rem; place-items: center; color: var(--ink-soft); pointer-events: none; transform: translateY(-50%); transition: color var(--dur-fast), transform var(--dur-fast); }
    .field-icon svg { inline-size: 100%; block-size: 100%; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
    .field-shell:focus-within .field-icon { color: var(--indigo); transform: translateY(-50%) scale(1.08); }
    .field-shell.is-disabled { opacity: .48; }
    .field-shell.is-disabled .field { cursor: not-allowed; }
    .choice-field { min-width: 0; margin: 0; padding: 0; border: 0; }
    .choice-field legend { margin-block-end: .45rem; padding: 0; color: var(--ink-soft); font-size: .7rem; font-weight: 750; }
    .choice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }
    .choice-tile { position: relative; cursor: pointer; }
    .choice-tile input { position: absolute; inline-size: 1px; block-size: 1px; opacity: 0; pointer-events: none; }
    .choice-tile > span { display: flex; min-height: 2.45rem; align-items: center; justify-content: center; border: 1px solid var(--line); border-radius: .75rem; padding: .5rem .75rem; color: var(--ink-soft); background: rgb(255 255 255 / .62); font-size: var(--text-xs); font-weight: 750; transition: color var(--dur-fast), border-color var(--dur-fast), background var(--dur-fast), box-shadow var(--dur-fast), transform var(--dur-fast); }
    .choice-tile:hover > span { border-color: #aebdb5; transform: translateY(-1px); }
    .choice-tile input:checked + span { color: var(--indigo); border-color: color-mix(in srgb, var(--indigo) 52%, white); background: color-mix(in srgb, #dcebe2 68%, white); box-shadow: inset 0 0 0 1px rgb(36 84 66 / .08); }
    .choice-tile input:focus-visible + span { outline: 3px solid color-mix(in srgb, var(--indigo) 68%, white); outline-offset: 2px; }
    .choice-tile--wide { display: block; margin-top: .5rem; }
    .choice-tile--gender > span { gap: .55rem; min-height: 3rem; }
    .choice-tile--gender b { display: grid; inline-size: 1.45rem; block-size: 1.45rem; place-items: center; border-radius: 50%; color: var(--vermilion); background: var(--peach-pale); font-size: .95rem; }
    .choice-tile--gender input:checked + span b { color: white; background: var(--indigo); }
    .switch-row { display: flex; min-height: 2rem; align-items: center; justify-content: space-between; gap: 1rem; color: var(--ink-soft); font-size: var(--text-xs); font-weight: 700; cursor: pointer; }
    .switch-control { position: relative; flex: 0 0 auto; inline-size: 2.75rem; block-size: 1.55rem; }
    .switch-control input { position: absolute; inset: 0; inline-size: 100%; block-size: 100%; margin: 0; opacity: 0; cursor: pointer; }
    .switch-control i { display: block; inline-size: 100%; block-size: 100%; border: 1px solid #c8ceca; border-radius: 999px; background: #e7e8e4; transition: border-color var(--dur-fast), background var(--dur-fast), box-shadow var(--dur-fast); }
