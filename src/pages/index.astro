---
// Root: client-side language detection → /{lang}/, fallback /en/.
import { LOCALES, DEFAULT_LOCALE } from '../i18n/locales';
const codes = LOCALES.map((l) => l.code);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Show Me the Saju</title>
    <meta name="robots" content="noindex" />
    <script define:vars={{ codes, DEFAULT_LOCALE }}>
      const prefs = navigator.languages.map((l) => l.toLowerCase());
      let target = DEFAULT_LOCALE;
      for (const p of prefs) {
        const hit = codes.find((c) => p === c || p.startsWith(c + '-') || c.startsWith(p));
        if (hit) { target = hit; break; }
      }
      location.replace('/' + target + '/');
    </script>
    <noscript><meta http-equiv="refresh" content="0; url=/en/" /></noscript>
  </head>
  <body></body>
</html>
