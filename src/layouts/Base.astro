---
import { LOCALES, DEFAULT_LOCALE } from '../i18n/locales';
import { t } from '../i18n/t';
import { withBase } from '../lib/paths';
import '../styles/tokens.css';

interface Props {
  lang: string;
  title: string;
  description?: string;
  /** Path AFTER the locale segment, e.g. '' for home, 'learn' for /xx/learn */
  path?: string;
  noindex?: boolean;
}
const { lang, title, description = '', path = '', noindex = false } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://showmethesaju.com';
const sub = path ? `${path}/` : '';
const canonical = `${site}/${lang}/${sub}`;
const htmlLang = LOCALES.find((l) => l.code === lang)?.htmlLang ?? lang;
const year = new Date().getFullYear();

const nav = [
  { href: withBase(`/${lang}/reading/`), label: t(lang, 'nav.reading') },
  { href: withBase(`/${lang}/compatibility/`), label: t(lang, 'nav.compatibility') },
  { href: withBase(`/${lang}/learn/`), label: t(lang, 'nav.learn') },
  { href: withBase(`/${lang}/glossary/`), label: t(lang, 'nav.glossary') },
  { href: withBase(`/${lang}/about/`), label: t(lang, 'nav.about') },
];
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={l.htmlLang} href={`${site}/${l.code}/${sub}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${site}/${DEFAULT_LOCALE}/${sub}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <!-- TODO Phase 2: self-host fonts in /public/fonts (see PLAN.md) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Gowun+Batang:wght@400;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="logo" href={withBase(`/${lang}/`)}>
          <span class="seal seal--logo" aria-hidden="true">쇼미</span>
          <span class="logo-text">{t(lang, 'meta.siteName')}</span>
        </a>
        <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">☰</button>
        <nav id="site-nav" class="site-nav">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <div class="lang-switch">
          <label class="visually-hidden" for="lang-select">{t(lang, 'nav.language')}</label>
          <select id="lang-select" class="field field--lang" data-current={lang}>
            {LOCALES.map((l) => (
              <option value={l.code} selected={l.code === lang}>{l.name}</option>
            ))}
          </select>
        </div>
      </div>
    </header>

    <main class="site-main"><slot /></main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-links">
          <a href="https://smartstore.naver.com/" rel="noopener" target="_blank">{t(lang, 'footer.shop')}</a>
          <a href="https://pf.kakao.com/" rel="noopener" target="_blank">{t(lang, 'footer.booking')}</a>
          <a href={withBase(`/${lang}/privacy/`)}>{t(lang, 'footer.privacy')}</a>
        </div>
        <p class="footer-rights">{t(lang, 'footer.rights', { year })}</p>
      </div>
    </footer>

    <script>
      // Language switcher: preserve the current sub-path across locales.
      const sel = document.getElementById('lang-select') as HTMLSelectElement | null;
      const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // '' or '/showmethesaju'
      sel?.addEventListener('change', () => {
        const current = sel.dataset.current!;
        const next = sel.value;
        const url = new URL(location.href);
        let path = url.pathname;
        if (base && path.startsWith(base)) path = path.slice(base.length); // strip base before swapping locale
        const parts = path.split('/');
        if (parts[1] === current) parts[1] = next; else parts.splice(1, 0, next);
        url.pathname = base + parts.join('/');
        location.href = url.toString();
      });
      // Mobile nav toggle.
      const btn = document.querySelector('.nav-toggle');
      const navEl = document.getElementById('site-nav');
      btn?.addEventListener('click', () => {
        const open = navEl?.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(!!open));
      });
    </script>

    <style>
      .site-header { border-bottom: 1px solid var(--line); background: var(--paper); position: sticky; top: 0; z-index: 10; }
      .header-inner, .footer-inner { max-width: var(--container); margin: 0 auto; padding: var(--space-3) var(--space-4); }
      .header-inner { display: flex; align-items: center; gap: var(--space-4); }
      .logo { display: flex; align-items: center; gap: var(--space-2); text-decoration: none; color: var(--ink); }
      .seal--logo { inline-size: 2rem; block-size: 2rem; font-size: var(--text-xs); }
      .logo-text { font-family: var(--font-display); font-weight: 700; font-size: var(--text-lg); }
      .site-nav { display: flex; gap: var(--space-4); margin-inline-start: auto; }
      .site-nav a { color: var(--ink); text-decoration: none; font-size: var(--text-sm); }
      .site-nav a:hover { color: var(--indigo); text-decoration: underline; }
      .lang-switch { margin-inline-start: var(--space-2); }
      .field--lang { padding: var(--space-1) var(--space-2); font-size: var(--text-sm); }
      .nav-toggle { display: none; background: none; border: 1px solid var(--line); border-radius: var(--radius-sm); font-size: var(--text-lg); padding: 0 var(--space-2); cursor: pointer; }
      .visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
      .site-main { max-width: var(--container); margin: 0 auto; padding: var(--space-8) var(--space-4) var(--space-16); }
      .site-footer { border-top: 1px solid var(--line); background: var(--paper-sunken); }
      .footer-links { display: flex; flex-wrap: wrap; gap: var(--space-4); }
      .footer-rights { color: var(--ink-soft); font-size: var(--text-sm); }
      @media (max-width: 720px) {
        .nav-toggle { display: block; margin-inline-start: auto; }
        .site-nav { display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--paper); border-bottom: 1px solid var(--line); flex-direction: column; padding: var(--space-4); }
        .site-nav.open { display: flex; }
        .lang-switch { margin-inline-start: 0; }
      }
    </style>
  </body>
</html>
