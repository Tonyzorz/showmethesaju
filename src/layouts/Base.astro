---
import { LOCALES, DEFAULT_LOCALE } from '../i18n/locales';
import { t } from '../i18n/t';
import { withBase } from '../lib/paths';
import AnalyticsConsent from '../components/AnalyticsConsent.astro';
import { GA_MEASUREMENT_ID } from '../lib/analytics';
import '../styles/tokens.css';

interface Props {
  lang: string;
  title: string;
  description?: string;
  /** Path AFTER the locale segment, e.g. '' for home, 'learn' for /xx/learn */
  path?: string;
  noindex?: boolean;
}
const { lang, title, description = '', path = '', noindex = false } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://tonyzorz.github.io/showmethesaju';
const sub = path ? `${path}/` : '';
const canonical = `${site}/${lang}/${sub}`;
const htmlLang = LOCALES.find((l) => l.code === lang)?.htmlLang ?? lang;
const year = new Date().getFullYear();

const nav = [
  { href: withBase(`/${lang}/reading/`), label: t(lang, 'nav.reading'), analyticsKey: 'reading' },
  { href: withBase(`/${lang}/compatibility/`), label: t(lang, 'nav.compatibility'), analyticsKey: 'compatibility' },
  { href: withBase(`/${lang}/learn/`), label: t(lang, 'nav.learn'), analyticsKey: 'learn' },
  { href: withBase(`/${lang}/glossary/`), label: t(lang, 'nav.glossary'), analyticsKey: 'glossary' },
  { href: withBase(`/${lang}/about/`), label: t(lang, 'nav.about'), analyticsKey: 'about' },
];

const commerce = [
  { href: 'https://smartstore.naver.com/', label: t(lang, 'footer.shop'), className: 'shop-link', analyticsEvent: 'shop_click', analyticsKey: 'naver_store' },
  { href: 'https://pf.kakao.com/', label: t(lang, 'footer.booking'), className: 'booking-link', analyticsEvent: 'booking_click', analyticsKey: 'kakao_booking' },
];
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={l.htmlLang} href={`${site}/${l.code}/${sub}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${site}/${DEFAULT_LOCALE}/${sub}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t(lang, 'meta.siteName')} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />
    <meta property="og:image" content={`${site}/og/og-default.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${site}/og/og-default.png`} />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="icon" href={withBase('/icons/favicon-32.png')} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={withBase('/icons/apple-touch-icon.png')} />
    <meta name="theme-color" content="#f8f7f3" />
    <script is:inline define:vars={{ measurementId: GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.__sajuAnalyticsMeasurementId = measurementId;
      window.gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
      window.gtag('set', 'ads_data_redaction', true);
    </script>
    <!-- Self-hosted fonts (scripts/fetch-fonts.mjs): no third-party requests,
         keeps the "your data never leaves your device" claim honest. -->
    <link rel="stylesheet" href={withBase('/fonts/fonts.css')} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="logo" href={withBase(`/${lang}/`)} data-analytics-event="navigation_click" data-analytics-destination="home" data-analytics-area="header">
          <span class="seal seal--logo" aria-hidden="true">쇼미</span>
          <span class="logo-text">{t(lang, 'meta.siteName')}</span>
        </a>
        <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">☰</button>
        <nav id="site-nav" class="site-nav">
          {nav.map((n) => <a href={n.href} data-analytics-event="navigation_click" data-analytics-destination={n.analyticsKey} data-analytics-area="header">{n.label}</a>)}
          <div class="nav-commerce">
            {commerce.map((item) => (
              <a class={item.className} href={item.href} rel="noopener" target="_blank" data-analytics-event={item.analyticsEvent} data-analytics-destination={item.analyticsKey} data-analytics-area="mobile_menu">{item.label}<span aria-hidden="true">↗</span></a>
            ))}
          </div>
        </nav>
        <div class="header-actions">
          {commerce.map((item) => (
            <a class={item.className} href={item.href} rel="noopener" target="_blank" data-analytics-event={item.analyticsEvent} data-analytics-destination={item.analyticsKey} data-analytics-area="header">{item.label}<span aria-hidden="true">↗</span></a>
          ))}
        </div>
        <div class="lang-switch">
          <label class="visually-hidden" for="lang-select">{t(lang, 'nav.language')}</label>
          <select id="lang-select" class="field field--lang" data-current={lang}>
            {LOCALES.map((l) => (
              <option value={l.code} selected={l.code === lang}>{l.name}</option>
            ))}
          </select>
        </div>
      </div>
    </header>

    <main class="site-main"><slot /></main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-links">
          <a href="https://smartstore.naver.com/" rel="noopener" target="_blank" data-analytics-event="shop_click" data-analytics-destination="naver_store" data-analytics-area="footer">{t(lang, 'footer.shop')}</a>
          <a href="https://pf.kakao.com/" rel="noopener" target="_blank" data-analytics-event="booking_click" data-analytics-destination="kakao_booking" data-analytics-area="footer">{t(lang, 'footer.booking')}</a>
          <a href={withBase(`/${lang}/privacy/`)} data-analytics-event="navigation_click" data-analytics-destination="privacy" data-analytics-area="footer">{t(lang, 'footer.privacy')}</a>
          <button id="analytics-settings" class="footer-settings" type="button">{t(lang, 'analytics.settings')}</button>
        </div>
        <p class="footer-rights">{t(lang, 'footer.rights', { year })}</p>
      </div>
    </footer>

    <AnalyticsConsent lang={lang} />

    <script>
      import { trackEvent } from '../lib/analytics';

      // Language switcher: preserve the current sub-path across locales.
      const sel = document.getElementById('lang-select') as HTMLSelectElement | null;
      const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // '' or '/showmethesaju'
      sel?.addEventListener('change', () => {
        const current = sel.dataset.current!;
        const next = sel.value;
        trackEvent('language_change', { from_language: current, to_language: next });
        const url = new URL(location.href);
        let path = url.pathname;
        if (base && path.startsWith(base)) path = path.slice(base.length); // strip base before swapping locale
        const parts = path.split('/');
        if (parts[1] === current) parts[1] = next; else parts.splice(1, 0, next);
        url.pathname = base + parts.join('/');
        location.href = url.toString();
      });
      // Mobile nav toggle.
      const btn = document.querySelector('.nav-toggle');
      const navEl = document.getElementById('site-nav');
      btn?.addEventListener('click', () => {
        const open = navEl?.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(!!open));
      });
    </script>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid color-mix(in srgb, var(--line) 75%, transparent);
        background: color-mix(in srgb, var(--paper) 88%, transparent);
        box-shadow: 0 10px 30px rgb(31 43 37 / 0.04);
        backdrop-filter: blur(18px) saturate(130%);
      }
      .header-inner, .footer-inner { max-width: var(--container); margin: 0 auto; padding: var(--space-3) var(--space-5); }
      .header-inner { display: flex; align-items: center; gap: clamp(.75rem, 1.6vw, 1.5rem); min-height: 4.5rem; }
      .logo { display: flex; align-items: center; gap: .7rem; text-decoration: none; color: var(--ink); flex: 0 0 auto; }
      .seal--logo { inline-size: 2.25rem; block-size: 2.25rem; font-size: .67rem; border-width: 2px; border-radius: .55rem; }
      .logo-text { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; white-space: nowrap; }
      .site-nav { display: flex; align-items: center; gap: clamp(.75rem, 1.5vw, 1.35rem); margin-inline-start: auto; }
      .site-nav > a { position: relative; color: var(--ink-soft); text-decoration: none; font-size: .84rem; font-weight: 650; white-space: nowrap; }
      .site-nav > a::after { content: ''; position: absolute; inset: auto 0 -.55rem; height: 2px; border-radius: 2px; background: var(--indigo); transform: scaleX(0); transition: transform var(--dur-fast) var(--ease-reveal); }
      .site-nav > a:hover { color: var(--ink); }
      .site-nav > a:hover::after { transform: scaleX(1); }
      .header-actions { display: flex; align-items: center; gap: .5rem; padding-inline-start: .3rem; border-inline-start: 1px solid var(--line); }
      .header-actions a, .nav-commerce a { display: inline-flex; align-items: center; gap: .35rem; text-decoration: none; white-space: nowrap; font-size: .78rem; font-weight: 700; border-radius: 999px; transition: transform var(--dur-fast), box-shadow var(--dur-fast), background var(--dur-fast); }
      .header-actions a:hover, .nav-commerce a:hover { transform: translateY(-1px); }
      .shop-link { color: var(--indigo); background: var(--paper-raised); border: 1px solid var(--line); padding: .55rem .75rem; }
      .booking-link { color: #fff; background: var(--indigo); border: 1px solid var(--indigo); padding: .55rem .8rem; box-shadow: 0 6px 16px rgb(31 80 64 / .16); }
      .lang-switch { margin-inline-start: 0; }
      .field--lang { width: auto; min-width: 5rem; padding: .52rem 1.7rem .52rem .65rem; font-size: .78rem; border-radius: 999px; background-color: var(--paper-raised); }
      .nav-toggle { display: none; background: var(--paper-raised); color: var(--ink); border: 1px solid var(--line); border-radius: 999px; font-size: var(--text-lg); line-height: 1; inline-size: 2.65rem; block-size: 2.65rem; cursor: pointer; }
      .nav-commerce { display: none; }
      .visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
      .site-main { position: relative; max-width: var(--container); margin: 0 auto; padding: clamp(2.75rem, 6vw, 5rem) var(--space-5) var(--space-24); }
      .site-footer { border-top: 1px solid var(--line); background: color-mix(in srgb, var(--paper-sunken) 72%, transparent); }
      .footer-inner { padding-block: var(--space-8); }
      .footer-links { display: flex; flex-wrap: wrap; gap: var(--space-5); }
      .footer-links a { color: var(--ink); font-size: var(--text-sm); font-weight: 650; text-decoration: none; }
      .footer-settings { appearance: none; border: 0; padding: 0; color: var(--ink); background: transparent; font: inherit; font-size: var(--text-sm); font-weight: 650; cursor: pointer; }
      .footer-links a:hover, .footer-settings:hover { color: var(--indigo); }
      .footer-rights { color: var(--ink-soft); font-size: var(--text-sm); margin-block-end: 0; }
      @media (max-width: 1120px) {
        .header-actions .shop-link { display: none; }
      }
      @media (max-width: 940px) {
        .nav-toggle { display: block; margin-inline-start: auto; }
        .site-nav { display: none; position: absolute; top: calc(100% + .5rem); left: var(--space-4); right: var(--space-4); background: color-mix(in srgb, var(--paper-raised) 96%, transparent); border: 1px solid var(--line); box-shadow: var(--shadow-float); border-radius: var(--radius-lg); flex-direction: column; align-items: stretch; gap: .2rem; padding: var(--space-3); }
        .site-nav.open { display: flex; }
        .site-nav > a { padding: .7rem .8rem; border-radius: var(--radius-sm); }
        .site-nav > a:hover { background: var(--paper-sunken); }
        .site-nav > a::after { display: none; }
        .nav-commerce { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; border-top: 1px solid var(--line); margin-top: .4rem; padding-top: .75rem; }
        .nav-commerce a { justify-content: center; padding: .7rem; }
        .header-actions { display: none; }
        .lang-switch { margin-inline-start: 0; }
      }
      @media (max-width: 540px) {
        .header-inner { min-height: 4rem; padding-inline: var(--space-4); }
        .logo-text { font-size: 1rem; }
        .site-main { padding-inline: var(--space-4); }
        .nav-commerce { grid-template-columns: 1fr; }
      }
    </style>
  </body>
</html>
